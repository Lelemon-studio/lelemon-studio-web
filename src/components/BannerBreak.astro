---
interface Props {
  whatsappUrl: string;
}
const { whatsappUrl } = Astro.props;
---

<section id="banner-cta" class="relative bg-yellow-400 py-16 px-6 sm:px-10 overflow-hidden">
  <div class="absolute inset-0 diagonal-lines-dark opacity-[0.06]"></div>
  <div class="max-w-7xl mx-auto relative">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
      <p class="text-2xl sm:text-3xl lg:text-4xl font-black text-neutral-950 leading-tight max-w-2xl">
        En 2 semanas ya estás operando. Lo demás depende de ti.
      </p>
      <button type="button" data-open-lead-modal class="shrink-0 inline-flex items-center gap-3 bg-neutral-950 hover:bg-neutral-800 text-white font-bold px-8 py-4 transition-all text-sm uppercase tracking-wider">
        Hablemos
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </button>
    </div>
  </div>
</section>
