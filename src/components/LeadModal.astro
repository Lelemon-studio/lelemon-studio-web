---
import {
  API_URL,
  TURNSTILE_SITE_KEY,
  LEAD_FORM_ID,
  LEAD_FORM_API_KEY,
} from '../config';

interface Props {
  whatsappUrl: string;
}
const { whatsappUrl } = Astro.props;
---

<div
  id="lead-modal"
  class="hidden fixed inset-0 z-[100] items-center justify-center p-4 sm:p-6"
  aria-hidden="true"
  aria-modal="true"
  role="dialog"
>
  <!-- Overlay -->
  <div id="lead-modal-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-sm" data-close-lead-modal></div>

  <!-- Modal card -->
  <div class="relative w-full max-w-lg bg-neutral-950 border border-neutral-800 shadow-2xl overflow-y-auto max-h-[90vh]">
    <!-- Close -->
    <button
      type="button"
      data-close-lead-modal
      aria-label="Cerrar"
      class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center text-neutral-500 hover:text-white transition-colors z-10"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <!-- Header -->
    <div class="p-6 sm:p-8 border-b border-neutral-800">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-px bg-yellow-400"></div>
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-yellow-400/80">Hablemos</span>
      </div>
      <h3 class="text-2xl sm:text-3xl font-black text-white leading-tight">
        Cuéntanos de tu negocio.
      </h3>
      <p class="mt-2 text-sm text-neutral-400">
        20 minutos. Evaluamos si podemos ayudarte. Sin compromiso.
      </p>
    </div>

    <!-- Form -->
    <form id="modal-lead-form" class="p-6 sm:p-8 space-y-5" novalidate>
      <div>
        <label for="modal-lead-name" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">Nombre</label>
        <input
          type="text"
          id="modal-lead-name"
          name="name"
          required
          autocomplete="name"
          placeholder="Tu nombre"
          class="w-full bg-neutral-900 border border-neutral-800 text-white px-4 py-3 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
        />
      </div>
      <div>
        <label for="modal-lead-email" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">Email</label>
        <input
          type="email"
          id="modal-lead-email"
          name="email"
          required
          autocomplete="email"
          placeholder="tu@correo.com"
          class="w-full bg-neutral-900 border border-neutral-800 text-white px-4 py-3 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
        />
      </div>
      <div>
        <label for="modal-lead-phone" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">Teléfono</label>
        <input
          type="tel"
          id="modal-lead-phone"
          name="phone"
          autocomplete="tel"
          placeholder="+56 9 XXXX XXXX"
          class="w-full bg-neutral-900 border border-neutral-800 text-white px-4 py-3 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
        />
      </div>
      <div>
        <label for="modal-lead-business" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">¿A qué se dedica tu negocio?</label>
        <input
          type="text"
          id="modal-lead-business"
          name="business"
          required
          placeholder="Clínica dental, abogados, tienda..."
          class="w-full bg-neutral-900 border border-neutral-800 text-white px-4 py-3 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
        />
      </div>
      <div>
        <label for="modal-lead-website" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">Sitio web o Instagram <span class="text-neutral-600 font-normal normal-case">(opcional)</span></label>
        <input
          type="text"
          id="modal-lead-website"
          name="website"
          placeholder="minegocio.cl · @minegocio"
          class="w-full bg-neutral-900 border border-neutral-800 text-white px-4 py-3 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
        />
      </div>
      <div>
        <label for="modal-lead-help" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">¿En qué te podemos apoyar? <span class="text-neutral-600 font-normal normal-case">(opcional)</span></label>
        <textarea
          id="modal-lead-help"
          name="help"
          rows="2"
          placeholder="Cuéntanos brevemente qué necesitas."
          class="w-full bg-neutral-900 border border-neutral-800 text-white px-4 py-3 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors resize-none"
        ></textarea>
      </div>
      <div class="flex items-start gap-3">
        <input type="checkbox" id="modal-lead-consent" name="consent" required class="mt-1 w-4 h-4 accent-yellow-400 bg-neutral-900 border-neutral-700" />
        <label for="modal-lead-consent" class="text-xs text-neutral-500 leading-relaxed">Acepto que Lelemon me contacte para agendar una llamada. No spam.</label>
      </div>

      <!-- Cloudflare Turnstile (invisible) -->
      <div id="modal-turnstile-container"></div>

      <button
        type="submit"
        id="modal-lead-submit"
        class="w-full bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold py-3.5 px-6 text-sm uppercase tracking-wider transition-all disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Quiero mi evaluación gratuita
      </button>
      <p id="modal-form-feedback" class="text-sm text-center hidden"></p>

      <!-- WhatsApp fallback -->
      <div class="pt-3 text-center border-t border-neutral-800">
        <p class="text-xs text-neutral-500 mb-2">¿Prefieres WhatsApp?</p>
        <a
          href={whatsappUrl}
          target="_blank"
          data-wa-cta
          class="inline-flex items-center gap-2 text-sm text-neutral-400 hover:text-yellow-400 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escríbenos directo
        </a>
      </div>
    </form>

    <!-- Success state (hidden by default) -->
    <div id="modal-form-success" class="hidden text-center p-10">
      <div class="w-16 h-16 bg-yellow-400/10 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-3">¡Recibimos tus datos!</h3>
      <p class="text-neutral-400 max-w-sm mx-auto text-sm">Te contactamos en menos de 24 horas para agendar tu evaluación.</p>
      <button type="button" data-close-lead-modal class="mt-8 text-yellow-400 hover:text-yellow-300 text-sm font-bold uppercase tracking-wider">
        Cerrar
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ TURNSTILE_SITE_KEY, FORM_API_URL: API_URL, FORM_ID: LEAD_FORM_ID, FORM_API_KEY: LEAD_FORM_API_KEY }}>
  (function() {
    var modal = document.getElementById('lead-modal');
    var form = document.getElementById('modal-lead-form');
    var submitBtn = document.getElementById('modal-lead-submit');
    var feedback = document.getElementById('modal-form-feedback');
    var successEl = document.getElementById('modal-form-success');
    var turnstileToken = '';
    var turnstileWidgetId = null;
    var turnstileInitialized = false;

    function openModal() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      // Tracking
      if (typeof fbq === 'function') fbq('track', 'ViewContent', { content_name: 'Lead Modal' });
      if (typeof gtag === 'function') gtag('event', 'modal_open', { event_category: 'Form', event_label: 'Lead Modal' });

      // Init turnstile lazy
      if (!turnstileInitialized && TURNSTILE_SITE_KEY && typeof turnstile !== 'undefined') {
        initTurnstile();
      }

      // Focus primer input
      setTimeout(function() {
        var nameInput = document.getElementById('modal-lead-name');
        if (nameInput) nameInput.focus();
      }, 50);
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function initTurnstile() {
      if (!TURNSTILE_SITE_KEY || typeof turnstile === 'undefined') return;
      turnstileWidgetId = turnstile.render('#modal-turnstile-container', {
        sitekey: TURNSTILE_SITE_KEY,
        callback: function(token) { turnstileToken = token; },
        'expired-callback': function() { turnstileToken = ''; },
        'error-callback': function() { turnstileToken = ''; },
        size: 'invisible',
      });
      turnstileInitialized = true;
    }

    // Wire opening
    document.querySelectorAll('[data-open-lead-modal]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.preventDefault();
        openModal();
      });
    });

    // Wire closing
    document.querySelectorAll('[data-close-lead-modal]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        closeModal();
      });
    });

    // ESC to close
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    function showFeedback(msg, isError) {
      feedback.textContent = msg;
      feedback.className = 'text-sm text-center mt-2 ' + (isError ? 'text-red-400' : 'text-green-400');
    }

    function setLoading(loading) {
      submitBtn.disabled = loading;
      submitBtn.textContent = loading ? 'Enviando...' : 'Quiero mi evaluación gratuita';
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      feedback.className = 'text-sm text-center hidden';

      var name = document.getElementById('modal-lead-name').value.trim();
      var email = document.getElementById('modal-lead-email').value.trim();
      var phone = document.getElementById('modal-lead-phone').value.trim();
      var business = document.getElementById('modal-lead-business').value.trim();
      var website = document.getElementById('modal-lead-website').value.trim();
      var help = document.getElementById('modal-lead-help').value.trim();
      var consent = document.getElementById('modal-lead-consent').checked;

      if (!name) { showFeedback('Ingresa tu nombre', true); return; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showFeedback('Ingresa un email válido', true); return;
      }
      if (!business) { showFeedback('Cuéntanos a qué se dedica tu negocio', true); return; }
      if (!consent) { showFeedback('Debes aceptar ser contactado', true); return; }
      if (!FORM_API_URL || !FORM_ID || !FORM_API_KEY) {
        showFeedback('Formulario no configurado', true); return;
      }

      if (TURNSTILE_SITE_KEY && !turnstileToken && typeof turnstile !== 'undefined') {
        turnstile.execute('#modal-turnstile-container');
        var attempts = 0;
        var wait = setInterval(function() {
          attempts++;
          if (turnstileToken || attempts > 20) {
            clearInterval(wait);
            if (turnstileToken) {
              submitLead(name, email, phone, business, website, help);
            } else {
              showFeedback('Error de verificación. Intenta de nuevo.', true);
            }
          }
        }, 250);
        return;
      }

      submitLead(name, email, phone, business, website, help);
    });

    function submitLead(name, email, phone, business, website, help) {
      setLoading(true);

      // Concat business/website/help al phone (backend acepta name/email/phone/turnstile)
      var phoneWithContext = phone || '';
      if (business) phoneWithContext += (phoneWithContext ? ' | ' : '') + 'Negocio: ' + business;
      if (website) phoneWithContext += (phoneWithContext ? ' | ' : '') + 'Web/IG: ' + website;
      if (help) phoneWithContext += (phoneWithContext ? ' | ' : '') + 'Ayuda: ' + help;

      fetch(FORM_API_URL + '/public/forms/' + FORM_ID + '/leads', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': FORM_API_KEY,
        },
        body: JSON.stringify({
          name: name,
          email: email,
          phone: phoneWithContext || undefined,
          turnstileToken: turnstileToken || 'no-turnstile',
        }),
      })
      .then(function(res) {
        if (!res.ok) {
          return res.json().then(function(data) {
            throw new Error(data.message || 'Error al enviar');
          });
        }
        return res.json();
      })
      .then(function() {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');

        if (typeof fbq === 'function') fbq('track', 'Lead', { content_name: 'Lead Modal' });
        if (typeof gtag === 'function') gtag('event', 'generate_lead', { event_category: 'Form', event_label: 'Lead Modal' });
      })
      .catch(function(err) {
        showFeedback(err.message || 'Error al enviar. Intenta de nuevo.', true);
        if (typeof turnstile !== 'undefined' && turnstileWidgetId !== null) {
          turnstile.reset(turnstileWidgetId);
          turnstileToken = '';
        }
      })
      .finally(function() {
        setLoading(false);
      });
    }
  })();
</script>
