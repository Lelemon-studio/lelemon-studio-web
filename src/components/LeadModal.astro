---
import {
  API_URL,
  TURNSTILE_SITE_KEY,
  LEAD_FORM_ID,
  LEAD_FORM_API_KEY,
} from '../config';

interface Props {
  whatsappUrl: string;
}
const { whatsappUrl } = Astro.props;

// Países ordenados por probabilidad del ICP (Chile primero)
const COUNTRIES = [
  { code: "+56",  name: "Chile",        flag: "🇨🇱" },
  { code: "+52",  name: "México",       flag: "🇲🇽" },
  { code: "+54",  name: "Argentina",    flag: "🇦🇷" },
  { code: "+57",  name: "Colombia",     flag: "🇨🇴" },
  { code: "+51",  name: "Perú",         flag: "🇵🇪" },
  { code: "+598", name: "Uruguay",      flag: "🇺🇾" },
  { code: "+593", name: "Ecuador",      flag: "🇪🇨" },
  { code: "+34",  name: "España",       flag: "🇪🇸" },
  { code: "+1",   name: "USA/Canadá",   flag: "🇺🇸" },
];
---

<div
  id="lead-modal"
  class="hidden fixed inset-0 z-[100] items-end sm:items-center justify-center"
  aria-hidden="true"
  aria-modal="true"
  role="dialog"
>
  <div id="lead-modal-overlay" class="absolute inset-0 bg-black/75 backdrop-blur-sm" data-close-lead-modal></div>

  <div class="lead-modal-card relative w-full sm:w-auto sm:max-w-[560px] bg-neutral-950 border border-neutral-800 shadow-[0_20px_60px_-10px_rgba(0,0,0,0.8)] flex flex-col max-h-[95vh] sm:max-h-[90vh] sm:rounded-none rounded-t-2xl overflow-hidden">
    <button
      type="button"
      data-close-lead-modal
      aria-label="Cerrar"
      class="absolute top-3 right-3 sm:top-4 sm:right-4 w-9 h-9 flex items-center justify-center text-neutral-500 hover:text-white hover:bg-neutral-800/50 rounded-full transition-all z-20"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <div class="sm:hidden flex justify-center pt-2.5 pb-1">
      <div class="w-10 h-1 bg-neutral-700 rounded-full"></div>
    </div>

    <div class="px-5 pt-4 pb-5 sm:px-7 sm:pt-7 sm:pb-6 border-b border-neutral-800/70 shrink-0">
      <div class="flex items-center gap-2.5 mb-3">
        <div class="w-6 h-px bg-yellow-400"></div>
        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.25em] text-yellow-400/80">Hablemos</span>
      </div>
      <h3 class="text-xl sm:text-2xl font-black text-white leading-tight pr-8">
        Cuéntanos de tu negocio.
      </h3>
      <p class="mt-2 text-xs sm:text-sm text-neutral-400 leading-relaxed">
        20 min. Evaluamos si podemos ayudarte. Sin compromiso.
      </p>
    </div>

    <div class="flex-1 overflow-y-auto overscroll-contain lead-modal-scroll">
      <form id="modal-lead-form" class="px-5 py-5 sm:px-7 sm:py-6 space-y-4" novalidate>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="modal-lead-name" class="block text-[11px] font-bold text-neutral-400 mb-1.5 uppercase tracking-wider">Nombre<span class="text-yellow-400 ml-1">*</span></label>
            <input
              type="text"
              id="modal-lead-name"
              name="name"
              required
              autocomplete="name"
              placeholder="Tu nombre"
              class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-3.5 py-2.5 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
            <p id="modal-err-name" class="hidden text-[11px] text-red-400 mt-1"></p>
          </div>
          <div>
            <label for="modal-lead-email" class="block text-[11px] font-bold text-neutral-400 mb-1.5 uppercase tracking-wider">Email<span class="text-yellow-400 ml-1">*</span></label>
            <input
              type="email"
              id="modal-lead-email"
              name="email"
              required
              autocomplete="email"
              placeholder="tu@correo.com"
              class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-3.5 py-2.5 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
            <p id="modal-err-email" class="hidden text-[11px] text-red-400 mt-1"></p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="min-w-0">
            <label for="modal-lead-phone" class="block text-[11px] font-bold text-neutral-400 mb-1.5 uppercase tracking-wider">Teléfono</label>
            <div class="flex gap-2">
              <select
                id="modal-lead-country"
                name="country"
                class="bg-neutral-900 border border-neutral-800 text-white px-2 py-2.5 text-sm focus:border-yellow-400 focus:outline-none transition-colors shrink-0 w-[88px]"
                aria-label="Código de país"
              >
                {COUNTRIES.map((c) => (
                  <option value={c.code} selected={c.code === "+56"}>{c.flag} {c.code}</option>
                ))}
              </select>
              <input
                type="tel"
                id="modal-lead-phone"
                name="phone"
                autocomplete="tel"
                inputmode="numeric"
                placeholder="9 1234 5678"
                class="lead-input flex-1 min-w-0 bg-neutral-900 border border-neutral-800 text-white px-3.5 py-2.5 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
              />
            </div>
            <p id="modal-err-phone" class="hidden text-[11px] text-red-400 mt-1"></p>
          </div>
          <div>
            <label for="modal-lead-business" class="block text-[11px] font-bold text-neutral-400 mb-1.5 uppercase tracking-wider">Rubro<span class="text-yellow-400 ml-1">*</span></label>
            <input
              type="text"
              id="modal-lead-business"
              name="business"
              required
              placeholder="Clínica, abogado, tienda..."
              class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-3.5 py-2.5 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
            <p id="modal-err-business" class="hidden text-[11px] text-red-400 mt-1"></p>
          </div>
        </div>

        <div>
          <label for="modal-lead-website" class="block text-[11px] font-bold text-neutral-400 mb-1.5 uppercase tracking-wider">
            Sitio web o Instagram
            <span class="text-neutral-600 font-normal normal-case ml-1">(opcional)</span>
          </label>
          <input
            type="text"
            id="modal-lead-website"
            name="website"
            placeholder="minegocio.cl · @minegocio"
            class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-3.5 py-2.5 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
          />
          <p id="modal-err-website" class="hidden text-[11px] text-red-400 mt-1"></p>
        </div>

        <div>
          <div class="flex items-baseline justify-between mb-1.5">
            <label for="modal-lead-help" class="block text-[11px] font-bold text-neutral-400 uppercase tracking-wider">
              ¿En qué te podemos apoyar?
              <span class="text-neutral-600 font-normal normal-case ml-1">(opcional)</span>
            </label>
            <span id="modal-help-counter" class="text-[10px] text-neutral-600">0/250</span>
          </div>
          <textarea
            id="modal-lead-help"
            name="help"
            rows="2"
            maxlength="250"
            placeholder="Cuéntanos brevemente qué necesitas."
            class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-3.5 py-2.5 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors resize-none"
          ></textarea>
        </div>

        <div class="flex items-start gap-2.5 pt-1">
          <input type="checkbox" id="modal-lead-consent" name="consent" required class="mt-0.5 w-4 h-4 accent-yellow-400 bg-neutral-900 border-neutral-700 shrink-0" />
          <label for="modal-lead-consent" class="text-[11px] text-neutral-500 leading-snug">Acepto que Lelemon me contacte para agendar una llamada. No spam.</label>
        </div>

        <div id="modal-turnstile-container"></div>

        <button
          type="submit"
          id="modal-lead-submit"
          class="w-full bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold py-3.5 px-6 text-sm uppercase tracking-wider transition-all disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
        >
          <span>Quiero mi evaluación</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </button>
        <p id="modal-form-feedback" class="text-xs text-center hidden"></p>

        <div class="pt-3 text-center border-t border-neutral-800/60">
          <p class="text-[11px] text-neutral-600 mb-1.5">¿Prefieres WhatsApp?</p>
          <a
            href={whatsappUrl}
            target="_blank"
            data-wa-cta
            class="inline-flex items-center gap-2 text-xs font-semibold text-neutral-400 hover:text-yellow-400 transition-colors"
          >
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Escríbenos directo
          </a>
        </div>
      </form>

      <div id="modal-form-success" class="hidden text-center px-5 py-12 sm:px-7 sm:py-16">
        <div class="w-14 h-14 bg-yellow-400/10 rounded-full flex items-center justify-center mx-auto mb-5">
          <svg class="w-7 h-7 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3 class="text-lg sm:text-xl font-bold text-white mb-2">¡Recibimos tus datos!</h3>
        <p class="text-neutral-400 max-w-xs mx-auto text-sm leading-relaxed">Te contactamos en menos de 24 horas para agendar tu evaluación.</p>
        <button type="button" data-close-lead-modal class="mt-6 inline-flex items-center gap-2 text-yellow-400 hover:text-yellow-300 text-xs font-bold uppercase tracking-wider">
          Cerrar
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  #lead-modal {
    animation: modalFadeIn 0.2s ease-out;
  }
  .lead-modal-card {
    animation: modalSlideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes modalFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes modalSlideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .lead-modal-scroll::-webkit-scrollbar { width: 5px; }
  .lead-modal-scroll::-webkit-scrollbar-track { background: transparent; }
  .lead-modal-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 999px; }
  .lead-modal-scroll::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }
  body.modal-open { overflow: hidden; }

  /* Estado de error: borde rojo */
  .lead-input.has-error {
    border-color: #f87171 !important;
  }
</style>

<script is:inline define:vars={{ TURNSTILE_SITE_KEY, FORM_API_URL: API_URL, FORM_ID: LEAD_FORM_ID, FORM_API_KEY: LEAD_FORM_API_KEY }}>
  (function() {
    var modal = document.getElementById('lead-modal');
    var form = document.getElementById('modal-lead-form');
    var submitBtn = document.getElementById('modal-lead-submit');
    var feedback = document.getElementById('modal-form-feedback');
    var successEl = document.getElementById('modal-form-success');
    var helpCounter = document.getElementById('modal-help-counter');
    var turnstileToken = '';
    var turnstileWidgetId = null;
    var turnstileInitialized = false;

    // ============ Validators ============
    function isValidEmail(v) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
    }
    function isValidPhone(v) {
      // 7-14 dígitos (sin contar código país)
      var digits = v.replace(/\D/g, '');
      return digits.length >= 7 && digits.length <= 14;
    }
    function isValidWebsite(v) {
      if (!v) return true;
      // URL (con o sin protocolo) o handle @usuario
      return /^(https?:\/\/)?[\w.-]+\.[a-z]{2,}(\/.*)?$/i.test(v) || /^@[\w.]+$/.test(v);
    }

    // ============ Error helpers ============
    function fid(id) { return document.getElementById('modal-lead-' + id); }
    function errEl(id) { return document.getElementById('modal-err-' + id); }

    function showError(id, msg) {
      var input = fid(id);
      var err = errEl(id);
      if (input) input.classList.add('has-error');
      if (err) {
        err.textContent = msg;
        err.classList.remove('hidden');
      }
    }
    function clearError(id) {
      var input = fid(id);
      var err = errEl(id);
      if (input) input.classList.remove('has-error');
      if (err) err.classList.add('hidden');
    }

    // Validar un solo campo
    function validateField(id) {
      var val = (fid(id).value || '').trim();
      if (id === 'name') {
        if (val.length < 2) { showError(id, 'Ingresa al menos 2 caracteres.'); return false; }
      } else if (id === 'email') {
        if (!val) { showError(id, 'Email requerido.'); return false; }
        if (!isValidEmail(val)) { showError(id, 'Email no válido (ej: tu@correo.com).'); return false; }
      } else if (id === 'phone') {
        if (val && !isValidPhone(val)) { showError(id, 'Ingresa un teléfono válido (7-14 dígitos).'); return false; }
      } else if (id === 'business') {
        if (val.length < 2) { showError(id, 'Cuéntanos a qué se dedica tu negocio.'); return false; }
      } else if (id === 'website') {
        if (val && !isValidWebsite(val)) { showError(id, 'Ingresa un sitio (minegocio.cl) o handle (@minegocio).'); return false; }
      }
      clearError(id);
      return true;
    }

    // Validar todo
    function validateAll() {
      var ok = true;
      ['name','email','phone','business','website'].forEach(function(id) {
        if (!validateField(id)) ok = false;
      });
      return ok;
    }

    // On-blur
    ['name','email','phone','business','website'].forEach(function(id) {
      var el = fid(id);
      if (!el) return;
      el.addEventListener('blur', function() { validateField(id); });
      // Clear error al escribir
      el.addEventListener('input', function() {
        if (el.classList.contains('has-error')) clearError(id);
      });
    });

    // Phone: solo dígitos y espacios
    var phoneEl = fid('phone');
    if (phoneEl) {
      phoneEl.addEventListener('input', function(e) {
        var cleaned = e.target.value.replace(/[^\d\s]/g, '');
        if (cleaned !== e.target.value) e.target.value = cleaned;
      });
    }

    // Help counter
    var helpEl = fid('help');
    if (helpEl && helpCounter) {
      helpEl.addEventListener('input', function() {
        helpCounter.textContent = helpEl.value.length + '/250';
      });
    }

    // ============ Modal open/close ============
    function openModal() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('modal-open');

      if (typeof fbq === 'function') fbq('track', 'ViewContent', { content_name: 'Lead Modal' });
      if (typeof gtag === 'function') gtag('event', 'modal_open', { event_category: 'Form', event_label: 'Lead Modal' });

      setTimeout(function() {
        var nameInput = fid('name');
        if (nameInput) nameInput.focus();
      }, 100);
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('modal-open');
    }

    function initTurnstile() {
      if (!TURNSTILE_SITE_KEY || typeof turnstile === 'undefined') return;
      if (turnstileInitialized) return;
      try {
        turnstileWidgetId = turnstile.render('#modal-turnstile-container', {
          sitekey: TURNSTILE_SITE_KEY,
          callback: function(token) {
            turnstileToken = token;
            console.log('[Turnstile] ✓ token recibido');
          },
          'expired-callback': function() {
            turnstileToken = '';
            console.warn('[Turnstile] token expirado');
          },
          'error-callback': function(err) {
            turnstileToken = '';
            console.error('[Turnstile] error:', err);
          },
          size: 'invisible',
        });
        turnstileInitialized = true;
        console.log('[Turnstile] widget inicializado, ID:', turnstileWidgetId);
      } catch (e) {
        console.error('[Turnstile] init falló:', e);
      }
    }

    // Inicializar al cargar página (no al abrir modal) — más robusto
    if (TURNSTILE_SITE_KEY) {
      if (typeof turnstile !== 'undefined') {
        initTurnstile();
      } else {
        var tsCheck = setInterval(function() {
          if (typeof turnstile !== 'undefined') {
            clearInterval(tsCheck);
            initTurnstile();
          }
        }, 500);
        setTimeout(function() { clearInterval(tsCheck); }, 15000);
      }
    }

    document.querySelectorAll('[data-open-lead-modal]').forEach(function(el) {
      el.addEventListener('click', function(e) { e.preventDefault(); openModal(); });
    });
    document.querySelectorAll('[data-close-lead-modal]').forEach(function(el) {
      el.addEventListener('click', function(e) { e.stopPropagation(); closeModal(); });
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });

    // ============ Feedback general ============
    function showFeedback(msg, isError) {
      feedback.textContent = msg;
      feedback.className = 'text-xs text-center mt-2 ' + (isError ? 'text-red-400' : 'text-green-400');
    }
    function setLoading(loading) {
      submitBtn.disabled = loading;
      submitBtn.innerHTML = loading
        ? '<span>Enviando...</span>'
        : '<span>Quiero mi evaluación</span><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>';
    }

    // ============ Submit ============
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      feedback.className = 'text-xs text-center hidden';

      // Validación completa
      if (!validateAll()) {
        showFeedback('Revisa los campos marcados.', true);
        return;
      }
      if (!document.getElementById('modal-lead-consent').checked) {
        showFeedback('Debes aceptar ser contactado.', true);
        return;
      }
      if (!FORM_API_URL || !FORM_ID || !FORM_API_KEY) {
        showFeedback('Formulario no configurado.', true);
        return;
      }

      var name = fid('name').value.trim();
      var email = fid('email').value.trim();
      var countryCode = document.getElementById('modal-lead-country').value;
      var phoneRaw = fid('phone').value.trim();
      var phone = phoneRaw ? countryCode + ' ' + phoneRaw : '';
      var business = fid('business').value.trim();
      var website = fid('website').value.trim();
      var help = fid('help').value.trim();

      if (TURNSTILE_SITE_KEY && typeof turnstile !== 'undefined') {
        // Reset + execute para obtener un token FRESCO (evita expired tokens)
        if (turnstileWidgetId !== null) {
          try { turnstile.reset(turnstileWidgetId); } catch (e) {}
        }
        turnstileToken = '';
        setLoading(true);
        try {
          turnstile.execute('#modal-turnstile-container');
          console.log('[Turnstile] execute() llamado');
        } catch (e) {
          console.error('[Turnstile] execute falló:', e);
          showFeedback('Error de verificación. Recarga e intenta de nuevo.', true);
          setLoading(false);
          return;
        }
        var attempts = 0;
        var wait = setInterval(function() {
          attempts++;
          if (turnstileToken || attempts > 40) {
            clearInterval(wait);
            if (turnstileToken) {
              console.log('[Turnstile] enviando con token (' + turnstileToken.length + ' chars)');
              submitLead(name, email, phone, business, website, help);
            } else {
              console.error('[Turnstile] timeout sin token tras ' + attempts + ' intentos');
              showFeedback('La verificación de seguridad tardó mucho. Intenta de nuevo.', true);
              setLoading(false);
            }
          }
        }, 250);
        return;
      }

      submitLead(name, email, phone, business, website, help);
    });

    function submitLead(name, email, phone, business, website, help) {
      setLoading(true);

      // Backend acepta name (255), email, phone (50), turnstileToken
      // Contexto extra va al name
      var nameWithContext = name;
      if (business) nameWithContext += ' | ' + business;
      if (website) nameWithContext += ' | ' + website;
      if (help) nameWithContext += ' | ' + help.substring(0, 150);
      if (nameWithContext.length > 250) nameWithContext = nameWithContext.substring(0, 247) + '...';

      fetch(FORM_API_URL + '/public/forms/' + FORM_ID + '/leads', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': FORM_API_KEY,
        },
        body: JSON.stringify({
          name: nameWithContext,
          email: email,
          phone: phone || undefined,
          turnstileToken: turnstileToken || 'no-turnstile',
        }),
      })
      .then(function(res) {
        if (!res.ok) {
          return res.json().then(function(data) { throw new Error(data.message || 'Error al enviar'); });
        }
        return res.json();
      })
      .then(function() {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');

        if (typeof fbq === 'function') fbq('track', 'Lead', { content_name: 'Lead Modal' });
        if (typeof gtag === 'function') gtag('event', 'generate_lead', { event_category: 'Form', event_label: 'Lead Modal' });
      })
      .catch(function(err) {
        showFeedback(err.message || 'Error al enviar. Intenta de nuevo.', true);
        if (typeof turnstile !== 'undefined' && turnstileWidgetId !== null) {
          turnstile.reset(turnstileWidgetId);
          turnstileToken = '';
        }
      })
      .finally(function() { setLoading(false); });
    }
  })();
</script>
