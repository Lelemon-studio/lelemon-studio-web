---
interface Props {
  whatsappUrl: string;
}
const { whatsappUrl } = Astro.props;
---

<div class="top-banner fixed top-0 left-0 right-0 bg-red-600 text-white text-center py-2 px-4 z-[60] transition-transform duration-300" id="top-banner">
  <a href={whatsappUrl} target="_blank" data-wa-cta class="inline-flex items-center gap-2 text-xs sm:text-sm font-semibold tracking-wide hover:opacity-90 transition-opacity">
    <span class="inline-block w-2 h-2 bg-white rounded-full animate-pulse"></span>
    Postulaciones abiertas — Pocos cupos disponibles
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
  </a>
</div>

<style>
  .banner-hidden {
    transform: translateY(-100%);
  }
</style>
