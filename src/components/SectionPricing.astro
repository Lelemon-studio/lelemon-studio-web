---
interface Props {
  whatsappUrl: string;
  included: string[];
}
const { whatsappUrl, included } = Astro.props;
---

<section id="pricing" class="relative bg-neutral-950 text-white py-20 lg:py-32 px-6 sm:px-10 overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-[0.03]"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-yellow-400/20 to-transparent"></div>

  <div class="absolute top-1/2 -translate-y-1/2 -right-[10%] text-[20vw] font-black text-neutral-900 leading-none select-none pointer-events-none tracking-tighter" aria-hidden="true">
    Desde $295k
  </div>

  <div class="max-w-7xl mx-auto relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <div>
        <div class="flex items-center gap-3 mb-6 scroll-reveal">
          <div class="w-8 h-px bg-yellow-400"></div>
          <span class="text-xs font-bold uppercase tracking-[0.3em] text-yellow-400/80">Precio claro</span>
        </div>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[0.95] tracking-tight scroll-reveal" style="--d:50ms">
          Un plan.<br/>Sin letra chica.
        </h2>
        <p class="mt-6 text-neutral-400 text-lg leading-relaxed max-w-md scroll-reveal" style="--d:75ms">
          Esto es exactamente lo que vas a pagar, cuándo, y qué incluye.
        </p>

        <!-- Pricing table -->
        <div class="mt-10 border border-neutral-800 bg-neutral-900/30 scroll-reveal" style="--d:100ms">
          <!-- Row: implementación + primer mes (destacado) -->
          <div class="px-6 py-6 bg-yellow-400/[0.04] border-b border-neutral-800">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-yellow-400 text-[11px] font-bold uppercase tracking-[0.2em]">Implementación + primer mes</p>
                <p class="text-neutral-500 text-xs mt-1.5">Una vez · Incluye setup y primer mes operando</p>
              </div>
              <div class="text-right">
                <span class="text-4xl sm:text-5xl font-black text-gradient-lemon leading-none">$400.000</span>
                <span class="block text-neutral-500 text-xs mt-1">CLP + IVA</span>
              </div>
            </div>
          </div>

          <!-- Row: mes 2 y 3 -->
          <div class="px-6 py-5 border-b border-neutral-800">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-white text-[11px] font-bold uppercase tracking-[0.2em]">Mes 2 y 3</p>
                <p class="text-neutral-500 text-xs mt-1.5">Precio promocional</p>
              </div>
              <div class="text-right">
                <span class="text-2xl sm:text-3xl font-black text-white leading-none">$295.000</span>
                <span class="block text-neutral-500 text-xs mt-1">CLP + IVA / mes</span>
              </div>
            </div>
          </div>

          <!-- Row: desde mes 4 -->
          <div class="px-6 py-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-white text-[11px] font-bold uppercase tracking-[0.2em]">Desde el mes 4</p>
                <p class="text-neutral-500 text-xs mt-1.5">Precio regular</p>
              </div>
              <div class="text-right">
                <span class="text-2xl sm:text-3xl font-black text-white leading-none">$350.000</span>
                <span class="block text-neutral-500 text-xs mt-1">CLP + IVA / mes</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Summary: al firmar + total 3 meses -->
        <div class="mt-6 grid grid-cols-2 gap-3 scroll-reveal" style="--d:150ms">
          <div class="border border-yellow-400/30 bg-yellow-400/[0.05] p-5">
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-yellow-400/80 mb-2">Al firmar pagas</p>
            <p class="text-2xl sm:text-3xl font-black text-white">$400.000 <span class="text-xs text-neutral-500 font-medium">CLP + IVA</span></p>
            <p class="text-[11px] text-neutral-500 mt-1.5">Implementación + mes 1</p>
          </div>
          <div class="border border-neutral-800 bg-neutral-900/30 p-5">
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-400 mb-2">Total 3 primeros meses</p>
            <p class="text-2xl sm:text-3xl font-black text-green-400">$990.000 <span class="text-xs text-neutral-500 font-medium">CLP + IVA</span></p>
            <p class="text-[11px] text-neutral-500 mt-1.5">Luego $350.000 CLP/mes</p>
          </div>
        </div>

        <p class="mt-6 text-sm text-neutral-400 leading-relaxed scroll-reveal" style="--d:175ms">
          <span class="text-white font-bold">Sin contrato ni permanencia mínima.</span> Cancelas el mes que quieras.
        </p>

        <div class="mt-10 scroll-reveal" style="--d:200ms">
          <button type="button" data-open-lead-modal id="pricing-cta" class="group inline-flex items-center gap-3 bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold px-8 py-4 transition-all text-sm uppercase tracking-wider">
            Hablemos 20 minutos
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </button>
          <p class="text-xs text-neutral-600 mt-3">Sin compromiso. Evaluamos si somos buen fit.</p>
        </div>
      </div>
      <div>
        <div class="scroll-reveal" style="--d:100ms">
          <p class="text-xs font-bold uppercase tracking-[0.3em] text-neutral-500 mb-8">Todo incluido</p>
          <ul class="space-y-0">
            {included.map((item, i) => (
              <li class="flex items-start gap-4 py-4 border-b border-neutral-800/50">
                <span class="text-xs font-bold text-yellow-400/40 mt-0.5 shrink-0">{String(i+1).padStart(2,'0')}</span>
                <span class="text-neutral-300 text-[15px] leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Testimonio — glass flotante -->
        <div class="mt-12 scroll-reveal" style="--d:200ms">
          <div class="testimonial-glass p-7 relative">
            <div class="flex items-center gap-0.5 text-yellow-400 text-sm mb-4">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="text-white/90 text-[15px] leading-relaxed italic mb-6">
              "Lelemon ha sido una pieza fundamental en el desarrollo de mis negocios, tanto para mi estudio jurídico como para mi agencia. Los resultados en captación de clientes fueron positivos desde el primer mes, logrando concretar mis primeros tres clientes rápidamente. ¡Una plataforma totalmente recomendada por su efectividad!"
            </p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-yellow-400/20 flex items-center justify-center text-lg font-bold text-yellow-400">N</div>
              <div>
                <p class="text-white text-sm font-bold">Nicolás Valdés</p>
                <p class="text-neutral-400 text-xs">
                  Abogado ·
                  <a href="https://teayudamoslaboral.cl" target="_blank" rel="noopener noreferrer" class="hover:text-yellow-400 underline underline-offset-2 decoration-neutral-600 hover:decoration-yellow-400 transition-colors">teayudamoslaboral.cl</a>
                  ·
                  <a href="https://teayudamosfamilia.cl" target="_blank" rel="noopener noreferrer" class="hover:text-yellow-400 underline underline-offset-2 decoration-neutral-600 hover:decoration-yellow-400 transition-colors">teayudamosfamilia.cl</a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═════════════════════════════════════════════
         Servicios sueltos — para pymes que solo necesitan una parte
         ═════════════════════════════════════════════ -->
    <div class="mt-24 lg:mt-32 pt-16 border-t border-neutral-800/50 scroll-reveal">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <div class="flex items-center justify-center gap-3 mb-6">
          <div class="w-8 h-px bg-neutral-700"></div>
          <span class="text-xs font-bold uppercase tracking-[0.3em] text-neutral-500">Servicios sueltos</span>
          <div class="w-8 h-px bg-neutral-700"></div>
        </div>
        <h3 class="text-3xl sm:text-4xl lg:text-5xl font-black leading-[0.95] tracking-tight">
          ¿Solo necesitas una parte?
        </h3>
        <p class="mt-5 text-neutral-400 leading-relaxed">
          También vendemos los servicios por separado. Contrata solo el que te sirva.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 scroll-reveal" style="--d:100ms">
        <!-- Web -->
        <div class="border border-neutral-800 bg-neutral-900/30 p-6 hover:border-yellow-400/30 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-yellow-400/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h4 class="text-lg font-bold text-white">Web profesional</h4>
          </div>
          <p class="text-sm text-neutral-400 leading-relaxed mb-5">Dominio, hosting, SSL, diseño mobile-first y conexión al CRM. Lista para convertir.</p>
          <div class="flex items-baseline gap-2">
            <span class="text-3xl font-black text-white">$100.000</span>
            <span class="text-xs text-neutral-500">CLP + IVA / mes</span>
          </div>
          <p class="text-[11px] text-neutral-600 mt-1.5">+ $150.000 CLP + IVA de implementación</p>
        </div>

        <!-- Agente IA + CRM -->
        <div class="border border-neutral-800 bg-neutral-900/30 p-6 hover:border-yellow-400/30 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-yellow-400/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
            </div>
            <h4 class="text-lg font-bold text-white">Agente IA + CRM</h4>
          </div>
          <p class="text-sm text-neutral-400 leading-relaxed mb-5">Asistente con IA en tu WhatsApp 24/7 y panel donde ves cada conversación y cliente.</p>
          <div class="flex items-baseline gap-2">
            <span class="text-3xl font-black text-white">$250.000</span>
            <span class="text-xs text-neutral-500">CLP + IVA / mes</span>
          </div>
          <p class="text-[11px] text-neutral-600 mt-1.5">+ $200.000 CLP + IVA de implementación</p>
          <p class="text-[11px] text-neutral-500 mt-2 leading-relaxed">Incluye <span class="text-yellow-400 font-bold">2.000 sesiones/mes</span> · Sobre eso, $200 CLP por sesión extra</p>
        </div>

        <!-- Marketing (Ads operados) -->
        <div class="border border-neutral-800 bg-neutral-900/30 p-6 hover:border-yellow-400/30 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-yellow-400/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <h4 class="text-lg font-bold text-white">Marketing operado</h4>
          </div>
          <p class="text-sm text-neutral-400 leading-relaxed mb-5">Estrategia, lanzamiento y optimización mensual de anuncios en Instagram y Facebook.</p>
          <div class="flex items-baseline gap-2">
            <span class="text-3xl font-black text-white">$200.000</span>
            <span class="text-xs text-neutral-500">CLP + IVA / mes</span>
          </div>
          <p class="text-[11px] text-neutral-600 mt-1.5">+ $100.000 CLP + IVA de implementación</p>
        </div>
      </div>

      <!-- Nota sobre bundle -->
      <div class="mt-10 text-center scroll-reveal" style="--d:200ms">
        <p class="text-sm text-neutral-400">
          Contratar los 3 por separado: <span class="text-neutral-300">desde $550.000/mes</span>
          <span class="mx-2 text-neutral-700">·</span>
          <span class="text-yellow-400 font-bold">Con el Plan ahorras hasta 36%</span>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-glass {
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow:
      0 20px 50px -12px rgba(0,0,0,0.4),
      inset 0 1px 0 rgba(255,255,255,0.06);
    transform: translateY(-4px);
    transition: all 0.3s ease;
  }
  .testimonial-glass:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.12);
    transform: translateY(-6px);
    box-shadow:
      0 25px 60px -12px rgba(0,0,0,0.5),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .text-gradient-lemon {
    background: linear-gradient(135deg, #FACC15, #84CC16, #FACC15);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientShift 5s ease infinite;
  }
  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
</style>
