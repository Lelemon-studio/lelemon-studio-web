---
interface Props {
  whatsappUrl: string;
  included: string[];
}
const { whatsappUrl, included } = Astro.props;
---

<section class="relative bg-neutral-950 text-white py-20 lg:py-32 px-6 sm:px-10 overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-[0.03]"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-yellow-400/20 to-transparent"></div>

  <div class="absolute top-1/2 -translate-y-1/2 -right-[10%] text-[20vw] font-black text-neutral-900 leading-none select-none pointer-events-none tracking-tighter" aria-hidden="true">
    Desde $249
  </div>

  <div class="max-w-7xl mx-auto relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <div>
        <div class="flex items-center gap-3 mb-6 scroll-reveal">
          <div class="w-8 h-px bg-yellow-400"></div>
          <span class="text-xs font-bold uppercase tracking-[0.3em] text-yellow-400/80">Inversión</span>
        </div>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[0.95] tracking-tight scroll-reveal" style="--d:50ms">
          ¿Cuánto<br/>cuesta?
        </h2>
        <div class="mt-10 scroll-reveal" style="--d:100ms">
          <div class="flex items-baseline gap-3">
            <span class="text-lg text-neutral-500 font-medium mr-1">Desde</span><span class="text-5xl sm:text-7xl lg:text-8xl font-black text-gradient-lemon">$249</span>
            <span class="text-neutral-600 text-lg font-medium">USD/mes</span>
          </div>
          <p class="text-neutral-600 mt-3 text-sm">+ $149 USD de setup <span class="text-neutral-500">(una vez)</span></p>
        </div>
        <div class="mt-8 flex items-center gap-4 scroll-reveal" style="--d:150ms">
          <div class="w-px h-12 bg-yellow-400/30"></div>
          <div>
            <p class="text-yellow-400 font-bold">Primer mes gratis.</p>
            <p class="text-neutral-600 text-sm">Sin contrato. Cancelas cuando quieras.</p>
          </div>
        </div>
        <div class="mt-10 p-6 border border-neutral-800 scroll-reveal" style="--d:200ms">
          <p class="text-sm text-neutral-500 leading-relaxed">El presupuesto de publicidad se paga directo a Meta o Google, no a nosotros. Recomendamos desde $150 USD/mes pero tú decides cuánto.</p>
        </div>
        <div class="mt-10 scroll-reveal" style="--d:250ms">
          <a href={whatsappUrl} target="_blank" data-wa-cta class="group inline-flex items-center gap-3 bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold px-8 py-4 transition-all text-sm uppercase tracking-wider">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Agendar llamada
          </a>
        </div>
      </div>
      <div class="scroll-reveal" style="--d:100ms">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-neutral-500 mb-8">Todo incluido</p>
        <ul class="space-y-0">
          {included.map((item, i) => (
            <li class="flex items-start gap-4 py-4 border-b border-neutral-800/50">
              <span class="text-xs font-bold text-yellow-400/40 mt-0.5 shrink-0">{String(i+1).padStart(2,'0')}</span>
              <span class="text-neutral-300 text-[15px] leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .text-gradient-lemon {
    background: linear-gradient(135deg, #FACC15, #84CC16, #FACC15);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientShift 5s ease infinite;
  }
  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
</style>
