---
/**
 * MarqueeStrip — banda yellow con texto en marquee, modo "ticker tape".
 * Sirve de transición visual entre dos secciones dark (Hero → Services).
 *
 * Patrón inspirado en Stripe stat strip / Linear customer ribbon.
 * Breve, on-brand, scrolleando.
 */

const items = [
  { icon: '🍋', text: 'ATIENDE 24/7' },
  { icon: '⚡', text: 'RESPUESTA <1 MIN' },
  { icon: '💬', text: 'IA EN TU WHATSAPP' },
  { icon: '🇨🇱', text: 'OPERADO DESDE CHILE' },
  { icon: '✅', text: 'SIN CONTRATO' },
  { icon: '⏱️', text: 'ARRIBA EN 2 A 3 SEMANAS' },
];

// Triplicar para loop sin saltos
const triplicated = [...items, ...items, ...items];
---

<section aria-hidden="true" class="relative bg-yellow-400 overflow-hidden border-t-2 border-b-2 border-neutral-950">
  <!-- Diagonal lines decoration -->
  <div class="absolute inset-0 diagonal-lines-dark opacity-[0.06] pointer-events-none"></div>

  <!-- Mask fade en bordes para suavizar entrada/salida -->
  <div class="relative py-4 mask-fade-x">
    <div class="marquee-strip flex items-center gap-10 w-max">
      {triplicated.map((item) => (
        <div class="flex items-center gap-3 whitespace-nowrap">
          <span class="text-xl select-none">{item.icon}</span>
          <span class="text-xs sm:text-sm font-black tracking-[0.18em] uppercase text-neutral-950">
            {item.text}
          </span>
          <svg class="w-3 h-3 text-neutral-950/40 ml-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="6"/>
          </svg>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-strip {
    animation: marquee-strip 35s linear infinite;
    will-change: transform;
  }
  @keyframes marquee-strip {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
  .mask-fade-x {
    -webkit-mask-image: linear-gradient(90deg, transparent, black 4%, black 96%, transparent);
    mask-image: linear-gradient(90deg, transparent, black 4%, black 96%, transparent);
  }

  /* Pausar al hover por accesibilidad */
  .marquee-strip:hover {
    animation-play-state: paused;
  }

  /* Respect reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .marquee-strip {
      animation: none;
    }
  }
</style>
