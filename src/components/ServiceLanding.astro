---
/**
 * ServiceLanding — template reusable para las niche landings de servicios
 * (web, agente-ia, marketing).
 *
 * Layout idéntico, contenido parametrizado vía props. Mantiene Navbar,
 * LeadModal y DemoChatModal globales (renderizados en Layout.astro).
 *
 * Uso: ver src/pages/web.astro, /agente-ia.astro, /marketing.astro
 */
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

interface Feature {
  title: string;
  description: string;
  icon?: string;          // key del dict ICONS
  meta?: string;          // texto chico tipo "24/7" o "<2s"
  tags?: string[];        // etiquetas con # al renderizar
  colSpan?: 1 | 2;        // bento — span 2 cols para destacar
  featured?: boolean;     // hover persistente (item destacado)
}

interface FAQ {
  question: string;
  answer: string;
}

// ── Iconos heroicons-style (paths inline, sin dependencias externas) ──
const ICONS: Record<string, string> = {
  sparkles: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.456-2.456L14.25 6l1.035-.259a3.375 3.375 0 002.456-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/>',
