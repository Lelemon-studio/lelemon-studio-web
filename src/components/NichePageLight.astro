---
interface ChatMessage {
  sender: 'client' | 'ai';
  text: string;
  time: string;
}

interface Props {
  niche: string;
  nicheSlug: string;
  emoji: string;
  headline: string;
  subtitle: string;
  highlights: string[];
  chatBusiness: string;
  chatEmoji: string;
  chatMessages: ChatMessage[];
  whatsappUrl: string;
}

const {
  niche,
  nicheSlug,
  emoji,
  headline,
  subtitle,
  highlights,
  chatBusiness,
  chatEmoji,
  chatMessages,
  whatsappUrl,
} = Astro.props;

import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
---

<Navbar whatsappUrl={whatsappUrl} variant="glass" />

<main>
  <section id="hero" class="relative bg-white pt-28 pb-20 lg:pt-36 lg:pb-28 px-6 sm:px-10">
    <div class="max-w-6xl mx-auto">

      <!-- Breadcrumb -->
      <a href="/#casos-de-uso" class="inline-flex items-center gap-2 text-xs font-medium text-neutral-400 hover:text-neutral-900 transition-colors mb-10">
        &larr; Todos los rubros
      </a>

      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Izquierda: todo el contenido -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <span class="text-3xl">{emoji}</span>
            <span class="text-xs font-bold uppercase tracking-[0.3em] text-yellow-600">Lelemon para {niche}</span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-black leading-[1.05] tracking-tight text-neutral-950 mb-5">
            {headline}
          </h1>

          <p class="text-base text-neutral-500 leading-relaxed mb-10 max-w-lg">
            {subtitle}
          </p>

          <ul class="space-y-5 mb-10">
            {highlights.map((h) => (
              <li class="flex items-start gap-4">
                <span class="w-7 h-7 bg-yellow-400 text-neutral-950 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="text-neutral-800 font-medium leading-snug">{h}</span>
              </li>
            ))}
          </ul>

          <a href={whatsappUrl} target="_blank" data-wa-cta class="inline-flex items-center gap-3 bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold px-8 py-4 transition-all text-sm uppercase tracking-wider">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Conversemos
          </a>
          <p class="text-xs text-neutral-400 mt-3">30 min. Sin compromiso.</p>
        </div>

        <!-- Derecha: iPhone mock -->
        <div id="chat-demo">
          <div class="iphone-mock mx-auto">
            <div class="iphone-mock__frame">
              <div class="iphone-notch"></div>
              <div class="flex items-center justify-between px-5 pt-1 pb-1 bg-[#075E54]">
                <span class="text-[10px] text-white/70 font-medium">23:14</span>
                <div class="flex items-center gap-1">
                  <svg class="w-3 h-3 text-white/60" fill="currentColor" viewBox="0 0 24 24"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3a4.24 4.24 0 00-6 0zm-4-4l2 2a7.07 7.07 0 0110 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
                  <div class="w-4 h-2.5 border border-white/50 rounded-sm relative"><div class="absolute inset-[1px] right-[2px] bg-green-400/80 rounded-[1px]"></div></div>
                </div>
              </div>
              <div class="bg-[#075E54] text-white px-4 py-2 flex items-center gap-3">
                <svg class="w-4 h-4 text-white/80" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center text-sm">{chatEmoji}</div>
                <div class="flex-1">
                  <p class="font-semibold text-xs">{chatBusiness}</p>
                  <p class="text-[9px] text-green-300">en línea</p>
                </div>
              </div>
              <div class="bg-[#ECE5DD] p-3 space-y-2" style="min-height: 280px;">
                <p class="text-[9px] text-neutral-500 text-center bg-white/60 rounded-full px-3 py-0.5 mx-auto w-fit">Hoy</p>
                {chatMessages.map((msg) => (
                  <div class={`chat-msg flex ${msg.sender === 'client' ? 'justify-end' : 'justify-start'}`}>
                    <div class={`${msg.sender === 'client' ? 'bg-[#DCF8C6] rounded-lg rounded-tr-sm' : 'bg-white rounded-lg rounded-tl-sm'} px-3 py-1.5 max-w-[85%] shadow-sm`}>
                      <p class="text-[11px] text-neutral-800">{msg.text}</p>
                      <p class="text-[9px] text-neutral-400 text-right mt-0.5">
                        {msg.time}
                        {msg.sender === 'client' && <span class="text-blue-400"> ✓✓</span>}
                        {msg.sender === 'ai' && <span class="text-yellow-500 font-bold"> IA</span>}
                      </p>
                    </div>
                  </div>
                ))}
                <div class="chat-msg flex justify-start"><div class="bg-white rounded-lg rounded-tl-sm px-4 py-2.5 shadow-sm"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>
              </div>
              <div class="bg-[#F0F0F0] px-3 py-2 flex items-center gap-2">
                <div class="flex-1 bg-white rounded-full px-3 py-1.5"><p class="text-[10px] text-neutral-400">Escribe un mensaje</p></div>
                <div class="w-7 h-7 bg-[#075E54] rounded-full flex items-center justify-center"><svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2v7z"/></svg></div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</main>

<Footer />

<style>
  .chat-msg {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
  .chat-msg.chat-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .iphone-mock {
    max-width: 320px;
  }
  .iphone-mock__frame {
    background: #000;
    border: 3px solid #1a1a1a;
    overflow: hidden;
    position: relative;
    box-shadow: 0 25px 60px -10px rgba(0,0,0,0.15);
  }
  .iphone-notch {
    width: 120px;
    height: 24px;
    background: #000;
    margin: 0 auto;
    border-radius: 0 0 16px 16px;
    position: relative;
    z-index: 2;
  }
  .typing-dots {
    display: flex;
    gap: 4px;
    padding: 2px 0;
  }
  .typing-dots span {
    width: 6px;
    height: 6px;
    background: #999;
    border-radius: 50%;
    animation: typingBounce 1.4s infinite;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
  }
</style>

<script>
  const chatDemo = document.getElementById('chat-demo');
  const chatMsgs = chatDemo?.querySelectorAll('.chat-msg') || [];
  const chatObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      chatMsgs.forEach((msg, i) => { setTimeout(() => msg.classList.add('chat-visible'), i * 500); });
      chatObs.unobserve(e.target);
    });
  }, { threshold: 0.3 });
  if (chatDemo) chatObs.observe(chatDemo);

  document.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('[data-wa-cta]');
    if (!link) return;
    const section = link.closest('section')?.id || 'unknown';
    if (typeof window.fbq === 'function') window.fbq('track', 'Lead', { content_name: 'whatsapp_click', content_category: section });
    if (typeof window.gtag === 'function') window.gtag('event', 'generate_lead', { event_category: 'whatsapp', event_label: section });
  });
</script>
