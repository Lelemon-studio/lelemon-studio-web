---
interface Props {
  whatsappUrl: string;
}
const { whatsappUrl } = Astro.props;

const verticales = [
  {
    icon: '📅',
    titulo: 'Agenda',
    headline: 'Tu agenda se llena sola. Tú apareces a atender.',
    href: '/para-agendamiento/',
    cta: 'Cómo agenda',
  },
  {
    icon: '💰',
    titulo: 'Ventas',
    headline: 'Responde, cotiza y envía el link de pago por ti.',
    href: '/para-ventas/',
    cta: 'Cómo vende',
  },
  {
    icon: '🛟',
    titulo: 'Soporte',
    headline: 'Resuelve las dudas que se repiten 100 veces al día.',
    href: '/para-soporte/',
    cta: 'Cómo atiende',
  },
  {
    icon: '✅',
    titulo: 'Calificación',
    headline: 'Separa al que ya quiere comprar del que anda mirando.',
    href: '/para-calificacion/',
    cta: 'Cómo filtra',
  },
];
---

<section id="casos-de-uso" class="relative bg-white py-20 lg:py-28 px-6 sm:px-10 overflow-hidden">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-6 scroll-reveal">
      <div class="w-8 h-px bg-neutral-950"></div>
      <span class="text-xs font-bold uppercase tracking-[0.3em] text-neutral-400">Casos de uso</span>
    </div>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-neutral-950 tracking-tight mb-4 scroll-reveal" style="--d:50ms">
      El mismo asistente, metido en cada parte de tu negocio.
    </h2>
    <p class="text-lg text-neutral-500 mb-14 max-w-xl scroll-reveal" style="--d:100ms">
      Agenda citas, cotiza productos, responde dudas o filtra clientes. Se adapta al flujo de tu negocio, no al revés.
    </p>

    <!-- Bento 2x2 -->
    <div class="bento scroll-reveal" style="--d:150ms">
      {verticales.map((v) => (
        <a href={v.href} class="bento-cell group">
          <span class="text-4xl mb-5 block">{v.icon}</span>
          <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-yellow-400 mb-3 block">{v.titulo}</span>
          <h3 class="text-xl sm:text-2xl font-black text-white leading-tight mb-auto">{v.headline}</h3>
          <span class="bento-cta">
            {v.cta}
            <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </span>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-14 text-center scroll-reveal" style="--d:300ms">
      <button type="button" data-open-lead-modal class="inline-flex items-center gap-3 bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold px-8 py-4 transition-all text-sm uppercase tracking-wider">
        Quiero esto para mi negocio
      </button>
    </div>

  </div>
</section>

<style>
  .bento {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .bento {
      grid-template-columns: 1fr 1fr;
    }
  }

  .bento-cell {
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: all 0.3s ease;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
  }

  @media (min-width: 1024px) {
    .bento-cell {
      padding: 3rem;
      min-height: 260px;
    }
  }

  .bento-cell:hover {
    background: rgba(23, 23, 23, 0.9);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
  }

  /* Bordes internos */
  @media (min-width: 768px) {
    .bento-cell:nth-child(odd) {
      border-right: 1px solid rgba(255,255,255,0.06);
    }
    .bento-cell:nth-child(-n+2) {
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
  }

  @media (max-width: 767px) {
    .bento-cell + .bento-cell {
      border-top: 1px solid rgba(255,255,255,0.06);
    }
  }

  .bento-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #0a0a0a;
    background: #FACC15;
    padding: 0.625rem 1.25rem;
    margin-top: 1.5rem;
    transition: all 0.2s;
    align-self: flex-start;
  }

  .group:hover .bento-cta {
    background: #FDE047;
  }
</style>
