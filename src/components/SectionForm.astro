---
import {
  API_URL,
  TURNSTILE_SITE_KEY,
  LEAD_FORM_ID as DEFAULT_FORM_ID,
  LEAD_FORM_API_KEY as DEFAULT_API_KEY,
} from '../config';

interface Props {
  whatsappUrl: string;
  formId?: string;
  apiKey?: string;
}
const { whatsappUrl, formId, apiKey } = Astro.props;

const FORM_ID = formId || DEFAULT_FORM_ID;
const FORM_API_KEY = apiKey || DEFAULT_API_KEY;
const FORM_API_URL = API_URL;

const COUNTRIES = [
  { code: "+56",  name: "Chile",        flag: "🇨🇱" },
  { code: "+52",  name: "México",       flag: "🇲🇽" },
  { code: "+54",  name: "Argentina",    flag: "🇦🇷" },
  { code: "+57",  name: "Colombia",     flag: "🇨🇴" },
  { code: "+51",  name: "Perú",         flag: "🇵🇪" },
  { code: "+598", name: "Uruguay",      flag: "🇺🇾" },
  { code: "+593", name: "Ecuador",      flag: "🇪🇨" },
  { code: "+34",  name: "España",       flag: "🇪🇸" },
  { code: "+1",   name: "USA/Canadá",   flag: "🇺🇸" },
];
---

<section id="contacto" class="relative bg-neutral-950 text-white py-20 lg:py-32 px-6 sm:px-10 overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-[0.03]"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-yellow-400/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <div class="flex items-center gap-3 mb-6 scroll-reveal">
          <div class="w-8 h-px bg-yellow-400"></div>
          <span class="text-xs font-bold uppercase tracking-[0.3em] text-yellow-400/80">Contacto</span>
        </div>
        <h2 class="text-4xl sm:text-5xl font-black leading-[0.95] tracking-tight scroll-reveal" style="--d:50ms">
          Cuéntanos<br/>de tu negocio.
        </h2>
        <p class="mt-6 text-neutral-500 leading-relaxed max-w-md scroll-reveal" style="--d:100ms">
          20 minutos. Evaluamos tu negocio y te decimos si podemos ayudarte. Sin compromiso, te respondemos en menos de 24 horas.
        </p>
        <div class="mt-8 flex items-center gap-4 scroll-reveal" style="--d:150ms">
          <div class="w-px h-12 bg-yellow-400/30"></div>
          <div>
            <p class="text-sm text-neutral-500">¿Prefieres hablar directo?</p>
            <a href={whatsappUrl} target="_blank" data-wa-cta class="text-yellow-400 hover:text-yellow-300 font-bold text-sm transition-colors inline-flex items-center gap-2 mt-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Escríbenos por WhatsApp
            </a>
          </div>
        </div>
      </div>

      <div class="scroll-reveal" style="--d:100ms">
        <form id="lead-form" class="space-y-5" novalidate>
          <div>
            <label for="lead-name" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">Nombre<span class="text-yellow-400 ml-1">*</span></label>
            <input
              type="text"
              id="lead-name"
              name="name"
              required
              autocomplete="name"
              placeholder="Tu nombre"
              class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
            <p id="err-name" class="hidden text-xs text-red-400 mt-1.5"></p>
          </div>
          <div>
            <label for="lead-email" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">Email<span class="text-yellow-400 ml-1">*</span></label>
            <input
              type="email"
              id="lead-email"
              name="email"
              required
              autocomplete="email"
              placeholder="tu@correo.com"
              class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
            <p id="err-email" class="hidden text-xs text-red-400 mt-1.5"></p>
          </div>
          <div class="min-w-0">
            <label for="lead-phone" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">Teléfono</label>
            <div class="flex gap-2">
              <select
                id="lead-country"
                name="country"
                class="bg-neutral-900 border border-neutral-800 text-white px-3 py-4 text-sm focus:border-yellow-400 focus:outline-none transition-colors shrink-0 w-[110px]"
                aria-label="Código de país"
              >
                {COUNTRIES.map((c) => (
                  <option value={c.code} selected={c.code === "+56"}>{c.flag} {c.code}</option>
                ))}
              </select>
              <input
                type="tel"
                id="lead-phone"
                name="phone"
                autocomplete="tel"
                inputmode="numeric"
                placeholder="9 1234 5678"
                class="lead-input flex-1 min-w-0 bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
              />
            </div>
            <p id="err-phone" class="hidden text-xs text-red-400 mt-1.5"></p>
          </div>
          <div>
            <label for="lead-business" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">¿A qué se dedica tu negocio?<span class="text-yellow-400 ml-1">*</span></label>
            <input
              type="text"
              id="lead-business"
              name="business"
              required
              placeholder="Clínica dental, abogados, tienda de ropa..."
              class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
            <p id="err-business" class="hidden text-xs text-red-400 mt-1.5"></p>
          </div>
          <div>
            <label for="lead-website" class="block text-xs font-bold text-neutral-400 mb-2 uppercase tracking-wider">Sitio web o Instagram <span class="text-neutral-600 font-normal normal-case">(opcional)</span></label>
            <input
              type="text"
              id="lead-website"
              name="website"
              placeholder="minegocio.cl · @minegocio"
              class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
            <p id="err-website" class="hidden text-xs text-red-400 mt-1.5"></p>
          </div>
          <div>
            <div class="flex items-baseline justify-between mb-2">
              <label for="lead-help" class="block text-xs font-bold text-neutral-400 uppercase tracking-wider">¿En qué te podemos apoyar? <span class="text-neutral-600 font-normal normal-case">(opcional)</span></label>
              <span id="help-counter" class="text-[11px] text-neutral-600">0/250</span>
            </div>
            <textarea
              id="lead-help"
              name="help"
              rows="3"
              maxlength="250"
              placeholder="Cuéntanos brevemente qué necesitas o qué problema quieres resolver."
              class="lead-input w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors resize-none"
            ></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="lead-consent" name="consent" required class="mt-1 w-4 h-4 accent-yellow-400 bg-neutral-900 border-neutral-700" />
            <label for="lead-consent" class="text-xs text-neutral-500 leading-relaxed">Acepto que Lelemon me contacte para agendar una llamada. No spam.</label>
          </div>

          <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark" data-size="flexible"></div>

          <button
            type="submit"
            id="lead-submit"
            class="w-full bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold py-4 px-8 text-sm uppercase tracking-wider transition-all disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Quiero mi evaluación gratuita
          </button>
          <p id="form-feedback" class="text-sm text-center hidden"></p>
        </form>

        <div id="form-success" class="hidden text-center py-12">
          <div class="w-16 h-16 bg-yellow-400/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">¡Recibimos tus datos!</h3>
          <p class="text-neutral-400 max-w-sm mx-auto">Te contactaremos en menos de 24 horas para agendar tu evaluación gratuita.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lead-input.has-error {
    border-color: #f87171 !important;
  }
</style>

<script is:inline define:vars={{ TURNSTILE_SITE_KEY, FORM_API_URL, FORM_ID, FORM_API_KEY }}>
  (function() {
    var form = document.getElementById('lead-form');
    var submitBtn = document.getElementById('lead-submit');
    var feedback = document.getElementById('form-feedback');
    var successEl = document.getElementById('form-success');
    var helpCounter = document.getElementById('help-counter');

    function getTurnstileToken() {
      var el = form.querySelector('[name="cf-turnstile-response"]');
      return el ? el.value : '';
    }

    // Validators
    function isValidEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }
    function isValidPhone(v) {
      var digits = v.replace(/\D/g, '');
      return digits.length >= 7 && digits.length <= 14;
    }
    function isValidWebsite(v) {
      if (!v) return true;
      return /^(https?:\/\/)?[\w.-]+\.[a-z]{2,}(\/.*)?$/i.test(v) || /^@[\w.]+$/.test(v);
    }

    function fid(id) { return document.getElementById('lead-' + id); }
    function errEl(id) { return document.getElementById('err-' + id); }

    function showError(id, msg) {
      var input = fid(id);
      var err = errEl(id);
      if (input) input.classList.add('has-error');
      if (err) { err.textContent = msg; err.classList.remove('hidden'); }
    }
    function clearError(id) {
      var input = fid(id);
      var err = errEl(id);
      if (input) input.classList.remove('has-error');
      if (err) err.classList.add('hidden');
    }

    function validateField(id) {
      var val = (fid(id).value || '').trim();
      if (id === 'name') {
        if (val.length < 2) { showError(id, 'Ingresa al menos 2 caracteres.'); return false; }
      } else if (id === 'email') {
        if (!val) { showError(id, 'Email requerido.'); return false; }
        if (!isValidEmail(val)) { showError(id, 'Email no válido (ej: tu@correo.com).'); return false; }
      } else if (id === 'phone') {
        if (val && !isValidPhone(val)) { showError(id, 'Ingresa un teléfono válido (7-14 dígitos).'); return false; }
      } else if (id === 'business') {
        if (val.length < 2) { showError(id, 'Cuéntanos a qué se dedica tu negocio.'); return false; }
      } else if (id === 'website') {
        if (val && !isValidWebsite(val)) { showError(id, 'Ingresa un sitio (minegocio.cl) o handle (@minegocio).'); return false; }
      }
      clearError(id);
      return true;
    }

    function validateAll() {
      var ok = true;
      ['name','email','phone','business','website'].forEach(function(id) {
        if (!validateField(id)) ok = false;
      });
      return ok;
    }

    ['name','email','phone','business','website'].forEach(function(id) {
      var el = fid(id);
      if (!el) return;
      el.addEventListener('blur', function() { validateField(id); });
      el.addEventListener('input', function() {
        if (el.classList.contains('has-error')) clearError(id);
      });
    });

    var phoneEl = fid('phone');
    if (phoneEl) {
      phoneEl.addEventListener('input', function(e) {
        var cleaned = e.target.value.replace(/[^\d\s]/g, '');
        if (cleaned !== e.target.value) e.target.value = cleaned;
      });
    }

    var helpEl = fid('help');
    if (helpEl && helpCounter) {
      helpEl.addEventListener('input', function() {
        helpCounter.textContent = helpEl.value.length + '/250';
      });
    }

    function showFeedback(msg, isError) {
      feedback.textContent = msg;
      feedback.className = 'text-sm text-center mt-2 ' + (isError ? 'text-red-400' : 'text-green-400');
    }
    function setLoading(loading) {
      submitBtn.disabled = loading;
      submitBtn.textContent = loading ? 'Enviando...' : 'Quiero mi evaluación gratuita';
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      feedback.className = 'text-sm text-center hidden';

      if (!validateAll()) {
        showFeedback('Revisa los campos marcados.', true);
        return;
      }
      if (!document.getElementById('lead-consent').checked) {
        showFeedback('Debes aceptar ser contactado.', true);
        return;
      }
      if (!FORM_API_URL || !FORM_ID || !FORM_API_KEY) {
        showFeedback('Formulario no configurado.', true);
        return;
      }

      var name = fid('name').value.trim();
      var email = fid('email').value.trim();
      var countryCode = document.getElementById('lead-country').value;
      var phoneRaw = fid('phone').value.trim();
      var phone = phoneRaw ? countryCode + ' ' + phoneRaw : '';
      var business = fid('business').value.trim();
      var website = fid('website').value.trim();
      var help = fid('help').value.trim();

      var turnstileToken = getTurnstileToken();
      if (TURNSTILE_SITE_KEY && !turnstileToken) {
        showFeedback('Completa la verificación de seguridad.', true);
        return;
      }

      submitLead(name, email, phone, business, website, help, turnstileToken);
    });

    function submitLead(name, email, phone, business, website, help, turnstileToken) {
      setLoading(true);

      // Keys estándar que el dashboard traduce a labels en español
      var data = {};
      if (business) data.business_type = business;
      if (website) data.website = website;
      if (help) data.message = help;

      fetch(FORM_API_URL + '/public/forms/' + FORM_ID + '/leads', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': FORM_API_KEY,
        },
        body: JSON.stringify({
          name: name,
          email: email,
          phone: phone || undefined,
          data: Object.keys(data).length > 0 ? data : undefined,
          turnstileToken: turnstileToken || 'no-turnstile',
        }),
      })
      .then(function(res) {
        if (!res.ok) {
          return res.json().then(function(data) { throw new Error(data.message || 'Error al enviar'); });
        }
        return res.json();
      })
      .then(function() {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');

        if (typeof fbq === 'function') fbq('track', 'Lead', { content_name: 'Landing Form' });
        if (typeof gtag === 'function') gtag('event', 'generate_lead', { event_category: 'Form', event_label: 'Landing' });
      })
      .catch(function(err) {
        showFeedback(err.message || 'Error al enviar. Intenta de nuevo.', true);
        if (typeof turnstile !== 'undefined') {
          try { turnstile.reset(); } catch (e) {}
        }
      })
      .finally(function() { setLoading(false); });
    }
  })();
</script>
