---
import {
  API_URL,
  TURNSTILE_SITE_KEY,
  LEAD_FORM_ID as DEFAULT_FORM_ID,
  LEAD_FORM_API_KEY as DEFAULT_API_KEY,
} from '../config';

interface Props {
  whatsappUrl: string;
  formId?: string;
  apiKey?: string;
}
const { whatsappUrl, formId, apiKey } = Astro.props;

const FORM_ID = formId || DEFAULT_FORM_ID;
const FORM_API_KEY = apiKey || DEFAULT_API_KEY;
const FORM_API_URL = API_URL;
---

<section id="contacto" class="relative bg-neutral-950 text-white py-20 lg:py-32 px-6 sm:px-10 overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-[0.03]"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-yellow-400/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <div class="flex items-center gap-3 mb-6 scroll-reveal">
          <div class="w-8 h-px bg-yellow-400"></div>
          <span class="text-xs font-bold uppercase tracking-[0.3em] text-yellow-400/80">Contacto</span>
        </div>
        <h2 class="text-4xl sm:text-5xl font-black leading-[0.95] tracking-tight scroll-reveal" style="--d:50ms">
          Cuéntanos<br/>de tu negocio.
        </h2>
        <p class="mt-6 text-neutral-500 leading-relaxed max-w-md scroll-reveal" style="--d:100ms">
          20 minutos. Evaluamos tu negocio y te decimos si podemos ayudarte. Sin compromiso, te respondemos en menos de 24 horas.
        </p>
        <div class="mt-8 flex items-center gap-4 scroll-reveal" style="--d:150ms">
          <div class="w-px h-12 bg-yellow-400/30"></div>
          <div>
            <p class="text-sm text-neutral-500">¿Prefieres hablar directo?</p>
            <a href={whatsappUrl} target="_blank" data-wa-cta class="text-yellow-400 hover:text-yellow-300 font-bold text-sm transition-colors inline-flex items-center gap-2 mt-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Escríbenos por WhatsApp
            </a>
          </div>
        </div>
      </div>

      <div class="scroll-reveal" style="--d:100ms">
        <form id="lead-form" class="space-y-6" novalidate>
          <div>
            <label for="lead-name" class="block text-sm font-bold text-neutral-400 mb-2 uppercase tracking-wider">Nombre</label>
            <input
              type="text"
              id="lead-name"
              name="name"
              required
              autocomplete="name"
              placeholder="Tu nombre"
              class="w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
          </div>
          <div>
            <label for="lead-email" class="block text-sm font-bold text-neutral-400 mb-2 uppercase tracking-wider">Email</label>
            <input
              type="email"
              id="lead-email"
              name="email"
              required
              autocomplete="email"
              placeholder="tu@correo.com"
              class="w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
          </div>
          <div>
            <label for="lead-phone" class="block text-sm font-bold text-neutral-400 mb-2 uppercase tracking-wider">Teléfono</label>
            <input
              type="tel"
              id="lead-phone"
              name="phone"
              autocomplete="tel"
              placeholder="+56 9 XXXX XXXX"
              class="w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
          </div>
          <div>
            <label for="lead-business" class="block text-sm font-bold text-neutral-400 mb-2 uppercase tracking-wider">¿A qué se dedica tu negocio?</label>
            <input
              type="text"
              id="lead-business"
              name="business"
              required
              placeholder="Clínica dental, abogados, tienda de ropa..."
              class="w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
          </div>
          <div>
            <label for="lead-website" class="block text-sm font-bold text-neutral-400 mb-2 uppercase tracking-wider">Sitio web o Instagram <span class="text-neutral-600 font-normal normal-case">(opcional)</span></label>
            <input
              type="text"
              id="lead-website"
              name="website"
              placeholder="minegocio.cl · @minegocio"
              class="w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors"
            />
          </div>
          <div>
            <label for="lead-help" class="block text-sm font-bold text-neutral-400 mb-2 uppercase tracking-wider">¿En qué te podemos apoyar? <span class="text-neutral-600 font-normal normal-case">(opcional)</span></label>
            <textarea
              id="lead-help"
              name="help"
              rows="3"
              placeholder="Cuéntanos brevemente qué necesitas o qué problema quieres resolver."
              class="w-full bg-neutral-900 border border-neutral-800 text-white px-5 py-4 text-sm placeholder-neutral-600 focus:border-yellow-400 focus:outline-none transition-colors resize-none"
            ></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="lead-consent" name="consent" required class="mt-1 w-4 h-4 accent-yellow-400 bg-neutral-900 border-neutral-700" />
            <label for="lead-consent" class="text-xs text-neutral-500 leading-relaxed">Acepto que Lelemon me contacte para agendar una llamada. No spam.</label>
          </div>

          <!-- Cloudflare Turnstile (invisible) -->
          <div id="turnstile-container"></div>

          <button
            type="submit"
            id="lead-submit"
            class="w-full bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold py-4 px-8 text-sm uppercase tracking-wider transition-all disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Quiero mi evaluación gratuita
          </button>
          <p id="form-feedback" class="text-sm text-center hidden"></p>
        </form>

        <!-- Success state (hidden by default) -->
        <div id="form-success" class="hidden text-center py-12">
          <div class="w-16 h-16 bg-yellow-400/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">¡Recibimos tus datos!</h3>
          <p class="text-neutral-400 max-w-sm mx-auto">Te contactaremos en menos de 24 horas para agendar tu evaluación gratuita.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ TURNSTILE_SITE_KEY, FORM_API_URL, FORM_ID, FORM_API_KEY }}>
  (function() {
    var form = document.getElementById('lead-form');
    var submitBtn = document.getElementById('lead-submit');
    var feedback = document.getElementById('form-feedback');
    var successEl = document.getElementById('form-success');
    var turnstileToken = '';
    var turnstileWidgetId = null;

    function initTurnstile() {
      if (!TURNSTILE_SITE_KEY || typeof turnstile === 'undefined') return;
      turnstileWidgetId = turnstile.render('#turnstile-container', {
        sitekey: TURNSTILE_SITE_KEY,
        callback: function(token) { turnstileToken = token; },
        'expired-callback': function() { turnstileToken = ''; },
        'error-callback': function() { turnstileToken = ''; },
        size: 'invisible',
      });
    }

    // Turnstile script loads async — retry until available
    if (TURNSTILE_SITE_KEY) {
      if (typeof turnstile !== 'undefined') {
        initTurnstile();
      } else {
        var check = setInterval(function() {
          if (typeof turnstile !== 'undefined') {
            clearInterval(check);
            initTurnstile();
          }
        }, 500);
        setTimeout(function() { clearInterval(check); }, 10000);
      }
    }

    function showFeedback(msg, isError) {
      feedback.textContent = msg;
      feedback.className = 'text-sm text-center mt-2 ' + (isError ? 'text-red-400' : 'text-green-400');
    }

    function setLoading(loading) {
      submitBtn.disabled = loading;
      submitBtn.textContent = loading ? 'Enviando...' : 'Quiero mi evaluación gratuita';
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      feedback.className = 'text-sm text-center hidden';

      var name = document.getElementById('lead-name').value.trim();
      var email = document.getElementById('lead-email').value.trim();
      var phone = document.getElementById('lead-phone').value.trim();
      var business = document.getElementById('lead-business').value.trim();
      var website = document.getElementById('lead-website').value.trim();
      var help = document.getElementById('lead-help').value.trim();
      var consent = document.getElementById('lead-consent').checked;

      if (!name) { showFeedback('Ingresa tu nombre', true); return; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showFeedback('Ingresa un email válido', true); return;
      }
      if (!business) { showFeedback('Cuéntanos a qué se dedica tu negocio', true); return; }
      if (!consent) { showFeedback('Debes aceptar ser contactado', true); return; }
      if (!FORM_API_URL || !FORM_ID || !FORM_API_KEY) {
        showFeedback('Formulario no configurado', true); return;
      }

      // If Turnstile is configured but no token yet, trigger challenge
      if (TURNSTILE_SITE_KEY && !turnstileToken && typeof turnstile !== 'undefined') {
        turnstile.execute('#turnstile-container');
        var attempts = 0;
        var wait = setInterval(function() {
          attempts++;
          if (turnstileToken || attempts > 20) {
            clearInterval(wait);
            if (turnstileToken) {
              submitLead(name, email, phone, business, website, help);
            } else {
              showFeedback('Error de verificación. Intenta de nuevo.', true);
            }
          }
        }, 250);
        return;
      }

      submitLead(name, email, phone, business, website, help);
    });

    function submitLead(name, email, phone, business, website, help) {
      setLoading(true);

      // Combine business + website + help into phone field so we don't lose context
      // (backend schema only accepts name/email/phone/turnstileToken)
      var phoneWithContext = phone || '';
      if (business) phoneWithContext += (phoneWithContext ? ' | ' : '') + 'Negocio: ' + business;
      if (website) phoneWithContext += (phoneWithContext ? ' | ' : '') + 'Web/IG: ' + website;
      if (help) phoneWithContext += (phoneWithContext ? ' | ' : '') + 'Ayuda: ' + help;

      fetch(FORM_API_URL + '/public/forms/' + FORM_ID + '/leads', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': FORM_API_KEY,
        },
        body: JSON.stringify({
          name: name,
          email: email,
          phone: phoneWithContext || undefined,
          turnstileToken: turnstileToken || 'no-turnstile',
        }),
      })
      .then(function(res) {
        if (!res.ok) {
          return res.json().then(function(data) {
            throw new Error(data.message || 'Error al enviar');
          });
        }
        return res.json();
      })
      .then(function() {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');

        if (typeof fbq === 'function') {
          fbq('track', 'Lead', { content_name: 'Landing Form' });
        }
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', { event_category: 'Form', event_label: 'Landing' });
        }
      })
      .catch(function(err) {
        showFeedback(err.message || 'Error al enviar. Intenta de nuevo.', true);
        if (typeof turnstile !== 'undefined' && turnstileWidgetId !== null) {
          turnstile.reset(turnstileWidgetId);
          turnstileToken = '';
        }
      })
      .finally(function() {
        setLoading(false);
      });
    }
  })();
</script>
