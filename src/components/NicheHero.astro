---
interface Props {
  eyebrow: string;
  h1Plain: string;
  h1Accent: string;
  subtitle: string;
  bullets: string[];
  priceFrom: string;
  priceUnit?: string;
  ctaPrimaryLabel?: string;
  whatsappUrl: string;
  testimonial?: {
    quote: string;
    name: string;
    role: string;
    site?: string;
  };
}

const {
  eyebrow,
  h1Plain,
  h1Accent,
  subtitle,
  bullets,
  priceFrom,
  priceUnit = 'CLP + IVA / mes',
  ctaPrimaryLabel = 'Cuéntame qué vendes',
  whatsappUrl,
  testimonial,
} = Astro.props;
---

<section class="relative min-h-[100svh] bg-neutral-950 text-white overflow-hidden flex items-center pt-24 pb-12 sm:pt-28 sm:pb-16">
  <!-- Grid pattern -->
  <div class="absolute inset-0 grid-pattern opacity-[0.04]" aria-hidden="true"></div>
  <!-- Gradient accent -->
  <div class="absolute top-0 right-0 w-[70%] h-[60%] bg-[radial-gradient(ellipse_at_top_right,_rgba(250,204,21,0.12)_0%,_transparent_70%)]" aria-hidden="true"></div>
  <!-- Diagonal accent line -->
  <div class="absolute top-0 right-[20%] w-px h-full bg-gradient-to-b from-yellow-400/30 via-yellow-400/10 to-transparent skew-x-[-20deg]" aria-hidden="true"></div>

  <div class="relative w-full max-w-7xl mx-auto px-6 sm:px-10 grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-10 lg:gap-16 items-center">
    <div class="max-w-xl lg:max-w-none">
    <!-- Eyebrow -->
    <div class="flex items-center gap-3 mb-6">
      <div class="w-10 h-px bg-yellow-400"></div>
      <span class="text-[10px] sm:text-xs font-semibold uppercase tracking-[0.3em] text-yellow-400/80">{eyebrow}</span>
    </div>

    <!-- H1 -->
    <h1>
      <span class="block text-[clamp(2.25rem,6vw,4rem)] font-black leading-[0.95] tracking-tight">
        {h1Plain}
      </span>
      <span class="block text-[clamp(2.25rem,6vw,4rem)] font-black leading-[0.95] tracking-tight text-yellow-400 mt-1">
        {h1Accent}
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mt-6 text-base sm:text-lg text-neutral-300 leading-relaxed max-w-xl">
      {subtitle}
    </p>

    <!-- Bullets -->
    <ul class="mt-7 space-y-2.5 max-w-xl">
      {bullets.map((b) => (
        <li class="flex items-start gap-2.5 text-sm sm:text-base text-neutral-200">
          <svg class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span>{b}</span>
        </li>
      ))}
    </ul>

    <!-- Precio -->
    <div class="mt-8 flex items-baseline gap-2.5">
      <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.25em] text-neutral-500">Desde</span>
      <span class="text-2xl sm:text-3xl font-black text-white">{priceFrom}</span>
      <span class="text-xs sm:text-sm text-neutral-500">{priceUnit}</span>
    </div>

    <!-- CTAs -->
    <div class="mt-7 flex flex-col sm:flex-row gap-3">
      <button
        type="button"
        data-open-lead-modal
        class="group inline-flex items-center justify-center gap-3 bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold px-7 py-4 transition-all text-sm uppercase tracking-wider"
      >
        <span>{ctaPrimaryLabel}</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </button>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-wa-cta
        class="inline-flex items-center justify-center gap-2.5 text-yellow-400 font-bold px-7 py-4 text-sm uppercase tracking-wider border border-yellow-400/40 hover:border-yellow-400 hover:bg-yellow-400/5 transition-all"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp directo
      </a>
    </div>

    <!-- Trust mini -->
    {testimonial && (
      <div class="mt-10 pt-6 border-t border-neutral-800/70 flex items-start gap-3 max-w-xl">
        <div class="w-9 h-9 shrink-0 rounded-full bg-yellow-400/20 border border-yellow-400/30 flex items-center justify-center text-yellow-400 font-bold text-xs">
          {testimonial.name.charAt(0)}
        </div>
        <div class="min-w-0">
          <div class="flex items-center gap-1 text-yellow-400 text-[10px] mb-0.5" aria-label="5 estrellas">★★★★★</div>
          <p class="text-xs sm:text-sm text-neutral-300 leading-snug italic">"{testimonial.quote}"</p>
          <p class="text-[11px] text-neutral-500 mt-0.5">
            {testimonial.name} · {testimonial.role}
            {testimonial.site && (
              <>
                {' · '}
                <a href={`https://${testimonial.site}`} target="_blank" rel="noopener noreferrer" class="hover:text-yellow-400 underline decoration-neutral-700 underline-offset-2 hover:decoration-yellow-400 transition-colors">{testimonial.site}</a>
              </>
            )}
          </p>
        </div>
      </div>
    )}
    </div>

    <!-- Visual slot (desktop) -->
    <div class="hidden lg:block">
      <slot name="visual" />
    </div>
  </div>
</section>
