<script>
  function animateChatLoop(containerId: string) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const msgs = container.querySelectorAll('.chat-msg-2');
    const totalDuration = msgs.length * 600 + 3000;

    function runAnimation() {
      // Reset all messages
      msgs.forEach((msg) => msg.classList.remove('chat-visible'));
      // Show them one by one
      msgs.forEach((msg, i) => {
        setTimeout(() => msg.classList.add('chat-visible'), i * 600);
      });
    }

    // Start on scroll into view, then loop
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        runAnimation();
        setInterval(runAnimation, totalDuration);
        obs.unobserve(e.target);
      });
    }, { threshold: 0.2 });
    obs.observe(container);
  }
  animateChatLoop('chat-agenda');
  animateChatLoop('chat-venta');

  // Portfolio fan — JS hover (no flickering)
  const fanContainer = document.getElementById('portfolio-fan');
  if (fanContainer) {
    const fanCards = fanContainer.querySelectorAll('.fan-card');

    fanContainer.addEventListener('mousemove', (e) => {
      const rect = fanContainer.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width; // 0 to 1

      // Divide into 3 zones: left (back), center (mid), right (front)
      let activeIdx: number;
      if (x < 0.33) activeIdx = 0;
      else if (x < 0.66) activeIdx = 1;
      else activeIdx = 2;

      fanCards.forEach((card) => {
        const idx = Number(card.getAttribute('data-fan'));
        if (idx === activeIdx) {
          card.classList.add('fan-active');
          card.classList.remove('fan-dimmed');
        } else {
          card.classList.remove('fan-active');
          card.classList.add('fan-dimmed');
        }
      });
    });

    fanContainer.addEventListener('mouseleave', () => {
      fanCards.forEach((card) => {
        card.classList.remove('fan-active', 'fan-dimmed');
      });
    });
  }

  // Activity feed animation loop
  const feed = document.getElementById('activity-feed');
  if (feed) {
    const cards = feed.querySelectorAll('.feed-card');
    const totalTime = cards.length * 700 + 4000;

    function runFeed() {
      cards.forEach((card) => card.classList.remove('feed-visible'));
      cards.forEach((card, i) => {
        setTimeout(() => card.classList.add('feed-visible'), i * 700);
      });
    }

    const feedObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        runFeed();
        setInterval(runFeed, totalTime);
        feedObs.unobserve(e.target);
      });
    }, { threshold: 0.2 });
    feedObs.observe(feed);
  }
</script>
