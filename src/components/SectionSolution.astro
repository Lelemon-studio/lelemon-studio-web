---
interface Props {
  whatsappUrl: string;
}
const { whatsappUrl } = Astro.props;
---

<!-- ZONA 1: WEB — Fondo blanco, bold, limpio -->
<section id="como-funciona" class="relative bg-white py-24 lg:py-32 px-6 sm:px-10 overflow-hidden">
  <!-- Giant decorative text -->
  <div class="absolute top-1/2 -translate-y-1/2 -right-[5%] text-[18vw] font-black text-neutral-950/[0.03] leading-none select-none pointer-events-none tracking-tighter" aria-hidden="true">
    WEB
  </div>

  <div class="max-w-7xl mx-auto relative">
    <div class="flex items-center gap-3 mb-6 scroll-reveal">
      <div class="w-8 h-px bg-neutral-950"></div>
      <span class="text-xs font-bold uppercase tracking-[0.3em] text-neutral-400">01 — Tu web</span>
    </div>

    <div class="scroll-reveal" style="--d:50ms">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-neutral-950 leading-[0.95] tracking-tight">
          Una web pensada para que te escriban. No para que te miren.
        </h2>
        <p class="mt-6 text-neutral-600 text-lg leading-relaxed">
          Rápida, móvil, con tu WhatsApp a un toque y conectada a tus campañas. Cada visita entra al mismo sistema. Cada conversación, al mismo CRM.
        </p>
      </div>
    </div>
    <div class="scroll-reveal" style="--d:150ms">
      <div class="portfolio-fan w-full max-w-4xl mx-auto" id="portfolio-fan">
          <!-- Back card (venpu empresas) -->
          <a href="https://empresas.venpu.cl" target="_blank" rel="noopener noreferrer" class="fan-card fan-card--back block" data-fan="0" aria-label="Ver empresas.venpu.cl en nueva pestaña">
            <div class="fan-card__inner">
              <div class="flex items-center gap-1.5 px-3 py-2 bg-neutral-800">
                <div class="flex gap-1"><div class="w-2 h-2 rounded-full bg-red-500/60"></div><div class="w-2 h-2 rounded-full bg-yellow-500/60"></div><div class="w-2 h-2 rounded-full bg-green-500/60"></div></div>
                <span class="text-[10px] text-neutral-500 ml-2">empresas.venpu.cl</span>
              </div>
              <img src="/portfolio/venpu.webp" alt="Web empresas.venpu.cl — landing B2B automotoras" width="1920" height="1080" class="w-full aspect-[16/9] object-cover object-top" loading="lazy" decoding="async" />
            </div>
          </a>
          <!-- Middle card (laboral) -->
          <a href="https://teayudamoslaboral.cl" target="_blank" rel="noopener noreferrer" class="fan-card fan-card--mid block" data-fan="1" aria-label="Ver teayudamoslaboral.cl en nueva pestaña">
            <div class="fan-card__inner">
              <div class="flex items-center gap-1.5 px-3 py-2 bg-neutral-800">
                <div class="flex gap-1"><div class="w-2 h-2 rounded-full bg-red-500/60"></div><div class="w-2 h-2 rounded-full bg-yellow-500/60"></div><div class="w-2 h-2 rounded-full bg-green-500/60"></div></div>
                <span class="text-[10px] text-neutral-500 ml-2">teayudamoslaboral.cl</span>
              </div>
              <img src="/portfolio/laboral.webp" alt="Web Te Ayudamos Laboral" width="1920" height="1080" class="w-full aspect-[16/9] object-cover object-top" loading="lazy" decoding="async" />
            </div>
          </a>
          <!-- Front card (familia) -->
          <a href="https://teayudamosfamilia.cl" target="_blank" rel="noopener noreferrer" class="fan-card fan-card--front block" data-fan="2" aria-label="Ver teayudamosfamilia.cl en nueva pestaña">
            <div class="fan-card__inner fan-card__inner--front">
              <div class="flex items-center gap-1.5 px-3 py-2 bg-neutral-800">
                <div class="flex gap-1"><div class="w-2 h-2 rounded-full bg-red-500/60"></div><div class="w-2 h-2 rounded-full bg-yellow-500/60"></div><div class="w-2 h-2 rounded-full bg-green-500/60"></div></div>
                <span class="text-[10px] text-neutral-500 ml-2">teayudamosfamilia.cl</span>
              </div>
              <img src="/portfolio/familia.webp" alt="Web Te Ayudamos Familia" width="1920" height="1080" class="w-full aspect-[16/9] object-cover object-top" loading="lazy" decoding="async" />
            </div>
          </a>
        </div>
      <!-- Feature badges -->
      <div class="flex flex-wrap gap-3 mt-8 justify-center">
        <div class="glass-badge flex items-center gap-2 px-5 py-2.5">
          <svg class="w-4 h-4 text-yellow-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          <span class="text-xs font-bold text-neutral-800">100% Responsive</span>
        </div>
        <div class="glass-badge flex items-center gap-2 px-5 py-2.5">
          <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          <span class="text-xs font-bold text-neutral-800">&lt;2s de carga</span>
        </div>
        <div class="glass-badge flex items-center gap-2 px-5 py-2.5">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          <span class="text-xs font-bold text-neutral-800">Pixel + GA4 listos</span>
        </div>
        <div class="glass-badge flex items-center gap-2 px-5 py-2.5">
          <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="text-xs font-bold text-neutral-800">WhatsApp integrado</span>
        </div>
        <div class="glass-badge flex items-center gap-2 px-5 py-2.5">
          <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <span class="text-xs font-bold text-neutral-800">SEO optimizada</span>
        </div>
      </div>
      <div class="mt-10 text-center scroll-reveal" style="--d:200ms">
        <button type="button" data-open-lead-modal class="inline-flex items-center gap-2 text-sm font-bold text-neutral-950 hover:text-yellow-600 transition-colors">
          Quiero mi web
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ZONA 2: CAMPAÑAS — Dark con gradiente -->
<section class="relative bg-neutral-950 py-24 lg:py-32 px-6 sm:px-10 overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-[0.03]"></div>
  <div class="absolute top-0 right-[15%] w-[50%] h-[80%] bg-[radial-gradient(ellipse_at_top_right,_rgba(250,204,21,0.1)_0%,_transparent_60%)]"></div>
  <!-- Giant decorative text -->
  <div class="absolute bottom-[10%] -right-[5%] text-[16vw] font-black text-neutral-900 leading-none select-none pointer-events-none tracking-tighter" aria-hidden="true">
    ADS
  </div>

  <div class="max-w-7xl mx-auto relative">
    <div class="flex items-center gap-3 mb-6 scroll-reveal">
      <div class="w-8 h-px bg-yellow-400"></div>
      <span class="text-xs font-bold uppercase tracking-[0.3em] text-yellow-400/80">02 — Campañas</span>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="scroll-reveal" style="--d:50ms">
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[0.95] tracking-tight">
          Te traemos los clientes.<br/>
          <span class="text-yellow-400">Tú cierras los que valgan.</span>
        </h2>
        <p class="mt-8 text-neutral-400 text-lg leading-relaxed max-w-md">
          Estrategia, segmentación, lanzamiento y optimización de tus anuncios en Instagram y Facebook. Cada mes. Tú pones los creativos (fotos, videos) y recibes los leads ya respondidos, calificados y agendados.
        </p>
      </div>
      <div class="scroll-reveal" style="--d:150ms">
        <!-- Activity feed -->
        <div class="max-w-md lg:ml-auto space-y-3" id="activity-feed">
          <!-- Notification 1 -->
          <div class="feed-card glass-feed-card p-4 flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-green-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-white font-semibold">Nuevo lead: María González</p>
              <p class="text-xs text-neutral-400 mt-0.5">Consulta dental — Vino de campaña "Urgencias"</p>
              <p class="text-[10px] text-neutral-600 mt-1.5">Hace 3 min</p>
            </div>
            <div class="w-2 h-2 bg-green-400 rounded-full shrink-0 mt-2 pulse-dot"></div>
          </div>
          <!-- Notification 2 -->
          <div class="feed-card glass-feed-card p-4 flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-yellow-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-white font-semibold">CPA bajó 32% esta semana</p>
              <p class="text-xs text-neutral-400 mt-0.5">Presupuesto reasignado a la audiencia que más convierte</p>
              <p class="text-[10px] text-neutral-600 mt-1.5">Hace 1 hora</p>
            </div>
            <span class="text-xs font-bold text-yellow-400 shrink-0 mt-1">-32%</span>
          </div>
          <!-- Notification 3 -->
          <div class="feed-card glass-feed-card p-4 flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-white font-semibold">5 leads hoy con "Consulta gratis"</p>
              <p class="text-xs text-neutral-400 mt-0.5">Tu mejor día de la semana — CPA promedio: $4.200</p>
              <p class="text-[10px] text-neutral-600 mt-1.5">Hace 2 horas</p>
            </div>
            <span class="text-xs font-bold text-blue-400 shrink-0 mt-1">5 nuevos</span>
          </div>
          <!-- Notification 4 -->
          <div class="feed-card glass-feed-card p-4 flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-purple-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-white font-semibold">Reporte semanal listo</p>
              <p class="text-xs text-neutral-400 mt-0.5">23 leads · 12 clientes · ROAS 4.2x · Todo optimizado</p>
              <p class="text-[10px] text-neutral-600 mt-1.5">Hace 5 horas</p>
            </div>
            <span class="text-xs font-bold text-green-400 shrink-0 mt-1">4.2x</span>
          </div>
          <!-- Notification 5 -->
          <div class="feed-card glass-feed-card p-4 flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-red-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-white font-semibold">Campaña pausada automáticamente</p>
              <p class="text-xs text-neutral-400 mt-0.5">"Mujeres 25-34" no rendía — presupuesto movido a lo que sí funciona</p>
              <p class="text-[10px] text-neutral-600 mt-1.5">Ayer</p>
            </div>
            <span class="text-xs font-bold text-red-400 shrink-0 mt-1">Pausada</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-10 text-center scroll-reveal" style="--d:300ms">
      <button type="button" data-open-lead-modal class="inline-flex items-center gap-2 text-sm font-bold text-yellow-400 hover:text-yellow-300 transition-colors">
        Quiero mis campañas
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- ZONA 3: ASISTENTE — Fondo amarillo, disruptivo -->
<section class="relative bg-yellow-400 py-24 lg:py-32 px-6 sm:px-10 overflow-hidden">
  <div class="absolute inset-0 diagonal-lines-dark opacity-[0.04]"></div>
  <!-- Giant decorative text -->
  <div class="absolute top-1/2 -translate-y-1/2 -left-[3%] text-[14vw] font-black text-neutral-950/[0.06] leading-none select-none pointer-events-none tracking-tighter" aria-hidden="true">
    24/7
  </div>

  <div class="max-w-7xl mx-auto relative">
    <div class="flex items-center gap-3 mb-6 scroll-reveal">
      <div class="w-8 h-px bg-neutral-950"></div>
      <span class="text-xs font-bold uppercase tracking-[0.3em] text-neutral-950/50">03 — Asistente IA</span>
    </div>

    <div class="scroll-reveal" style="--d:50ms">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-neutral-950 leading-[0.95] tracking-tight">
          El que atiende cuando tú no alcanzas.
        </h2>
        <p class="mt-6 text-neutral-950 text-lg leading-relaxed font-medium">
          Responde, cotiza, agenda y hace el primer filtro. A las 2 AM, los domingos, en feriados. Cuando un cliente necesita hablar contigo, te lo traspasa. Tú decides cuándo entrar.
        </p>
      </div>
    </div>

    <!-- Two iPhone mocks with floating badges -->
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 max-w-3xl mx-auto">

      <!-- iPhone 1: Agendando cita -->
      <div class="scroll-reveal relative" style="--d:100ms">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-neutral-950/40 mb-5 text-center">Agenda citas</p>
        <!-- Floating badges -->
        <div class="badge-float badge-float--1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Responde en 1 min
        </div>
        <div class="badge-float badge-float--2">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Agenda sola
        </div>
        <div class="iphone-mock mx-auto">
          <div class="iphone-mock__frame">
            <!-- Notch -->
            <div class="iphone-notch"></div>
            <!-- Status bar -->
            <div class="flex items-center justify-between px-5 pt-1 pb-1 bg-[#075E54]">
              <span class="text-[10px] text-white/70 font-medium">23:14</span>
              <div class="flex items-center gap-1">
                <svg class="w-3 h-3 text-white/60" fill="currentColor" viewBox="0 0 24 24"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3a4.24 4.24 0 00-6 0zm-4-4l2 2a7.07 7.07 0 0110 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
                <div class="w-4 h-2.5 border border-white/50 rounded-sm relative"><div class="absolute inset-[1px] right-[2px] bg-green-400/80 rounded-[1px]"></div></div>
              </div>
            </div>
            <!-- WhatsApp header -->
            <div class="bg-[#075E54] text-white px-4 py-2 flex items-center gap-3">
              <svg class="w-4 h-4 text-white/80" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
              <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center text-sm">🦷</div>
              <div class="flex-1">
                <p class="font-semibold text-xs">Clínica Dental Sonríe</p>
                <p class="text-[9px] text-green-300">en línea</p>
              </div>
              <svg class="w-4 h-4 text-white/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            </div>
            <!-- Chat messages -->
            <div class="bg-[#ECE5DD] p-3 space-y-2" id="chat-agenda" style="min-height: 300px;">
              <p class="text-[9px] text-neutral-500 text-center bg-white/60 rounded-full px-3 py-0.5 mx-auto w-fit">Hoy</p>
              <div class="chat-msg-2 flex justify-end"><div class="bg-[#DCF8C6] rounded-lg rounded-tr-sm px-3 py-1.5 max-w-[85%] shadow-sm"><p class="text-[11px] text-neutral-800">Hola necesito una hora para mañana, se me partió una muela 😬</p><p class="text-[9px] text-neutral-400 text-right mt-0.5">23:14 <span class="text-blue-400">✓✓</span></p></div></div>
              <div class="chat-msg-2 flex justify-start"><div class="bg-white rounded-lg rounded-tl-sm px-3 py-1.5 max-w-[85%] shadow-sm"><p class="text-[11px] text-neutral-800">Hola! Tenemos hora mañana a las 9:30 y 12:00. Como es urgencia te damos prioridad 🏥</p><p class="text-[11px] text-neutral-800 mt-1">¿Cuál te acomoda?</p><p class="text-[9px] text-neutral-400 text-right mt-0.5">23:14 <span class="text-yellow-500 font-bold">IA</span></p></div></div>
              <div class="chat-msg-2 flex justify-end"><div class="bg-[#DCF8C6] rounded-lg rounded-tr-sm px-3 py-1.5 max-w-[85%] shadow-sm"><p class="text-[11px] text-neutral-800">9:30 porfa</p><p class="text-[9px] text-neutral-400 text-right mt-0.5">23:15 <span class="text-blue-400">✓✓</span></p></div></div>
