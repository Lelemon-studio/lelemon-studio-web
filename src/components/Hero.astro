---
interface Props {
  whatsappUrl: string;
  rubros: string[];
}
const { whatsappUrl, rubros } = Astro.props;
---

<section class="relative min-h-[85vh] lg:min-h-screen bg-neutral-950 text-white overflow-hidden flex items-center pt-28 pb-20 sm:pt-28 sm:pb-32" id="hero">
  <!-- Grid pattern background -->
  <div class="absolute inset-0 grid-pattern opacity-[0.04]"></div>
  <!-- Gradient accent -->
  <div class="absolute top-0 right-0 w-[60%] h-[70%] bg-[radial-gradient(ellipse_at_top_right,_rgba(250,204,21,0.12)_0%,_transparent_70%)]"></div>
  <!-- Diagonal accent lines -->
  <div class="absolute top-0 right-[20%] w-px h-full bg-gradient-to-b from-yellow-400/30 via-yellow-400/10 to-transparent skew-x-[-20deg]"></div>
  <div class="absolute top-0 right-[21%] w-px h-[60%] bg-gradient-to-b from-yellow-400/15 to-transparent skew-x-[-20deg]"></div>

  <!-- Large decorative stroke text — solo desktop, sutil -->
  <div class="hidden lg:block absolute top-[15%] -right-[5%] text-[18vw] font-black text-stroke-yellow leading-none select-none pointer-events-none opacity-[0.04] tracking-tighter" aria-hidden="true">
    LEMON
  </div>

  <!-- Floating lemons — 2 sutiles en desktop, 0 en mobile -->
  <div class="hidden lg:block absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="hero-lemon absolute top-[12%] right-[8%]" style="--dur:22s;--rot:25deg">
      <span class="text-8xl opacity-10">🍋</span>
    </div>
    <div class="hero-lemon absolute top-[65%] left-[6%]" style="--dur:26s;--rot:-20deg">
      <span class="text-6xl opacity-10">🍋</span>
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 sm:px-10 w-full">
    <div class="max-w-4xl">
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-8 hero-fade" style="--i:0">
        <div class="w-12 h-px bg-yellow-400"></div>
        <span class="text-xs font-semibold uppercase tracking-[0.3em] text-yellow-400/80">Marketing operado · Chile</span>
      </div>

      <!-- Main headline -->
      <h1 class="hero-fade" style="--i:1">
        <span class="block text-[clamp(2.5rem,7vw,5.5rem)] font-black leading-[0.95] tracking-tight">
          Potencia tu
        </span>
        <span class="block text-[clamp(2.5rem,7vw,5.5rem)] font-black leading-[0.95] tracking-tight text-yellow-400 mt-2">
          captación de clientes.
        </span>
      </h1>

      <p class="mt-8 sm:mt-10 text-base sm:text-xl text-neutral-300 max-w-xl leading-relaxed hero-fade" style="--i:2">
        Armamos tu web, corremos tus anuncios en Instagram y Facebook, ponemos un asistente con IA en tu WhatsApp y ordenamos los leads en tu CRM.
        <span class="block mt-3 text-sm text-neutral-500">
          Todo el proceso de adquisición, operado. Tú apareces solo para cerrar.
        </span>
      </p>

      <!-- Marquee rubros — solo desktop (evita truncation mobile + animation cost) -->
      <div class="hidden sm:block mt-10 overflow-hidden mask-fade hero-fade" style="--i:3">
        <div class="marquee-track flex gap-4 w-max">
          {[...rubros, ...rubros, ...rubros].map((r) => (
            <span class="text-xs text-yellow-400/70 uppercase tracking-[0.15em] font-semibold whitespace-nowrap border border-yellow-400/20 bg-yellow-400/5 px-4 py-2">{r}</span>
          ))}
        </div>
      </div>

      <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 hero-fade" style="--i:4">
        <button type="button" data-open-lead-modal class="group inline-flex items-center justify-center gap-3 bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold px-7 py-4 transition-all text-sm uppercase tracking-wider">
          <span>Cuéntame qué vendes</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </button>
        <button type="button" data-open-demo-modal class="group inline-flex items-center justify-center gap-2.5 text-yellow-400 font-bold px-7 py-4 text-sm uppercase tracking-wider border border-yellow-400/40 hover:border-yellow-400 hover:bg-yellow-400/5 transition-all">
          <span class="text-base leading-none">🍋</span>
          Conversa con Pepita
        </button>
      </div>

      <!-- Social proof row -->
      <div class="mt-10 sm:mt-12 hero-fade" style="--i:5">
        <div class="flex flex-col sm:flex-row sm:items-center gap-5 sm:gap-8">
          <!-- Testimonio + rating -->
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 shrink-0 rounded-full bg-yellow-400/20 border border-yellow-400/30 flex items-center justify-center text-yellow-400 font-bold text-sm">N</div>
            <div>
              <div class="flex items-center gap-1 text-yellow-400 text-[11px] mb-0.5" aria-label="5 estrellas">
                ★★★★★
              </div>
              <p class="text-sm text-neutral-300 leading-snug">
                <span class="italic">"Cerré mis 3 primeros clientes el primer mes."</span>
              </p>
              <p class="text-[11px] text-neutral-500 mt-0.5">
                Nicolás V. · Abogado ·
                <a href="https://teayudamoslaboral.cl" target="_blank" rel="noopener noreferrer" class="hover:text-yellow-400 underline decoration-neutral-700 underline-offset-2 hover:decoration-yellow-400 transition-colors">teayudamoslaboral.cl</a>
              </p>
            </div>
          </div>

          <!-- Divider + sites operando -->
          <div class="hidden sm:block w-px h-10 bg-neutral-800"></div>

          <div class="flex items-center gap-3">
            <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-neutral-500 whitespace-nowrap">Ya operando con</span>
            <div class="flex items-center gap-3 text-[11px] text-neutral-400">
              <a href="https://teayudamoslaboral.cl" target="_blank" rel="noopener noreferrer" class="hover:text-yellow-400 transition-colors">laboral.cl</a>
              <span class="text-neutral-700">·</span>
              <a href="https://teayudamosfamilia.cl" target="_blank" rel="noopener noreferrer" class="hover:text-yellow-400 transition-colors">familia.cl</a>
              <span class="text-neutral-700">·</span>
              <span class="text-neutral-500">+ más</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom diagonal cut -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none" class="w-full h-20">
      <path d="M0 80L1440 20V80H0Z" fill="white"/>
    </svg>
  </div>
</section>

<style>
  .hero-fade {
    opacity: 0;
    transform: translateY(24px);
    animation: hero-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i) * 150ms + 300ms);
  }
  @keyframes hero-enter {
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-lemon {
    animation: lemon-float var(--dur, 20s) infinite ease-in-out;
  }
  @keyframes lemon-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-20px) rotate(calc(var(--rot, 20deg) * 0.5)); }
    50% { transform: translateY(8px) rotate(var(--rot, 20deg)); }
    75% { transform: translateY(-15px) rotate(calc(var(--rot, 20deg) * 0.3)); }
  }
  .mask-fade {
    -webkit-mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
  }
  .marquee-track {
    animation: marquee 20s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
</style>
