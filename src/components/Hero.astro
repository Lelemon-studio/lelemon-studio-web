---
interface Props {
  whatsappUrl: string;
  rubros: string[];
}
const { whatsappUrl, rubros } = Astro.props;
---

<!-- Barra de urgencia -->
<div class="fixed top-0 left-0 right-0 z-[60] bg-red-600 text-white text-center py-2 px-4" id="urgency-bar">
  <p class="text-xs sm:text-sm font-bold uppercase tracking-wider">
    <span class="inline-block w-2 h-2 bg-white rounded-full animate-pulse mr-2 align-middle"></span>
    Implementación + primer mes por $600 USD · Cupos abiertos este mes
    <span class="inline-block w-2 h-2 bg-white rounded-full animate-pulse ml-2 align-middle"></span>
  </p>
</div>

<section class="relative min-h-screen bg-neutral-950 text-white overflow-hidden flex items-center pt-32 pb-28 sm:pt-28 sm:pb-32" id="hero">
  <!-- Grid pattern background -->
  <div class="absolute inset-0 grid-pattern opacity-[0.04]"></div>
  <!-- Gradient accent -->
  <div class="absolute top-0 right-0 w-[60%] h-[70%] bg-[radial-gradient(ellipse_at_top_right,_rgba(250,204,21,0.12)_0%,_transparent_70%)]"></div>
  <!-- Diagonal accent lines -->
  <div class="absolute top-0 right-[20%] w-px h-full bg-gradient-to-b from-yellow-400/30 via-yellow-400/10 to-transparent skew-x-[-20deg]"></div>
  <div class="absolute top-0 right-[21%] w-px h-[60%] bg-gradient-to-b from-yellow-400/15 to-transparent skew-x-[-20deg]"></div>

  <!-- Large decorative stroke text -->
  <div class="absolute top-[15%] -right-[5%] text-[18vw] font-black text-stroke-yellow leading-none select-none pointer-events-none opacity-[0.06] tracking-tighter" aria-hidden="true">
    LEMON
  </div>

  <!-- Floating lemons -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="hero-lemon absolute top-[12%] right-[8%]" style="--dur:18s;--rot:25deg">
      <span class="text-9xl opacity-15">🍋</span>
    </div>
    <div class="hero-lemon absolute top-[60%] left-[3%]" style="--dur:22s;--rot:-20deg">
      <span class="text-8xl opacity-10">🍋</span>
    </div>
    <div class="hero-lemon absolute top-[75%] right-[18%]" style="--dur:26s;--rot:40deg">
      <span class="text-7xl opacity-10">🍋</span>
    </div>
    <div class="hero-lemon absolute top-[20%] left-[15%]" style="--dur:20s;--rot:15deg">
      <span class="text-5xl opacity-15">🍋</span>
    </div>
    <div class="hero-lemon absolute top-[40%] right-[35%]" style="--dur:30s;--rot:-35deg">
      <span class="text-4xl opacity-20">🍋</span>
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 sm:px-10 w-full">
    <div class="max-w-4xl">
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-8 hero-fade" style="--i:0">
        <div class="w-12 h-px bg-yellow-400"></div>
        <span class="text-xs font-semibold uppercase tracking-[0.3em] text-yellow-400/80">Marketing operado · Chile</span>
      </div>

      <!-- Main headline -->
      <h1 class="hero-fade" style="--i:1">
        <span class="block text-[clamp(2.5rem,7vw,5.5rem)] font-black leading-[0.95] tracking-tight">
          Digitaliza tu negocio
        </span>
        <span class="block text-[clamp(2.5rem,7vw,5.5rem)] font-black leading-[0.95] tracking-tight mt-2">
          <span class="text-stroke-yellow">para que</span>
          <span class="text-yellow-400 ml-3">venda solo.</span>
        </span>
      </h1>

      <p class="mt-10 text-lg sm:text-xl text-neutral-500 max-w-xl leading-relaxed hero-fade" style="--i:2">
        Armamos tu web, ponemos un asistente con IA atendiendo tu WhatsApp, y gestionamos tus anuncios en Instagram y Facebook. Tu negocio atrae y atiende clientes las 24 horas. Tú apareces solo cuando están listos para cerrar.
        <span class="block mt-4 text-sm text-neutral-600">
          Incluye CRM propio y reportes cada mes.
        </span>
      </p>

      <!-- Marquee rubros -->
      <div class="mt-10 overflow-hidden mask-fade hero-fade" style="--i:3">
        <div class="marquee-track flex gap-4 w-max">
          {[...rubros, ...rubros, ...rubros].map((r) => (
            <span class="text-xs text-yellow-400/70 uppercase tracking-[0.15em] font-semibold whitespace-nowrap border border-yellow-400/20 bg-yellow-400/5 px-4 py-2">{r}</span>
          ))}
        </div>
      </div>

      <div class="mt-12 flex flex-col sm:flex-row gap-5 hero-fade" style="--i:4">
        <button type="button" data-open-lead-modal class="group inline-flex items-center gap-3 bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold px-8 py-4 transition-all text-sm uppercase tracking-wider">
          <span>Cuéntame qué vendes</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </button>
        <a href={whatsappUrl} target="_blank" data-wa-cta class="inline-flex items-center gap-3 text-neutral-500 hover:text-yellow-400 font-medium px-8 py-4 border border-neutral-800 hover:border-yellow-400/30 transition-all text-sm uppercase tracking-wider">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escríbenos por WhatsApp
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom diagonal cut -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none" class="w-full h-20">
      <path d="M0 80L1440 20V80H0Z" fill="white"/>
    </svg>
  </div>
</section>

<style>
  .hero-fade {
    opacity: 0;
    transform: translateY(24px);
    animation: hero-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i) * 150ms + 300ms);
  }
  @keyframes hero-enter {
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-lemon {
    animation: lemon-float var(--dur, 20s) infinite ease-in-out;
  }
  @keyframes lemon-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-20px) rotate(calc(var(--rot, 20deg) * 0.5)); }
    50% { transform: translateY(8px) rotate(var(--rot, 20deg)); }
    75% { transform: translateY(-15px) rotate(calc(var(--rot, 20deg) * 0.3)); }
  }
  .mask-fade {
    -webkit-mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
  }
  .marquee-track {
    animation: marquee 20s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
</style>
