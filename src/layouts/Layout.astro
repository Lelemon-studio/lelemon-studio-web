---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Potencia tu captación de clientes. Armamos tu web, corremos tus anuncios en Instagram y Facebook, ponemos un asistente con IA en tu WhatsApp y ordenamos los leads en tu CRM.",
  ogImage = "/og.png",
  canonicalUrl = "https://lelemon.cl/",
} = Astro.props;

const siteName = "Lelemon";
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const siteUrl = "https://lelemon.cl";

// SEO: keywords naturales (no stuffing, orden por importancia)
const keywords = "marketing digital chile, asistente IA whatsapp, agencia marketing pyme, CRM con IA, anuncios instagram facebook chile, automatización ventas whatsapp, agencia digital santiago, marketing operado chile";

// ── Analytics IDs ──
const META_PIXEL_ID = "1631046424566981";
const GA4_MEASUREMENT_ID = "G-4WFRN3WMMJ";

// ── Lead Form Config ──
import { TURNSTILE_SITE_KEY } from '../config';
import LeadModal from '../components/LeadModal.astro';

const whatsappUrl = "https://wa.me/56950467634?text=Hola,%20me%20interesa%20saber%20m%C3%A1s%20sobre%20Lelemon";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="author" content="Lelemon" />
    <meta name="publisher" content="Lelemon" />
    <meta name="geo.region" content="CL" />
    <meta name="geo.placename" content="Santiago, Chile" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="Lelemon — Potencia tu captación de clientes" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:image:alt" content="Lelemon — Potencia tu captación de clientes" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- DNS prefetch de dominios criticos -->
    <link rel="dns-prefetch" href="https://connect.facebook.net" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://challenges.cloudflare.com" />
    <link rel="dns-prefetch" href="https://api.lelemon.cl" />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a0a" />

    <!-- GA4 via Partytown (runs in Web Worker — zero main thread) -->
    <script type="text/partytown" is:inline define:vars={{ GA4_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA4_MEASUREMENT_ID);
    </script>
    <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`}></script>

    <!-- Meta Pixel fallback noscript (Pixel inicia via deferred loader al final del body) -->
    <noscript>
      <img height="1" width="1" style="display:none"
        src={`https://www.facebook.com/tr?id=${META_PIXEL_ID}&ev=PageView&noscript=1`} />
    </noscript>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <slot />

    <!-- Lead Modal global (se abre con data-open-lead-modal) -->
    <LeadModal whatsappUrl={whatsappUrl} />

    <!-- Deferred Meta Pixel + Turnstile lazy loader + CTA tracking
         GA4 ya corre en Web Worker vía Partytown (zero main thread) -->
    <script is:inline define:vars={{ META_PIXEL_ID }}>
      (function() {
        // Stub de gtag: dataLayer.push es forwardeado a Partytown worker
        window.dataLayer = window.dataLayer || [];
        window.gtag = window.gtag || function() { window.dataLayer.push(arguments); };

        // Stub de fbq: encola hasta que Pixel cargue
        window.fbq = window.fbq || function() {
          (window.fbq.q = window.fbq.q || []).push([].slice.call(arguments));
        };

        function loadPixel() {
          if (window._pixelLoaded) return;
          window._pixelLoaded = true;
          var savedQueue = (window.fbq && window.fbq.q) || [];
          delete window.fbq;
          !function(f,b,e,v,n,t,s) {
            if(f.fbq)return;n=f.fbq=function(){n.callMethod? n.callMethod.apply(n,arguments):n.queue.push(arguments)};
            if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
            t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)
          }(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
          window.fbq('init', META_PIXEL_ID);
          window.fbq('track', 'PageView');
          savedQueue.forEach(function(args) { window.fbq.apply(null, args); });
        }

        function loadTurnstile() {
          if (window.turnstile || window._turnstileLoading) return;
          window._turnstileLoading = true;
          var s = document.createElement('script');
          s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
          s.async = true;
          s.defer = true;
          document.head.appendChild(s);
        }
        window.loadTurnstile = loadTurnstile;

        // Pixel al idle o fallback post-load
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadPixel, { timeout: 3000 });
        } else {
          window.addEventListener('load', function() { setTimeout(loadPixel, 1500); });
        }

        // En primera interacción: cargar Pixel + Turnstile
        ['click','scroll','touchstart','keydown'].forEach(function(ev) {
          window.addEventListener(ev, function handler() {
            loadPixel();
            loadTurnstile();
          }, { once: true, passive: true });
        });

        // CTA tracking (fbq encola hasta que Pixel cargue; gtag va directo al worker)
        document.addEventListener('DOMContentLoaded', function() {
          document.querySelectorAll('[data-wa-cta]').forEach(function(el) {
            el.addEventListener('click', function() {
              window.fbq('track', 'Contact', { content_name: 'WhatsApp CTA' });
              window.gtag('event', 'contact', { event_category: 'CTA', event_label: 'WhatsApp' });
            });
          });

          var scheduleCta = document.getElementById('pricing-cta');
          if (scheduleCta) {
            scheduleCta.addEventListener('click', function() {
              window.fbq('track', 'Schedule', { content_name: 'Pricing CTA' });
              window.gtag('event', 'schedule', { event_category: 'CTA', event_label: 'Pricing' });
            });
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>
