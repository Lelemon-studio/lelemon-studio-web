---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Creamos tu web, activamos un asistente IA en WhatsApp y gestionamos Meta Ads para que respondas más rápido y generes más clientes. Evaluación gratis.",
  ogImage = "/og.png",
  canonicalUrl = "https://lelemon.cl/",
} = Astro.props;

const siteName = "Lelemon";
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const siteUrl = "https://lelemon.cl";

// ── Analytics IDs ──
const META_PIXEL_ID = "1631046424566981";
const GA4_MEASUREMENT_ID = "G-4WFRN3WMMJ";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Lelemon" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Meta Pixel -->
    <script is:inline define:vars={{ META_PIXEL_ID }}>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window,document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', META_PIXEL_ID);
      fbq('track', 'PageView');
    </script>
    <noscript>
      <img height="1" width="1" style="display:none"
        src={`https://www.facebook.com/tr?id=${META_PIXEL_ID}&ev=PageView&noscript=1`} />
    </noscript>

    <!-- Google Analytics 4 -->
    <script is:inline define:vars={{ GA4_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA4_MEASUREMENT_ID);
    </script>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`}></script>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <slot />

    <!-- Meta Pixel conversion events on CTAs -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Track Lead on all WhatsApp CTA clicks
        document.querySelectorAll('[data-wa-cta]').forEach(function(el) {
          el.addEventListener('click', function() {
            if (typeof fbq === 'function') {
              fbq('track', 'Lead', { content_name: 'WhatsApp CTA' });
            }
            if (typeof gtag === 'function') {
              gtag('event', 'generate_lead', { event_category: 'CTA', event_label: 'WhatsApp' });
            }
          });
        });

        // Track Schedule on pricing CTA click
        var scheduleCta = document.getElementById('pricing-cta');
        if (scheduleCta) {
          scheduleCta.addEventListener('click', function() {
            if (typeof fbq === 'function') {
              fbq('track', 'Schedule', { content_name: 'Pricing CTA' });
            }
            if (typeof gtag === 'function') {
              gtag('event', 'schedule', { event_category: 'CTA', event_label: 'Pricing' });
            }
          });
        }
      });
    </script>
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>
