---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Más ventas para tu negocio cada mes. Web profesional, agente IA en WhatsApp y campañas en Meta — montados, conectados y operados por nosotros. Servicios independientes desde $100.000 CLP/mes o pack completo desde $350.000.",
  ogImage = "/og.png",
  canonicalUrl = "https://lelemon.cl/",
} = Astro.props;

const siteName = "Lelemon";
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const siteUrl = "https://lelemon.cl";

// SEO: keywords naturales (no stuffing, orden por importancia)
const keywords = "agencia marketing pyme chile, asistente IA whatsapp chile, web profesional pyme, agente IA atención whatsapp, CRM con IA, anuncios instagram facebook chile, marketing operado chile, agencia digital santiago, e-commerce shopify chile";

// ── Analytics IDs ──
const META_PIXEL_ID = "1631046424566981";
const GA4_MEASUREMENT_ID = "G-4WFRN3WMMJ";

// ── Lead Form Config ──
import { TURNSTILE_SITE_KEY, POSTHOG_KEY, POSTHOG_HOST } from '../config';
import LeadModal from '../components/LeadModal.astro';
import DemoChatModal from '../components/DemoChatModal.astro';

const whatsappUrl = "https://wa.me/56950467634?text=Hola,%20me%20interesa%20saber%20m%C3%A1s%20sobre%20Lelemon";

// Mensaje del FAB según la página actual — para identificar el interés del lead
const path = Astro.url.pathname;
const fabMessages: Record<string, string> = {
  '/web': 'Hola, me interesa que me ayuden con mi web 👋',
  '/agente-ia': 'Hola, me interesa el agente IA en WhatsApp 👋',
  '/marketing': 'Hola, me interesa que me ayuden con anuncios y marketing 👋',
  '/nosotros': 'Hola, vengo desde la web de Lelemon 👋',
};
const fabMessage = fabMessages[path.replace(/\/$/, '') || '/'] ?? 'Hola, vengo desde la web 👋';
const whatsappFabUrl = `https://wa.me/56950467634?text=${encodeURIComponent(fabMessage)}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="author" content="Lelemon" />
    <meta name="publisher" content="Lelemon" />
    <meta name="geo.region" content="CL" />
    <meta name="geo.placename" content="Santiago, Chile" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="Lelemon — Más ventas para tu negocio cada mes" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:image:alt" content="Lelemon — Más ventas para tu negocio cada mes" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Preload logo above-the-fold (LCP element helper) -->
    <link rel="preload" as="image" href="/logo-white.svg" fetchpriority="high" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- DNS prefetch de dominios criticos -->
    <link rel="dns-prefetch" href="https://connect.facebook.net" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://challenges.cloudflare.com" />
    <link rel="dns-prefetch" href="https://api.lelemon.cl" />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Config para /scripts/init.js (cargado con defer abajo) -->
    <script is:inline define:vars={{ META_PIXEL_ID, POSTHOG_KEY, POSTHOG_HOST, GA4_MEASUREMENT_ID }}>
      window.__LELEMON__ = { metaPixelId: META_PIXEL_ID, posthogKey: POSTHOG_KEY, posthogHost: POSTHOG_HOST, ga4Id: GA4_MEASUREMENT_ID };
    </script>
    <script src="/scripts/init.js" defer></script>

    <!-- Meta Pixel fallback noscript -->
    <noscript>
      <img height="1" width="1" style="display:none"
        src={`https://www.facebook.com/tr?id=${META_PIXEL_ID}&ev=PageView&noscript=1`} />
    </noscript>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <slot />

    <!-- Lead Modal global (se abre con data-open-lead-modal) -->
    <LeadModal whatsappUrl={whatsappUrl} />

    <!-- Demo Chat Modal global (se abre con data-open-demo-modal) -->
    <DemoChatModal />

    <!-- Floating WhatsApp button (mobile + desktop) -->
    <a
      href={whatsappFabUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-wa-cta
      aria-label="Hablar por WhatsApp"
      class="fab-wa fixed bottom-5 right-5 sm:bottom-6 sm:right-6 z-[90] w-14 h-14 sm:w-[60px] sm:h-[60px] bg-[#25D366] hover:bg-[#1faa55] rounded-full shadow-[0_8px_20px_-4px_rgba(37,211,102,0.45)] flex items-center justify-center transition-all hover:scale-110 active:scale-95"
    >
      <svg class="w-7 h-7 sm:w-8 sm:h-8 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="sr-only">Abrir WhatsApp</span>
    </a>
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>
