---
import Layout from '../layouts/Layout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const whatsappUrl = "https://wa.me/56950467634?text=Hola,%20me%20interesa%20el%20agente%20IA%20de%20Lelemon";

const tiers = [
  {
    name: "Starter",
    capacity: "500 sesiones / mes",
    price: "$150.000",
    priceUnit: "CLP + IVA / mes",
    priceImpl: "$200.000",
    forWhom: "Solopreneurs, clínicas chicas, talleres con bajo volumen.",
    ctaLabel: "Cuéntame qué vendes",
  },
  {
    name: "Pro",
    capacity: "1.000 sesiones / mes",
    price: "$200.000",
    priceUnit: "CLP + IVA / mes",
    priceImpl: "$200.000",
    forWhom: "PYME mediana con flujo constante de consultas.",
    ctaLabel: "Cuéntame qué vendes",
  },
  {
    name: "Business",
    capacity: "2.000 sesiones / mes",
    price: "$250.000",
    priceUnit: "CLP + IVA / mes",
    priceImpl: "$200.000",
    forWhom: "PYME activa con campañas corriendo y alto volumen.",
    ctaLabel: "Cuéntame qué vendes",
    badge: "Más pedido",
    featured: true,
  },
  {
    name: "Custom",
    capacity: "+2.000 sesiones / mes",
    price: "Conversemos",
    forWhom: "Volúmenes altos, multi-rubro o necesidades específicas.",
    ctaLabel: "Hablemos",
  },
];

const features = [
  {
    icon: "clock",
    title: "Atiende 24/7 en tu WhatsApp",
    description: "Sábados, domingos, feriados, 3 AM. Tus clientes nunca encuentran el negocio cerrado. Responde en menos de 1 minuto.",
    meta: "24/7",
    tags: ["IA", "WhatsApp", "Auto"],
    colSpan: 2,
    featured: true,
  },
  {
    icon: "graduation",
    title: "Entrenado con tu negocio",
    description: "Sabe qué vendes, cuánto cuesta, qué horarios manejas. No improvisa.",
    meta: "Custom",
    tags: ["Onboarding"],
  },
  {
    icon: "check",
    title: "Califica leads",
    description: "Detecta quién está listo para comprar. Solo te llega lo caliente — el resto se gestiona solo.",
    meta: "Auto",
    tags: ["Sales", "SDR"],
  },
  {
    icon: "calendar",
    title: "Agenda en tu calendar",
    description: "Conectado a Google Calendar. El cliente elige hora, queda agendado, recibe recordatorio automático.",
    meta: "G-Cal",
    tags: ["Calendar", "Booking"],
  },
  {
    icon: "user-check",
    title: "Pasa a humano",
    description: "Cuando hace falta, el agente te traspasa el chat. Tú decides cuándo entrar.",
    meta: "Handoff",
    tags: ["Live"],
  },
  {
    icon: "dashboard",
    title: "Panel CRM + reportes",
    description: "Cada conversación, cada lead, cada oportunidad. Estados, historial, notas. Tu equipo trabaja desde ahí.",
    meta: "Incluido",
    tags: ["CRM", "Inbox", "Reports"],
    colSpan: 2,
  },
  {
    icon: "report",
    title: "Reportes mensuales",
    description: "Cuántas conversaciones, cuántos calificados, cuánto cerraste. Sabes qué te está aportando.",
    meta: "Mensual",
    tags: ["Analytics"],
  },
];

const faqs = [
  {
    question: "¿Se nota que es un bot?",
    answer: "No. Las respuestas son naturales y conversacionales. Está entrenado con la voz de tu negocio. Si un cliente pregunta algo que no sabe, te lo traspasa antes de inventar respuestas.",
  },
  {
    question: "¿Qué pasa con el WhatsApp?",
    answer: "Usamos el número de WhatsApp Business de tu negocio. Si no tienes uno, te ayudamos a crearlo y lo dejamos separado de tu WhatsApp personal. Conectamos el agente a ese número.",
  },
  {
    question: "¿Puedo entrar a las conversaciones cuando quiera?",
    answer: "Sí. En el panel ves cada chat en tiempo real. Puedes pausar al agente, tomar el control, escribir tú mismo y volver a activarlo. Tú mandas siempre.",
  },
  {
    question: "¿Qué es una sesión?",
    answer: "Toda la conversación con un cliente, no importa cuántos mensajes intercambien. Si un cliente te escribe 30 mensajes en un chat, eso cuenta como 1 sesión. Las sesiones se reinician cuando el cliente vuelve después de inactividad o si la conversación se cierra.",
  },
  {
    question: "¿Qué pasa si supero las sesiones del tier?",
    answer: "$200 CLP por sesión extra. Si esto se vuelve recurrente, lo más conveniente es subir al tier siguiente y bajar el costo unitario. Te avisamos en el reporte mensual.",
  },
  {
    question: "¿Puedo cambiar de tier después?",
    answer: "Sí. Si arrancas en Starter y empieza a llegarte más volumen, subes a Pro o Business sin re-implementación. Es solo un cambio en el plan. También puedes bajar si bajó el flujo.",
  },
  {
    question: "¿Puede vender o solo responde?",
    answer: "Vende. Cotiza, manda links de pago, agenda citas, responde objeciones. Está armado como SDR (vendedor): su trabajo es mover al cliente hacia la decisión, no solo contestar dudas.",
  },
  {
    question: "¿Cuánto se demora en estar operando?",
    answer: "Entre 5 y 10 días. Hacemos una llamada de 30-45 minutos donde nos cuentas todo del negocio, el agente queda entrenado, lo conectamos al WhatsApp, lo probamos contigo y sale a producción.",
  },
  {
    question: "¿Qué información necesitan de mí?",
    answer: "Servicios o productos con precios, horarios, dirección, formas de pago, preguntas frecuentes que ya te hacen los clientes. Si tienes catálogo en PDF o Excel, mejor. Si no, lo armamos juntos en la llamada.",
  },
  {
    question: "¿Y si decido cancelar?",
    answer: "Sin contrato ni permanencia. Te quedas con la información del CRM y los chats históricos. Apagamos el agente y listo.",
  },
];
---

<Layout
  title="Asistente con IA para tu WhatsApp"
  description="Un agente IA que atiende, cotiza, agenda y califica leads en tu WhatsApp 24/7. Incluye CRM y reportes. Desde $150.000 CLP + IVA/mes (500 sesiones)."
  canonicalUrl="https://lelemon.cl/agente-ia"
>
  <!-- JSON-LD: Service -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Agente IA + CRM Lelemon",
    "provider": { "@type": "Organization", "name": "Lelemon", "url": "https://lelemon.cl" },
    "description": "Agente conversacional con IA conectado a WhatsApp Business. Atiende, cotiza, agenda y califica leads 24/7. Incluye panel CRM.",
    "areaServed": { "@type": "Country", "name": "Chile" },
    "offers": {
      "@type": "Offer",
      "price": "150000",
      "priceCurrency": "CLP",
      "priceValidUntil": "2026-12-31"
    }
  })} />

  <ServiceLanding
    whatsappUrl={whatsappUrl}
    eyebrow="Agente IA + CRM · Volver al inicio"
    h1Plain="Un asistente con IA"
    h1Accent="que atiende tu WhatsApp 24/7."
    subtitle="Responde, cotiza, agenda y califica leads. Tú apareces solo para cerrar lo que vale. Lo demás, gestionado solo."
    problemTitle="Cada mensaje sin responder en 5 minutos es un cliente perdido."
    problemBody="La gente compra cuando tiene la duda fresca. Si llegas 2 horas tarde — o peor, al día siguiente — el cliente ya se fue a la competencia. Tú no puedes estar pegado al WhatsApp todo el día. Pero un agente con IA bien entrenado sí. Y atiende exactamente como tú lo harías, con la información de tu negocio."
    featuresEyebrow="Qué incluye"
    featuresTitle="Tu vendedor virtual, operando solo, todo el día."
    features={features}
    tiers={tiers}
    faqs={faqs}
  />
</Layout>
