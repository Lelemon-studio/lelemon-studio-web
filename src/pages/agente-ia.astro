---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import NicheHero from '../components/NicheHero.astro';
import Footer from '../components/Footer.astro';

const whatsappUrl = "https://wa.me/56950467634?text=Hola,%20me%20interesa%20el%20agente%20IA%20de%20Lelemon";

const bullets = [
  "Atiende WhatsApp 24/7 — incluso de madrugada",
  "Cotiza, agenda y filtra al cliente sola",
  "Deja todo ordenado en un panel para ti",
  "Tú apareces solo a cerrar lo que vale",
];

const features = [
  { title: "Entiende tu negocio", body: "Cargamos tus servicios, precios y respuestas frecuentes. Contesta como si fueras tú." },
  { title: "Reportes mensuales", body: "Cuántas conversaciones tuvo, cuántas terminaron en clientes interesados, cuáles agendaron contigo." },
  { title: "Crece contigo", body: "Desde negocios chicos hasta empresas con miles de mensajes al mes. Subes de plan cuando lo necesites." },
  { title: "Sin contrato", body: "Cancelas cuando quieras. Te entregamos toda la base de contactos." },
];

const clients = [
  { name: "Venpu", url: "https://venpu.cl", logo: "/logos/venpu.png" },
  { name: "Te Ayudamos Laboral", url: "https://teayudamoslaboral.cl", logo: "/logos/teayudamoslaboral.svg" },
];

const faqs = [
  { q: "¿Cuántos mensajes incluye?", a: "El plan inicial cubre 500 conversaciones al mes (alcanza cómodo a un negocio chico). Si necesitas más, hay planes con 1.000, 2.000 o a la medida." },
  { q: "¿Qué pasa si me paso del límite?", a: "$200 CLP por conversación extra. Si se vuelve costumbre, conviene subir al plan siguiente." },
  { q: "¿Qué tan rápido se activa?", a: "Entre 5 y 10 días. Te pedimos info de tu negocio, configuramos a la IA y la probamos contigo antes de soltarla." },
  { q: "¿Y si la IA no entiende algo?", a: "La IA pasa la conversación a una persona (tú o quien definas). Tú ves todo en el panel y puedes responder cuando quieras." },
];
---

<Layout
  title="Asistente IA en WhatsApp para PYMES en Chile"
  description="Una IA que atiende tu WhatsApp 24/7, cotiza, agenda y deja todo ordenado en un panel. Pruébala aquí. Desde $150.000 CLP + IVA/mes."
  canonicalUrl="https://lelemon.cl/agente-ia"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Agente IA en WhatsApp Lelemon",
    "provider": { "@type": "Organization", "name": "Lelemon", "url": "https://lelemon.cl" },
    "description": "Asistente IA que atiende WhatsApp 24/7, cotiza, agenda y filtra clientes interesados.",
    "areaServed": { "@type": "Country", "name": "Chile" },
    "offers": { "@type": "Offer", "price": "150000", "priceCurrency": "CLP", "priceValidUntil": "2026-12-31" }
  })} />

  <Navbar whatsappUrl={whatsappUrl} variant="dark" />

  <main>
    <NicheHero
      eyebrow="Agente IA WhatsApp · Chile"
      h1Plain="Tu WhatsApp atendido"
      h1Accent="24/7 con una IA."
      subtitle="Una IA que contesta, cotiza, agenda y deja todo ordenado en un panel para ti."
      bullets={bullets}
      priceFrom="$150.000"
      whatsappUrl={whatsappUrl}
      testimonial={{
        quote: "Dejé de perder ventas por no contestar a tiempo.",
        name: "Nicolás V.",
        role: "Abogado",
        site: "teayudamoslaboral.cl",
      }}
    >
      <div slot="visual" class="relative max-w-[300px] mx-auto">
        <div class="absolute -inset-10 bg-green-500/10 blur-3xl rounded-full" aria-hidden="true"></div>

        <!-- Phone mockup iOS-like (proporción real 9:19.5) -->
        <div class="relative bg-neutral-950 rounded-[2.75rem] p-[10px] shadow-[0_30px_80px_-15px_rgba(0,0,0,0.7)] border border-neutral-800">
          <!-- Side buttons decorativos -->
          <div class="absolute -left-[2px] top-24 w-[2px] h-12 bg-neutral-800 rounded-l"></div>
          <div class="absolute -left-[2px] top-40 w-[2px] h-16 bg-neutral-800 rounded-l"></div>
          <div class="absolute -right-[2px] top-32 w-[2px] h-20 bg-neutral-800 rounded-r"></div>

          <div class="bg-[#ECE5DD] rounded-[2.25rem] overflow-hidden relative">
            <!-- Dynamic island -->
            <div class="absolute top-2 left-1/2 -translate-x-1/2 w-24 h-6 bg-neutral-950 rounded-full z-10"></div>

            <!-- Status bar -->
            <div class="bg-[#075E54] pt-3 pb-1 px-5 flex justify-between items-center text-white text-[10px] font-semibold">
              <span>9:41</span>
              <span class="opacity-0">·</span>
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3" viewBox="0 0 16 11" fill="currentColor"><path d="M0 9h2v2H0V9zm4-2h2v4H4V7zm4-3h2v7H8V4zm4-3h2v10h-2V1z"/></svg>
                <svg class="w-3 h-3" viewBox="0 0 16 11" fill="currentColor"><path d="M8.5 11C12 11 15.5 7.5 15.5 7.5l-1-1S11 10 8 10s-6.5-3.5-6.5-3.5l-1 1S5 11 8.5 11z"/></svg>
                <span class="ml-0.5">100%</span>
              </span>
            </div>

            <!-- Header WSP -->
            <div class="bg-[#075E54] text-white px-4 pt-2 pb-3 flex items-center gap-3 border-b border-black/10">
              <div class="w-8 h-8 rounded-full bg-yellow-400 flex items-center justify-center text-base shrink-0">🍋</div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-sm leading-tight">Tu negocio</p>
                <p class="text-[10px] text-green-300 flex items-center gap-1">
                  <span class="w-1.5 h-1.5 bg-green-400 rounded-full inline-block"></span>
                  IA escribiendo…
                </p>
              </div>
            </div>

            <!-- Mensajes mock con animación staggered -->
            <div class="px-3 py-3 space-y-2 min-h-[380px] mock-chat-msgs">
              <div class="flex justify-end mock-msg" style="--d:0ms">
                <div class="bg-[#DCF8C6] rounded-lg rounded-tr-sm px-3 py-2 max-w-[85%] shadow-sm">
                  <p class="text-[12px] text-neutral-800">Hola, ¿hacen consultas tributarias?</p>
                </div>
              </div>
              <div class="flex justify-start mock-msg" style="--d:600ms">
                <div class="bg-white rounded-lg rounded-tl-sm px-3 py-2 max-w-[85%] shadow-sm">
                  <p class="text-[12px] text-neutral-800">¡Hola! Sí, te atiendo. ¿Es para tu empresa o personal?</p>
                </div>
              </div>
              <div class="flex justify-end mock-msg" style="--d:1400ms">
                <div class="bg-[#DCF8C6] rounded-lg rounded-tr-sm px-3 py-2 max-w-[85%] shadow-sm">
                  <p class="text-[12px] text-neutral-800">Para mi empresa, somos 12 personas</p>
                </div>
              </div>
              <div class="flex justify-start mock-msg" style="--d:2200ms">
                <div class="bg-white rounded-lg rounded-tl-sm px-3 py-2 max-w-[85%] shadow-sm">
                  <p class="text-[12px] text-neutral-800">Perfecto. Te agendo con Camilo el jueves a las 11. ¿Te calza?</p>
                </div>
              </div>
              <div class="flex justify-end mock-msg" style="--d:3000ms">
                <div class="bg-[#DCF8C6] rounded-lg rounded-tr-sm px-3 py-2 max-w-[85%] shadow-sm">
                  <p class="text-[12px] text-neutral-800">Sí, dale 🙌</p>
                </div>
              </div>
            </div>

            <!-- Input bar -->
            <div class="bg-[#F0F0F0] px-3 py-2 flex items-center gap-2">
              <div class="flex-1 bg-white rounded-full h-7 px-3 flex items-center text-[11px] text-neutral-400">Escribe un mensaje</div>
              <div class="w-7 h-7 bg-[#075E54] rounded-full"></div>
            </div>

            <!-- Home indicator iOS -->
            <div class="bg-[#F0F0F0] pt-1 pb-1.5 flex justify-center">
              <div class="w-28 h-1 bg-neutral-950 rounded-full"></div>
            </div>
          </div>
        </div>

        <!-- Notificaciones flotantes -->
        <div class="absolute -top-2 -right-4 sm:-right-8 mock-notif" style="--d:1400ms">
          <div class="bg-white text-neutral-950 rounded-xl px-3 py-2 shadow-[0_10px_30px_-5px_rgba(0,0,0,0.3)] border border-neutral-200 flex items-center gap-2">
            <span class="w-7 h-7 bg-green-500 rounded-full flex items-center justify-center text-white shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            <div>
              <p class="text-[11px] font-bold leading-tight">Lead calificado</p>
              <p class="text-[10px] text-neutral-500">Empresa · 12 personas</p>
            </div>
          </div>
        </div>

        <div class="absolute top-1/3 -left-4 sm:-left-10 mock-notif" style="--d:2200ms">
          <div class="bg-white text-neutral-950 rounded-xl px-3 py-2 shadow-[0_10px_30px_-5px_rgba(0,0,0,0.3)] border border-neutral-200 flex items-center gap-2">
            <span class="w-7 h-7 bg-yellow-400 rounded-full flex items-center justify-center text-neutral-950 shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </span>
            <div>
              <p class="text-[11px] font-bold leading-tight">Reunión agendada</p>
              <p class="text-[10px] text-neutral-500">Jueves · 11:00 AM</p>
            </div>
          </div>
        </div>

        <div class="absolute -bottom-2 -right-4 sm:-right-6 mock-notif" style="--d:3000ms">
          <div class="bg-white text-neutral-950 rounded-xl px-3 py-2 shadow-[0_10px_30px_-5px_rgba(0,0,0,0.3)] border border-neutral-200 flex items-center gap-2">
            <span class="w-7 h-7 bg-green-500 rounded-full flex items-center justify-center text-white shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            <div>
              <p class="text-[11px] font-bold leading-tight">Listo para cerrar</p>
              <p class="text-[10px] text-neutral-500">+1 cliente esperando</p>
            </div>
          </div>
        </div>

        <!-- Badge 24/7 esquina superior -->
        <div class="absolute -top-3 -left-2 sm:-left-3 bg-yellow-400 text-neutral-950 font-black text-xs px-3 py-1.5 rounded-full shadow-lg rotate-[-6deg]">
          24/7 ✨
        </div>
      </div>
    </NicheHero>

    <!-- Logos clientes -->
    <section class="bg-white border-y border-neutral-200 py-10 px-6 sm:px-10">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center gap-8 sm:gap-12">
        <p class="text-[11px] sm:text-xs font-bold uppercase tracking-[0.25em] text-neutral-500 whitespace-nowrap">Ya trabajan con nosotros</p>
        <div class="flex flex-wrap items-center justify-center sm:justify-start gap-x-10 sm:gap-x-14 gap-y-6">
          {clients.map((c) => (
            <a
              href={c.url}
              target="_blank"
              rel="noopener noreferrer"
              class="block opacity-60 hover:opacity-100 transition-opacity"
              title={`Visitar ${c.name}`}
              aria-label={c.name}
            >
              <img src={c.logo} alt={c.name} loading="lazy" class="h-8 sm:h-9 w-auto" />
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Qué incluye (bento oscuro con accent) -->
    <section class="bg-neutral-950 text-white py-16 sm:py-24 px-6 sm:px-10 relative overflow-hidden">
      <div class="absolute inset-0 grid-pattern opacity-[0.03]" aria-hidden="true"></div>
      <div class="absolute top-0 left-1/4 w-[40%] h-[60%] bg-[radial-gradient(ellipse,_rgba(34,197,94,0.08)_0%,_transparent_70%)]" aria-hidden="true"></div>

      <div class="relative max-w-6xl mx-auto">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-px bg-yellow-400"></div>
          <span class="text-[10px] sm:text-xs font-semibold uppercase tracking-[0.3em] text-yellow-400/80">Qué incluye</span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black leading-[1.05] tracking-tight max-w-3xl mb-12 sm:mb-14">
          No solo es una IA cualquiera.<br/>
          <span class="text-yellow-400">Es la voz de tu negocio.</span>
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-6 gap-3 sm:gap-4">
          <!-- Card destacado -->
          <div class="sm:col-span-4 sm:row-span-2 group relative bg-gradient-to-br from-yellow-400 to-yellow-500 text-neutral-950 p-6 sm:p-8 overflow-hidden">
            <div class="absolute -bottom-8 -right-8 text-[12rem] sm:text-[14rem] opacity-10 leading-none select-none pointer-events-none">🍋</div>
            <div class="relative">
              <div class="w-11 h-11 bg-neutral-950 text-yellow-400 flex items-center justify-center mb-5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              </div>
              <h3 class="text-2xl sm:text-3xl font-black tracking-tight mb-3">Entiende tu negocio</h3>
              <p class="text-sm sm:text-base text-neutral-900/85 leading-relaxed max-w-md">Cargamos tus servicios, precios, horarios y respuestas frecuentes. La IA contesta como si fueras tú — con tu tono, tu información, tu manera.</p>
            </div>
          </div>

          <div class="sm:col-span-2 group bg-neutral-900 border border-neutral-800 hover:border-yellow-400/40 p-6 transition-colors">
            <div class="w-10 h-10 bg-yellow-400/10 text-yellow-400 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="font-bold text-base mb-1.5">Atiende 24/7</h3>
            <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">Sin horarios. Si te escriben a las 3 AM, también responde.</p>
          </div>

          <div class="sm:col-span-2 group bg-neutral-900 border border-neutral-800 hover:border-yellow-400/40 p-6 transition-colors">
            <div class="w-10 h-10 bg-yellow-400/10 text-yellow-400 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2a4 4 0 014-4h4M9 5h6a4 4 0 014 4v6"/></svg>
            </div>
            <h3 class="font-bold text-base mb-1.5">Filtra interesados</h3>
            <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">Te llegan los que valen la pena. Los curiosos quedan ordenados igual.</p>
          </div>

          <div class="sm:col-span-2 group bg-neutral-900 border border-neutral-800 hover:border-yellow-400/40 p-6 transition-colors">
            <div class="w-10 h-10 bg-yellow-400/10 text-yellow-400 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="font-bold text-base mb-1.5">Agenda sola</h3>
            <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">Mira tu calendario y confirma reuniones con el cliente.</p>
          </div>

          <div class="sm:col-span-2 group bg-neutral-900 border border-neutral-800 hover:border-yellow-400/40 p-6 transition-colors">
            <div class="w-10 h-10 bg-yellow-400/10 text-yellow-400 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <h3 class="font-bold text-base mb-1.5">Reportes claros</h3>
            <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">Cuántas conversaciones, cuántos clientes interesados, cuántas reuniones.</p>
          </div>

          <div class="sm:col-span-2 group bg-neutral-900 border border-neutral-800 hover:border-yellow-400/40 p-6 transition-colors">
            <div class="w-10 h-10 bg-yellow-400/10 text-yellow-400 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="font-bold text-base mb-1.5">Sin contrato</h3>
            <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">Cancelas cuando quieras. Te entregamos toda la base de contactos.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ corto -->
    <section class="bg-white py-14 sm:py-20 px-6 sm:px-10">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-black text-neutral-950 mb-8">Dudas comunes</h2>
        <div class="space-y-3">
          {faqs.map((f) => (
            <details class="group bg-neutral-50 border border-neutral-200 px-4 py-3.5">
              <summary class="cursor-pointer font-bold text-neutral-950 text-sm sm:text-base flex justify-between items-center gap-3 list-none">
                <span>{f.q}</span>
                <svg class="w-4 h-4 shrink-0 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-neutral-600 mt-3 leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="bg-neutral-950 text-white py-16 px-6 sm:px-10">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl sm:text-4xl font-black tracking-tight">Listo para que la IA atienda por ti.</h2>
        <p class="mt-4 text-neutral-400 text-sm sm:text-base">20 min y sabes si te calza. Sin compromiso.</p>
        <button type="button" data-open-lead-modal class="mt-7 inline-flex items-center gap-3 bg-yellow-400 hover:bg-yellow-300 text-neutral-950 font-bold px-7 py-4 text-sm uppercase tracking-wider transition-all">
          Cuéntame qué vendes
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </button>
      </div>
    </section>

    <Footer />
  </main>
</Layout>

<style is:global>
  .mock-msg {
    opacity: 0;
    transform: translateY(8px) scale(0.97);
    animation: mockFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes mockFadeIn {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .mock-notif {
    opacity: 0;
    transform: scale(0.85) translateY(8px);
    animation: mockNotif 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    animation-delay: var(--d, 0ms);
    z-index: 20;
  }
  @keyframes mockNotif {
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mock-msg, .mock-notif { opacity: 1; transform: none; animation: none; }
  }
</style>
