---
import Layout from '../layouts/Layout.astro';

const founder = {
  name: "Camilo Alaniz",
  role: "Founder & AI Engineer",
  image: "https://res.cloudinary.com/dborlhema/image/upload/v1768233343/Gemini_Generated_Image_xk43skxk43skxk43_xbkzto.png",
  linkedin: "https://www.linkedin.com/in/kmilo93sd",
  bio: [
    "10+ años en tecnología",
    "Ex Nubox - Senior Engineer",
    "Cat lover",
  ],
  badges: [
    { name: "Google for Startups 2026", color: "green" },
    { name: "AWS Activate 2026", color: "orange" },
  ],
};

const stats = [
  { value: "3x", label: "más leads cerrados con seguimiento inteligente" },
  { value: "67%", label: "menos tiempo perdido en leads no calificados" },
  { value: "4.2x", label: "ROI promedio en campañas optimizadas con IA" },
];

const benefits = [
  {
    icon: "users",
    title: "CRM Inteligente",
    description: "Calificación automática de leads con IA. Te dice a quién contactar y cuándo. Pipeline visual y simple.",
    stat: "IA",
    statLabel: "califica por ti",
  },
  {
    icon: "chart",
    title: "Gestión de Ads",
    description: "Manejo y optimización de campañas en Google y Meta. Tracking de conversiones real conectado al CRM.",
    stat: "ROI",
    statLabel: "claro y medible",
  },
  {
    icon: "trending",
    title: "Optimización de Ventas",
    description: "Análisis de embudo completo. Recomendaciones de IA para mejorar conversión. Dashboards en tiempo real.",
    stat: "100%",
    statLabel: "datos en tiempo real",
  },
];

const painPoints = [
  {
    quote: "Se nos escapan leads porque nadie les hizo seguimiento a tiempo",
    pain: "Leads que se pierden",
  },
  {
    quote: "Gastamos en ads pero no sabemos cuáles generan clientes reales",
    pain: "Campañas sin tracking",
  },
  {
    quote: "Implementamos un CRM caro y nadie del equipo lo usa",
    pain: "CRMs complicados",
  },
  {
    quote: "Los datos están en planillas, WhatsApp, email... en todas partes",
    pain: "Datos dispersos",
  },
];

const steps = [
  {
    number: "1",
    title: "Conectamos tus canales",
    description: "Integramos tus campañas de ads, WhatsApp, email y otros canales en un solo lugar. Sin migración compleja.",
    icon: "link",
  },
  {
    number: "2",
    title: "La IA analiza y califica",
    description: "Cada lead es analizado automáticamente. Sabrás quién tiene mayor probabilidad de compra.",
    icon: "bot",
  },
  {
    number: "3",
    title: "Tu equipo cierra más ventas",
    description: "Con mejor información y recomendaciones inteligentes, tu equipo se enfoca en lo que importa.",
    icon: "trophy",
  },
];

const objections = [
  {
    question: "¿Qué tipo de empresas pueden usar Lelemon Studio?",
    answer: "Empresas con equipos comerciales que manejan volumen de leads: inmobiliarias, automotoras, empresas de servicios B2B, educación, seguros y más. Si tu equipo necesita gestionar leads y campañas de ads, Lelemon es para ti.",
  },
  {
    question: "¿Cómo se conecta con mis campañas de ads?",
    answer: "Conectamos directamente con Google Ads, Meta Ads (Facebook e Instagram) y otras plataformas. La integración toma minutos y a partir de ahí trackeas conversiones reales, no solo clics.",
  },
  {
    question: "¿Necesito cambiar mi CRM actual?",
    answer: "Lelemon Studio funciona como un CRM completo, pero también puede integrarse con tu CRM actual si lo prefieres. Te ayudamos en la migración para que la transición sea transparente.",
  },
  {
    question: "¿Cuánto tiempo toma la implementación?",
    answer: "La implementación básica toma entre 1 y 2 semanas. Incluye integración de canales, configuración del CRM, setup de campañas y capacitación de tu equipo.",
  },
];

const whatsappUrl = "https://wa.me/56977066965?text=Hola,%20me%20interesa%20saber%20más%20sobre%20Lelemon%20Studio";
---

<Layout title="Lelemon Studio | Optimiza tus ventas con inteligencia artificial">
  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-[#FAFDF7]/80 backdrop-blur-md border-b border-gray-200/50" id="navbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <a href="/" class="flex items-center group">
          <img src="/logo.svg" alt="Lelemon Studio" class="h-10 transition-transform duration-300 group-hover:scale-105" />
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-[#18181B] bg-[#FACC15] hover:bg-[#EAB308] rounded-xl transition-all duration-200 shadow-[0_4px_14px_-4px_rgba(250,204,21,0.5)] hover:shadow-[0_6px_20px_-4px_rgba(250,204,21,0.6)] hover:-translate-y-0.5"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hablar con ventas
        </a>
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center px-4 sm:px-6 lg:px-8 overflow-hidden pt-20">
      <!-- Background -->
      <div class="absolute inset-0 bg-[#FAFDF7] -z-10">
        <div class="absolute -top-20 -right-20 w-[500px] h-[500px] bg-gradient-to-bl from-[#FACC15]/25 via-[#FEF08A]/15 to-transparent rounded-full blur-3xl animate-blob"></div>
        <div class="absolute -bottom-32 -left-32 w-[400px] h-[400px] bg-gradient-to-tr from-[#FACC15]/20 to-transparent rounded-full blur-3xl animate-blob animation-delay-2000"></div>
        <div class="absolute top-1/2 left-1/3 w-[300px] h-[300px] bg-gradient-to-r from-[#84cc16]/15 to-transparent rounded-full blur-2xl animate-blob animation-delay-4000"></div>
      </div>

      <div class="max-w-7xl mx-auto w-full py-16 lg:py-24">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Left column - Content -->
          <div class="space-y-8">
            <!-- Badge -->
            <div class="animate-fade-in">
              <span class="inline-flex items-center gap-2 bg-[#FACC15]/10 border border-[#FACC15]/30 px-4 py-2 rounded-full">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#FACC15] opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-[#EAB308]"></span>
                </span>
                <span class="text-sm font-medium text-[#A16207]">Para equipos de ventas</span>
              </span>
            </div>

            <!-- Heading -->
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight text-[#18181B] animate-fade-in animation-delay-100">
              Optimiza tus ventas
              <span class="relative inline-block mt-2">
                <span class="text-[#CA8A04]">con inteligencia artificial</span>
                <svg class="absolute -bottom-2 left-0 w-full h-3" viewBox="0 0 300 12" fill="none" preserveAspectRatio="none">
                  <path d="M2 9C50 3 100 3 150 6C200 9 250 5 298 8" stroke="#FACC15" stroke-width="4" stroke-linecap="round" class="animate-draw" />
                </svg>
              </span>
            </h1>

            <!-- Description -->
            <p class="text-lg lg:text-xl text-[#52525B] max-w-xl leading-relaxed animate-fade-in animation-delay-200">
              <strong class="text-[#18181B]">CRM inteligente + gestión de campañas + optimización de ventas.</strong> Todo conectado en un solo entorno.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-4 animate-fade-in animation-delay-300">
              <a
                href={whatsappUrl}
                target="_blank"
                class="group inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-[#18181B] bg-[#FACC15] hover:bg-[#EAB308] rounded-xl transition-all duration-200 shadow-[0_4px_20px_-4px_rgba(250,204,21,0.5)] hover:shadow-[0_8px_30px_-4px_rgba(250,204,21,0.6)] hover:-translate-y-1"
              >
                <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Ver demo en vivo
              </a>
              <a
                href="#problema"
                class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-[#3F3F46] bg-white hover:bg-gray-50 border border-gray-200 hover:border-gray-300 rounded-xl transition-all duration-200 shadow-sm hover:shadow-md group"
              >
                Cómo funciona
                <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>

            <!-- Trust indicators -->
            <div class="flex items-center gap-6 pt-4 animate-fade-in animation-delay-400">
              <div class="flex items-center gap-2 text-sm text-[#71717A]">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Implementación en 2 semanas
              </div>
              <div class="flex items-center gap-2 text-sm text-[#71717A]">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Sin cambiar tus herramientas
              </div>
            </div>
          </div>

          <!-- Right column - Dashboard Visual -->
          <div class="relative hidden lg:block">
            <div class="relative">
              <div class="relative mx-auto w-full max-w-[480px] animate-fade-in animation-delay-300">
                <!-- Browser frame -->
                <div class="relative bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden">
                  <!-- Browser chrome -->
                  <div class="bg-gray-100 border-b border-gray-200 px-4 py-3 flex items-center gap-3">
                    <div class="flex gap-1.5">
                      <div class="w-3 h-3 rounded-full bg-red-400"></div>
                      <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                      <div class="w-3 h-3 rounded-full bg-green-400"></div>
                    </div>
                    <div class="flex-1 bg-white rounded-md px-3 py-1.5 text-xs text-gray-400 border border-gray-200 font-mono">
                      dashboard.lelemon.studio
                    </div>
                  </div>

                  <!-- Dashboard content -->
                  <div class="bg-[#FAFDF7] p-5 space-y-4">
                    <!-- Stat cards -->
                    <div class="grid grid-cols-3 gap-3">
                      <div class="bg-white rounded-xl p-3 border border-gray-100 shadow-sm">
                        <p class="text-xs text-gray-500 mb-1">Leads hoy</p>
                        <p class="text-2xl font-bold text-[#18181B]">127</p>
                        <p class="text-xs text-green-600 font-medium mt-0.5">+23%</p>
                      </div>
                      <div class="bg-white rounded-xl p-3 border border-gray-100 shadow-sm">
                        <p class="text-xs text-gray-500 mb-1">Tasa de cierre</p>
                        <p class="text-2xl font-bold text-[#18181B]">34%</p>
                        <p class="text-xs text-green-600 font-medium mt-0.5">+8%</p>
                      </div>
                      <div class="bg-white rounded-xl p-3 border border-gray-100 shadow-sm">
                        <p class="text-xs text-gray-500 mb-1">ROI campañas</p>
                        <p class="text-2xl font-bold text-[#CA8A04]">4.2x</p>
                        <p class="text-xs text-green-600 font-medium mt-0.5">este mes</p>
                      </div>
                    </div>

                    <!-- Pipeline chart -->
                    <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm">
                      <p class="text-xs font-semibold text-gray-600 mb-3">Pipeline de ventas</p>
                      <div class="space-y-2.5">
                        <div class="flex items-center gap-3">
                          <span class="text-xs text-gray-500 w-20 text-right shrink-0">Nuevos</span>
                          <div class="flex-1 bg-gray-100 rounded-full h-5 relative overflow-hidden">
                            <div class="absolute inset-y-0 left-0 bg-blue-400 rounded-full" style="width: 85%"></div>
                            <span class="absolute inset-0 flex items-center justify-end pr-2 text-xs font-semibold text-white">42</span>
                          </div>
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="text-xs text-gray-500 w-20 text-right shrink-0">Contactados</span>
                          <div class="flex-1 bg-gray-100 rounded-full h-5 relative overflow-hidden">
                            <div class="absolute inset-y-0 left-0 bg-yellow-400 rounded-full" style="width: 62%"></div>
                            <span class="absolute inset-0 flex items-center justify-end pr-2 text-xs font-semibold text-gray-700">31</span>
                          </div>
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="text-xs text-gray-500 w-20 text-right shrink-0">Propuesta</span>
                          <div class="flex-1 bg-gray-100 rounded-full h-5 relative overflow-hidden">
                            <div class="absolute inset-y-0 left-0 bg-amber-500 rounded-full" style="width: 36%"></div>
                            <span class="absolute inset-0 flex items-center justify-end pr-2 text-xs font-semibold text-white">18</span>
                          </div>
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="text-xs text-gray-500 w-20 text-right shrink-0">Cerrados</span>
                          <div class="flex-1 bg-gray-100 rounded-full h-5 relative overflow-hidden">
                            <div class="absolute inset-y-0 left-0 bg-green-500 rounded-full" style="width: 18%"></div>
                            <span class="absolute inset-0 flex items-center justify-end pr-2 text-xs font-semibold text-white">9</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Floating badges -->
                <div class="absolute -left-52 top-8 bg-white rounded-xl shadow-lg px-4 py-3 animate-float">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                      <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                    </div>
                    <span class="text-sm font-medium text-gray-700">Lead calificado</span>
                  </div>
                </div>
                <div class="absolute -right-48 top-20 bg-white rounded-xl shadow-lg px-4 py-3 animate-float animation-delay-1000">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center">
                      <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                      </svg>
                    </div>
                    <span class="text-sm font-medium text-gray-700">Campaña optimizada</span>
                  </div>
                </div>
                <div class="absolute -left-44 bottom-20 bg-white rounded-xl shadow-lg px-4 py-3 animate-float animation-delay-2000">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                      <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                    <span class="text-sm font-medium text-gray-700">Venta cerrada</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce hidden lg:block">
        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-12 px-4 sm:px-6 lg:px-8 bg-white border-y border-gray-100">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          {stats.map((stat, index) => (
            <div class="text-center animate-on-scroll" style={`--delay: ${index * 100}ms`}>
              <div class="text-4xl lg:text-5xl font-bold text-[#CA8A04] mb-2">{stat.value}</div>
              <p class="text-gray-600 text-sm lg:text-base">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section id="problema" class="py-24 px-4 sm:px-6 lg:px-8 bg-[#FAFDF7]">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <span class="inline-flex items-center gap-2 bg-red-50 border border-red-100 px-4 py-1.5 rounded-full mb-4">
            <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
            <span class="text-sm font-medium text-red-700">El problema</span>
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#18181B] mb-6">
            ¿Te suena familiar?
          </h2>
          <p class="text-lg text-[#52525B] max-w-2xl mx-auto">
            Esto le pasa a la mayoría de los equipos comerciales todos los días
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {painPoints.map((point, index) => (
            <div
              class="group bg-white border border-gray-100 rounded-2xl p-6 hover:border-red-200 hover:shadow-lg transition-all duration-300 animate-on-scroll"
              style={`--delay: ${index * 100}ms`}
            >
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-red-50 rounded-xl flex items-center justify-center group-hover:bg-red-100 transition-colors">
                  <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-[#18181B] font-medium italic mb-2">"{point.quote}"</p>
                  <span class="text-sm text-red-600 font-medium">{point.pain}</span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-12">
          <p class="text-xl font-medium text-[#18181B]">
            Cada lead sin seguimiento,
            <span class="text-red-600">es una venta que se pierde para siempre</span>.
          </p>
        </div>
      </div>
    </section>

    <!-- Solution Section -->
    <section class="py-24 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <span class="inline-flex items-center gap-2 bg-green-50 border border-green-100 px-4 py-1.5 rounded-full mb-4">
            <span class="w-2 h-2 bg-green-500 rounded-full"></span>
            <span class="text-sm font-medium text-green-700">La solución</span>
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#18181B] mb-6">
