---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import SectionProblem from '../components/SectionProblem.astro';
import SectionSolution from '../components/SectionSolution.astro';
import BannerBreak from '../components/BannerBreak.astro';
import SectionPricing from '../components/SectionPricing.astro';
import SectionFaq from '../components/SectionFaq.astro';
import SectionForm from '../components/SectionForm.astro';
import SectionTeam from '../components/SectionTeam.astro';
import SectionUseCases from '../components/SectionUseCases.astro';
import SectionResult from '../components/SectionResult.astro';
import SectionCta from '../components/SectionCta.astro';
import Footer from '../components/Footer.astro';

const rubros = ["Agendamiento", "Ventas", "Soporte", "Calificación", "Recordatorios", "Tu negocio"];

const included = [
  "Tu web profesional con dominio, correos, hosting y SSL incluidos",
  "Asistente con IA en WhatsApp con número dedicado — responde, agenda y califica 24/7",
  "Calificación automática: los clientes calientes te llegan a ti, del resto se hace cargo el asistente",
  "Panel donde ves cada conversación, cada cliente, cada oportunidad",
  "Anuncios en Instagram y Facebook — los armamos, lanzamos, optimizamos y gestionamos por ti",
  "Reportes claros cada mes: sabes exactamente qué funciona y qué no",
  "Soporte directo cuando lo necesites, sin tickets ni esperas",
];

const faqs = [
  { question: "¿Cuánto se demoran?", answer: "1 a 3 semanas. El asistente inteligente se activa en días. La web toma un poco más dependiendo del rubro. Las campañas se lanzan apenas la web esté arriba." },
  { question: "¿Se nota que es un bot?", answer: "No. Las respuestas son naturales y están entrenadas con la info de tu negocio. Y cuando el cliente necesita hablar contigo, te traspasa la conversación. Tú decides cuándo tomar el control." },
  { question: "¿Yo tengo que escribir los textos de la web?", answer: "No. Nosotros hacemos todo. Necesitamos 20 minutos de tu tiempo en una llamada para entender qué haces, a quién atiendes y qué te diferencia. Con eso armamos todo." },
  { question: "¿Qué pasa con el WhatsApp?", answer: "Nosotros te entregamos un número dedicado para tu negocio. Es tuyo, seguro, y separado de tu WhatsApp personal. El asistente responde ahí y tú puedes meterte a cualquier conversación cuando quieras." },
  { question: "¿Puedo ver las conversaciones de mis clientes?", answer: "Sí. Tienes acceso completo al panel. Ves cada conversación, quién escribió, qué necesita y en qué estado está. Puedes entrar a cualquier chat y tomar el control en cualquier momento." },
  { question: "¿Necesito saber de tecnología?", answer: "Cero. Nosotros configuramos todo. Tú solo necesitas tu teléfono y 20 minutos para contarnos sobre tu negocio. El resto lo hacemos nosotros." },
  { question: "¿Las campañas de publicidad están incluidas?", answer: "Nosotros configuramos, optimizamos y gestionamos las campañas en Instagram y Facebook. Los creativos (imágenes, videos) los pone el cliente. Si necesitas trabajo de agencia creativa, eso se cotiza por separado. El presupuesto publicitario se paga directo en Instagram y Facebook, y tú decides cuánto invertir." },
  { question: "¿Puedo cancelar cuando quiera?", answer: "Sí. Sin contrato, sin permanencia mínima, sin multas. Si un mes decides que no lo necesitas, cancelas y listo." },
  { question: "¿Y si no me sirve?", answer: "Los primeros 3 meses pagas $299 USD/mes (en vez de $499). Sin contrato ni permanencia. Si no te sirve, cancelas cuando quieras. Sin letra chica." },
  { question: "¿Cuántos clientes nuevos voy a recibir?", answer: "Depende de tu rubro, tu zona y cuánto inviertas en publicidad. Lo que sí te garantizamos: vas a responder el 100% de las consultas, 24/7, en menos de 1 minuto. Eso solo ya cambia todo." },
];

const founder = {
  name: "Camilo Alaniz",
  role: "Founder",
  image: "https://res.cloudinary.com/dborlhema/image/upload/v1768233343/Gemini_Generated_Image_xk43skxk43skxk43_xbkzto.png",
  linkedin: "https://www.linkedin.com/in/kmilo93sd",
  badges: ["Google for Startups 2026", "AWS Activate 2026"],
};

const whatsappUrl = "https://wa.me/56977066965?text=Hola,%20me%20interesa%20saber%20m%C3%A1s%20sobre%20Lelemon";
---

<Layout title="Marketing operado con IA para pymes en Chile | Lelemon" description="Armamos tu web, ponemos un asistente con IA en tu WhatsApp y gestionamos tus anuncios en Instagram y Facebook. Tu negocio atrae y atiende clientes 24/7. Desde $299 USD/mes.">
  <!-- JSON-LD: WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Lelemon",
    "alternateName": "Lelemon Studio",
    "url": "https://lelemon.cl",
    "inLanguage": "es-CL",
    "publisher": {
      "@type": "Organization",
      "name": "Lelemon",
      "logo": "https://lelemon.cl/logo.svg"
    }
  })} />

  <!-- JSON-LD: ProfessionalService + LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Lelemon",
    "description": "Marketing operado con IA para pymes en Chile. Armamos tu web, ponemos un asistente con IA en tu WhatsApp y gestionamos tus anuncios en Instagram y Facebook.",
    "url": "https://lelemon.cl",
    "logo": "https://lelemon.cl/logo.svg",
    "image": "https://lelemon.cl/og.png",
    "email": "contacto@lelemon.cl",
    "telephone": "+56977066965",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Santiago",
      "addressRegion": "Región Metropolitana",
      "addressCountry": "CL"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -33.4489,
      "longitude": -70.6693
    },
    "areaServed": {
      "@type": "Country",
      "name": "Chile"
    },
    "priceRange": "Desde $299 USD/mes",
    "sameAs": [
      "https://www.linkedin.com/in/kmilo93sd"
    ],
    "founder": {
      "@type": "Person",
      "name": "Camilo Alaniz",
      "jobTitle": "Founder",
      "url": "https://www.linkedin.com/in/kmilo93sd"
    },
    "offers": {
      "@type": "Offer",
      "name": "Paquete Lelemon",
      "description": "Web + Asistente con IA + Anuncios gestionados + CRM + Reportes mensuales",
      "price": "499",
      "priceCurrency": "USD",
      "priceValidUntil": "2026-12-31"
    }
  })} />

  <!-- JSON-LD: FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  })} />

  <!-- Grain texture overlay -->
  <div class="grain-overlay" aria-hidden="true"></div>

  <Navbar whatsappUrl={whatsappUrl} />

  <main>
    <Hero whatsappUrl={whatsappUrl} rubros={rubros} />
    <SectionProblem />
    <SectionSolution whatsappUrl={whatsappUrl} />
    <SectionUseCases whatsappUrl={whatsappUrl} />
    <SectionResult whatsappUrl={whatsappUrl} />
    <BannerBreak whatsappUrl={whatsappUrl} />
    <SectionPricing whatsappUrl={whatsappUrl} included={included} />
    <SectionForm whatsappUrl={whatsappUrl} />
    <SectionFaq faqs={faqs} whatsappUrl={whatsappUrl} />
    <SectionTeam founder={founder} />
    <SectionCta whatsappUrl={whatsappUrl} />
    <Footer />
  </main>

  <!-- Custom cursor lemon -->
  <div id="custom-cursor" class="fixed pointer-events-none z-[9999] hidden lg:block text-2xl leading-none" aria-hidden="true">🍋</div>
</Layout>

<style is:global>
  /* ============ GRAIN TEXTURE ============ */
  .grain-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    pointer-events: none;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }

  /* ============ GRID PATTERN ============ */
  .grid-pattern {
    background-image:
      linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* ============ DIAGONAL LINES ============ */
  .diagonal-lines {
    background-image: repeating-linear-gradient(
      -45deg, transparent, transparent 10px,
      rgba(0,0,0,0.12) 10px, rgba(0,0,0,0.12) 11px
    );
  }
  .diagonal-lines-dark {
    background-image: repeating-linear-gradient(
      -45deg, transparent, transparent 10px,
      rgba(0,0,0,0.25) 10px, rgba(0,0,0,0.25) 11px
    );
  }

  /* ============ TEXT EFFECTS ============ */
  .text-stroke-yellow {
    -webkit-text-stroke: 2px #FACC15;
    color: transparent;
  }
  .text-stroke-white {
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.3);
    color: transparent;
  }

  /* ============ SCROLL REVEAL ============ */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--d, 0ms);
  }
  .scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ============ CLIP-PATH REVEAL ============ */
  .clip-reveal {
    clip-path: inset(100% 0 0 0);
    transition: clip-path 0.8s cubic-bezier(0.77, 0, 0.175, 1);
  }
  .clip-reveal.visible {
    clip-path: inset(0 0 0 0);
  }

  /* ============ CUSTOM CURSOR ============ */
  #custom-cursor {
    transition: transform 0.3s cubic-bezier(0.23,1,0.32,1);
    transform: translate(-50%, 50%);
    will-change: left, top;
  }
  #custom-cursor.cursor-hover {
    transform: translate(-50%, 50%) scale(1.6);
  }

  /* ============ SMOOTH SCROLL ============ */
  html { scroll-behavior: smooth; }
</style>

<script>
  // ============ Scroll reveal (with IntersectionObserver) ============
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        revealObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.scroll-reveal, .clip-reveal').forEach(el => revealObs.observe(el));

  // ============ Counter animation ============
  const counterObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const duration = 1500;
      const startTime = performance.now();
      function tick(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = String(Math.round(eased * target));
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
      counterObs.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.counter-num').forEach(el => counterObs.observe(el));

  // ============ Chat typing animation ============
  const chatDemo = document.getElementById('chat-demo');
  const chatMsgs = chatDemo?.querySelectorAll('.chat-msg') || [];
  const chatObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      chatMsgs.forEach((msg, i) => {
        setTimeout(() => msg.classList.add('chat-visible'), i * 500);
      });
      chatObs.unobserve(e.target);
    });
  }, { threshold: 0.3 });
  if (chatDemo) chatObs.observe(chatDemo);

  // ============ Custom cursor (mix-blend-mode difference) ============
  const cursor = document.getElementById('custom-cursor');
  if (cursor && window.matchMedia('(pointer: fine)').matches) {
    let cx = 0, cy = 0, tx = 0, ty = 0;

    document.addEventListener('mousemove', (e) => {
      tx = e.clientX;
      ty = e.clientY;
    });

    function animateCursor() {
      cx += (tx - cx) * 0.15;
      cy += (ty - cy) * 0.15;
      cursor.style.left = cx + 'px';
      cursor.style.top = cy + 'px';
      requestAnimationFrame(animateCursor);
    }
    animateCursor();

    document.querySelectorAll('a, button, summary, [data-magnetic]').forEach(el => {
      el.addEventListener('mouseenter', () => cursor.classList.add('cursor-hover'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('cursor-hover'));
    });
  }

  // ============ Spotlight glow on solution cards ============
  document.querySelectorAll('[data-spotlight]').forEach(card => {
    const el = card as HTMLElement;
    el.addEventListener('mousemove', (e) => {
      const rect = el.getBoundingClientRect();
      el.style.setProperty('--mx', `${e.clientX - rect.left}px`);
      el.style.setProperty('--my', `${e.clientY - rect.top}px`);
    });
  });

  // ============ UTM params: read from URL and append to WhatsApp links ============
  const params = new URLSearchParams(window.location.search);
  const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content'];
  const utmParts = utmKeys.map(k => params.get(k) ? `${k}=${params.get(k)}` : '').filter(Boolean);

  if (utmParts.length > 0) {
    const utmSuffix = encodeURIComponent(`\n[${utmParts.join('&')}]`);
    document.querySelectorAll<HTMLAnchorElement>('[data-wa-cta]').forEach(a => {
      const url = new URL(a.href);
      const currentText = url.searchParams.get('text') || '';
      url.searchParams.set('text', currentText + decodeURIComponent(utmSuffix));
      a.href = url.toString();
    });
  }

  // ============ WhatsApp click tracking: Meta Pixel + GA4 ============
  document.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('[data-wa-cta]');
    if (!link) return;

    const section = link.closest('section')?.id || link.closest('nav')?.tagName || 'unknown';

    // Meta Pixel
    if (typeof window.fbq === 'function') {
      window.fbq('track', 'Lead', { content_name: 'whatsapp_click', content_category: section });
    }
    // GA4
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'generate_lead', { event_category: 'whatsapp', event_label: section });
    }
  });

  // ============ Lead form submit ============
  const leadForm = document.getElementById('lead-form') as HTMLFormElement | null;
  const formFeedback = document.getElementById('form-feedback');

  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = leadForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    const data = new FormData(leadForm);
    const name = data.get('name') as string;
    const email = data.get('email') as string;
    const phone = data.get('phone') as string;

    // Basic validation
    if (!name?.trim() || !email?.trim()) {
      showFeedback('Por favor completa nombre y email.', false);
      btn.disabled = false;
      btn.textContent = 'Quiero mi llamada gratuita';
      return;
    }

    // Fire tracking events
    if (typeof window.fbq === 'function') {
      window.fbq('track', 'Lead', { content_name: 'form_submit' });
    }
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'generate_lead', { event_category: 'form', event_label: 'lead_form' });
    }

    // Build WhatsApp message with lead info
    const utmTag = utmParts.length > 0 ? `\n[${utmParts.join('&')}]` : '';
    const msg = `Hola, soy ${name.trim()}. Quiero agendar una llamada.\nEmail: ${email.trim()}${phone ? `\nTel: ${phone.trim()}` : ''}${utmTag}`;
    const waUrl = `https://wa.me/56977066965?text=${encodeURIComponent(msg)}`;

    showFeedback('Redirigiendo a WhatsApp...', true);
    setTimeout(() => window.open(waUrl, '_blank'), 400);

    btn.disabled = false;
    btn.textContent = 'Quiero mi llamada gratuita';
  });

  function showFeedback(msg: string, success: boolean) {
    if (!formFeedback) return;
    formFeedback.textContent = msg;
    formFeedback.className = `text-sm text-center mt-2 ${success ? 'text-green-400' : 'text-red-400'}`;
  }
</script>
