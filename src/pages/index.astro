---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import SectionServices from '../components/SectionServices.astro';
import BannerBreak from '../components/BannerBreak.astro';
import SectionPack from '../components/SectionPack.astro';
import SectionFaq from '../components/SectionFaq.astro';
import SectionCta from '../components/SectionCta.astro';
import Footer from '../components/Footer.astro';

const rubros = ["Agendamiento", "Ventas", "Soporte", "Calificación", "Recordatorios", "Tu negocio"];

const faqs = [
  { question: "¿Cuánto se demoran en montar todo?", answer: "1 a 3 semanas. El agente IA se activa en 5 a 10 días. La web toma un poco más dependiendo del rubro. Las campañas se lanzan apenas la web esté arriba." },
  { question: "¿Puedo contratar solo una parte (solo web, solo IA o solo ads)?", answer: "Sí. Cada servicio se vende por separado y tiene su propia página: /web, /agente-ia, /marketing. Si terminas necesitando los tres, el pack completo te sale 30% más barato que sumarlos sueltos." },
  { question: "¿Cuántas conversaciones del asistente IA incluye?", answer: "Depende del tier que elijas. El Pro (1.000 sesiones/mes, incluido en el pack completo) cubre cómodo a una clínica con 300-500 consultas o una tienda con 1.000 mensajes. Si esperas más volumen, ajustamos. Detalle de los 4 tiers en /agente-ia." },
  { question: "¿El presupuesto publicitario está incluido?", answer: "No. El ad-spend de Meta se paga directo en Instagram y Facebook, no a nosotros. Tú decides cuánto invertir — recomendamos partir desde $200.000/mes para que el algoritmo aprenda. Nosotros operamos las campañas; tú pones el presupuesto y los creativos." },
  { question: "¿Puedo cancelar cuando quiera?", answer: "Sí. Sin contrato, sin permanencia, sin multas. Cancelas y te entregamos los activos: dominio, contenidos, base de leads del CRM. Te quedas con todo." },
  { question: "¿Necesito saber de tecnología?", answer: "Cero. Nosotros configuramos todo. Tú solo necesitas 20 minutos en una llamada para contarnos del negocio. El resto lo hacemos nosotros." },
  { question: "¿Cuántos clientes nuevos voy a recibir?", answer: "Depende de tu rubro, tu zona y cuánto inviertas en ads. Lo que sí garantizamos: respondes el 100% de las consultas, 24/7, en menos de 1 minuto. Eso solo cambia todo." },
];

const whatsappUrl = "https://wa.me/56950467634?text=Hola,%20me%20interesa%20saber%20m%C3%A1s%20sobre%20Lelemon";
---

<Layout title="Más ventas para tu negocio cada mes | Lelemon" description="Web profesional, agente IA en WhatsApp y campañas en Meta — montados, conectados y operados por nosotros. Servicios independientes desde $100.000 CLP/mes o pack completo (Sistema vendedor) por $350.000/mes con 30% de ahorro.">
  <!-- JSON-LD: WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Lelemon",
    "alternateName": "Lelemon Studio",
    "url": "https://lelemon.cl",
    "inLanguage": "es-CL",
    "publisher": {
      "@type": "Organization",
      "name": "Lelemon",
      "logo": "https://lelemon.cl/logo.svg"
    }
  })} />

  <!-- JSON-LD: ProfessionalService + LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Lelemon",
    "description": "Más ventas para tu negocio cada mes. Web profesional, agente IA en WhatsApp y campañas operadas en Meta. Servicios independientes o pack completo (Sistema vendedor) con 30% de ahorro.",
    "url": "https://lelemon.cl",
    "logo": "https://lelemon.cl/logo.svg",
    "image": "https://lelemon.cl/og.png",
    "email": "contacto@lelemon.cl",
    "telephone": "+56950467634",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Santiago",
      "addressRegion": "Región Metropolitana",
      "addressCountry": "CL"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -33.4489,
      "longitude": -70.6693
    },
    "areaServed": {
      "@type": "Country",
      "name": "Chile"
    },
    "priceRange": "Desde $100.000 CLP + IVA/mes (servicios sueltos) · $350.000 pack completo",
    "sameAs": [
      "https://www.linkedin.com/in/kmilo93sd"
    ],
    "founder": {
      "@type": "Person",
      "name": "Camilo Alaniz",
      "jobTitle": "Founder",
      "url": "https://www.linkedin.com/in/kmilo93sd"
    },
    "offers": {
      "@type": "Offer",
      "name": "Paquete Lelemon",
      "description": "Web + Asistente con IA + Anuncios gestionados + CRM + Reportes mensuales",
      "price": "350000",
      "priceCurrency": "CLP",
      "priceValidUntil": "2026-12-31"
    }
  })} />

  <!-- JSON-LD: FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  })} />

  <!-- Grain texture overlay -->
  <div class="grain-overlay" aria-hidden="true"></div>

  <Navbar whatsappUrl={whatsappUrl} />

  <main>
    <Hero whatsappUrl={whatsappUrl} rubros={rubros} />
    <MarqueeStrip />
    <SectionServices />
    <BannerBreak whatsappUrl={whatsappUrl} />
    <SectionPack />
    <SectionFaq faqs={faqs} whatsappUrl={whatsappUrl} />
    <SectionCta whatsappUrl={whatsappUrl} />
    <Footer />
  </main>

  <!-- Custom cursor lemon -->
  <div id="custom-cursor" class="fixed pointer-events-none z-[9999] hidden lg:block text-2xl leading-none" aria-hidden="true">🍋</div>
</Layout>

<style is:global>
  /* ============ GRAIN TEXTURE (desktop only — mobile lo oculta por performance) ============ */
  .grain-overlay {
    display: none;
  }
  @media (min-width: 1024px) {
    .grain-overlay {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 9998;
      pointer-events: none;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 256px 256px;
    }
  }

  /* ============ GRID PATTERN ============ */
  .grid-pattern {
    background-image:
      linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* ============ DIAGONAL LINES ============ */
  .diagonal-lines {
    background-image: repeating-linear-gradient(
      -45deg, transparent, transparent 10px,
      rgba(0,0,0,0.12) 10px, rgba(0,0,0,0.12) 11px
    );
  }
  .diagonal-lines-dark {
    background-image: repeating-linear-gradient(
      -45deg, transparent, transparent 10px,
      rgba(0,0,0,0.25) 10px, rgba(0,0,0,0.25) 11px
    );
  }

  /* ============ TEXT EFFECTS ============ */
  .text-stroke-yellow {
    -webkit-text-stroke: 2px #FACC15;
    color: transparent;
  }
  .text-stroke-white {
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.3);
    color: transparent;
  }

  /* ============ SCROLL REVEAL ============
     Gate por html.js-anim: si no hay JS, todo visible (mejor SI + accesible).
     El JS hoisted aplica .js-anim al <html> en cuanto carga. */
  html.js-anim .scroll-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--d, 0ms);
  }
  html.js-anim .scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ============ CLIP-PATH REVEAL ============ */
  html.js-anim .clip-reveal {
    clip-path: inset(100% 0 0 0);
    transition: clip-path 0.8s cubic-bezier(0.77, 0, 0.175, 1);
  }
  html.js-anim .clip-reveal.visible {
    clip-path: inset(0 0 0 0);
  }

  @media (prefers-reduced-motion: reduce) {
    html.js-anim .scroll-reveal,
    html.js-anim .clip-reveal { opacity: 1; transform: none; clip-path: none; transition: none; }
  }

  /* ============ CUSTOM CURSOR ============ */
  #custom-cursor {
    transition: transform 0.3s cubic-bezier(0.23,1,0.32,1);
    transform: translate(-50%, 50%);
    will-change: left, top;
  }
  #custom-cursor.cursor-hover {
    transform: translate(-50%, 50%) scale(1.6);
  }

  /* ============ SMOOTH SCROLL ============ */
  html { scroll-behavior: smooth; }
</style>

<script>
  // Activar animaciones gateadas por CSS (.js-anim).
  // Si JS no corre, contenido visible — Speed Index no se penaliza.
  document.documentElement.classList.add('js-anim');

  // ============ Scroll reveal (with IntersectionObserver) ============
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        revealObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.scroll-reveal, .clip-reveal').forEach(el => revealObs.observe(el));

  // ============ Counter animation ============
  const counterObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const duration = 1500;
      const startTime = performance.now();
      function tick(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = String(Math.round(eased * target));
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
      counterObs.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.counter-num').forEach(el => counterObs.observe(el));

  // ============ Chat typing animation ============
  const chatDemo = document.getElementById('chat-demo');
  const chatMsgs = chatDemo?.querySelectorAll('.chat-msg') || [];
  const chatObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      chatMsgs.forEach((msg, i) => {
        setTimeout(() => msg.classList.add('chat-visible'), i * 500);
      });
      chatObs.unobserve(e.target);
    });
  }, { threshold: 0.3 });
  if (chatDemo) chatObs.observe(chatDemo);

  // ============ Custom cursor (mix-blend-mode difference) ============
  const cursor = document.getElementById('custom-cursor');
  if (cursor && window.matchMedia('(pointer: fine)').matches) {
    let cx = 0, cy = 0, tx = 0, ty = 0;

    document.addEventListener('mousemove', (e) => {
      tx = e.clientX;
      ty = e.clientY;
    });

    function animateCursor() {
      cx += (tx - cx) * 0.15;
      cy += (ty - cy) * 0.15;
      cursor.style.left = cx + 'px';
      cursor.style.top = cy + 'px';
      requestAnimationFrame(animateCursor);
    }
    animateCursor();

    document.querySelectorAll('a, button, summary, [data-magnetic]').forEach(el => {
      el.addEventListener('mouseenter', () => cursor.classList.add('cursor-hover'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('cursor-hover'));
    });
  }

  // ============ Spotlight glow on solution cards ============
  document.querySelectorAll('[data-spotlight]').forEach(card => {
    const el = card as HTMLElement;
    el.addEventListener('mousemove', (e) => {
      const rect = el.getBoundingClientRect();
      el.style.setProperty('--mx', `${e.clientX - rect.left}px`);
      el.style.setProperty('--my', `${e.clientY - rect.top}px`);
    });
  });

  // CTA tracking ([data-wa-cta]) está delegado en /scripts/init.js

</script>
