---
import Layout from '../layouts/Layout.astro';

const whatsappUrl = 'https://wa.me/56977066965?text=Hola%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20Lelemon%20Studio';
---

<Layout title="Lelemon Studio — Optimiza tus ventas con IA">

  <!-- ========== NAVBAR ========== -->
  <nav class="fixed top-0 inset-x-0 z-50 bg-surface/80 backdrop-blur-lg border-b border-dark/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <div class="w-9 h-9 rounded-lg bg-lemon-300 flex items-center justify-center">
          <span class="text-dark font-extrabold text-lg">L</span>
        </div>
        <span class="font-bold text-xl text-dark">Lelemon <span class="font-medium text-dark/60">Studio</span></span>
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-lemon-300 hover:bg-lemon-400 text-dark font-semibold text-sm px-5 py-2.5 rounded-full transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Hablar con ventas
      </a>
    </div>
  </nav>

  <!-- ========== HERO ========== -->
  <section class="pt-32 pb-20 sm:pt-40 sm:pb-28 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-lemon-300/10 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <!-- Trust badges -->
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <span class="inline-flex items-center gap-1.5 bg-white border border-dark/10 text-dark/70 text-xs font-medium px-3 py-1.5 rounded-full">
          <svg class="w-3.5 h-3.5 text-lemon-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
          Google for Startups 2026
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white border border-dark/10 text-dark/70 text-xs font-medium px-3 py-1.5 rounded-full">
          <svg class="w-3.5 h-3.5 text-lemon-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
          AWS Activate 2026
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-dark leading-[1.1] mb-6">
        Tu equipo de ventas,
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-lemon-500 via-lemon-400 to-lemon-300">potenciado con IA</span>
      </h1>

      <p class="text-lg sm:text-xl text-dark/60 max-w-2xl mx-auto mb-10 leading-relaxed">
        CRM inteligente + gestión de campañas + optimización de ventas. Todo conectado en un solo entorno para que tu equipo cierre más.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-lemon-300 hover:bg-lemon-400 text-dark font-semibold px-8 py-3.5 rounded-full transition-colors text-base shadow-lg shadow-lemon-300/25"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Agendar demo
        </a>
        <a
          href="#como-funciona"
          class="inline-flex items-center gap-2 text-dark/70 hover:text-dark font-medium px-6 py-3.5 rounded-full border border-dark/10 hover:border-dark/20 transition-colors text-base"
        >
          Como funciona
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>

      <!-- Dashboard mockup -->
      <div class="mt-16 relative">
        <div class="bg-white rounded-2xl shadow-2xl shadow-dark/5 border border-dark/5 p-6 sm:p-8">
          <div class="flex items-center gap-2 mb-6">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
            <span class="ml-3 text-xs text-dark/40 font-mono">dashboard.lelemon.studio</span>
          </div>
          <div class="grid grid-cols-3 gap-4 mb-4">
            <div class="bg-surface rounded-xl p-4 text-left">
              <p class="text-xs text-dark/50 mb-1">Leads hoy</p>
              <p class="text-2xl font-bold text-dark">127</p>
              <p class="text-xs text-green-600 font-medium mt-1">+23% vs ayer</p>
            </div>
            <div class="bg-surface rounded-xl p-4 text-left">
              <p class="text-xs text-dark/50 mb-1">Tasa de cierre</p>
              <p class="text-2xl font-bold text-dark">34%</p>
              <p class="text-xs text-green-600 font-medium mt-1">+8% este mes</p>
            </div>
            <div class="bg-surface rounded-xl p-4 text-left">
              <p class="text-xs text-dark/50 mb-1">ROI campañas</p>
              <p class="text-2xl font-bold text-dark">4.2x</p>
              <p class="text-xs text-green-600 font-medium mt-1">+1.1x vs anterior</p>
            </div>
          </div>
          <div class="bg-surface rounded-xl p-4">
            <div class="flex items-center justify-between mb-3">
              <p class="text-sm font-semibold text-dark">Pipeline de ventas</p>
              <p class="text-xs text-dark/40">Actualizado hace 2 min</p>
            </div>
            <div class="flex gap-2 h-8">
              <div class="bg-lemon-300 rounded-lg flex-[4] flex items-center justify-center text-xs font-semibold text-dark">Nuevos (42)</div>
              <div class="bg-lemon-400 rounded-lg flex-[3] flex items-center justify-center text-xs font-semibold text-dark">Contactados (31)</div>
              <div class="bg-lemon-500 rounded-lg flex-[2] flex items-center justify-center text-xs font-semibold text-white">Propuesta (18)</div>
              <div class="bg-dark rounded-lg flex-[1] flex items-center justify-center text-xs font-semibold text-white">Cerrados (9)</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROBLEMA ========== -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-lemon-500 font-semibold text-sm tracking-wide uppercase mb-3">El problema</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-dark tracking-tight">
          Tu equipo de ventas merece mejores herramientas
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        <div class="flex gap-4 p-6 bg-red-50/60 rounded-2xl border border-red-100">
          <div class="shrink-0 w-10 h-10 rounded-xl bg-red-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-dark mb-1">Leads que se pierden</h3>
            <p class="text-sm text-dark/60">Falta de seguimiento oportuno hace que oportunidades calientes se enfrien y se pierdan.</p>
          </div>
        </div>

        <div class="flex gap-4 p-6 bg-red-50/60 rounded-2xl border border-red-100">
          <div class="shrink-0 w-10 h-10 rounded-xl bg-red-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-dark mb-1">Campañas sin optimización</h3>
            <p class="text-sm text-dark/60">Inviertes en ads sin saber cuáles generan clientes reales. Sin tracking ni ROI claro.</p>
          </div>
        </div>

        <div class="flex gap-4 p-6 bg-red-50/60 rounded-2xl border border-red-100">
          <div class="shrink-0 w-10 h-10 rounded-xl bg-red-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-dark mb-1">CRMs que nadie usa</h3>
            <p class="text-sm text-dark/60">Herramientas complicadas que tu equipo termina abandonando. Los datos quedan desactualizados.</p>
          </div>
        </div>

        <div class="flex gap-4 p-6 bg-red-50/60 rounded-2xl border border-red-100">
          <div class="shrink-0 w-10 h-10 rounded-xl bg-red-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-dark mb-1">Datos dispersos</h3>
            <p class="text-sm text-dark/60">Información repartida entre planillas, WhatsApp, email y mil herramientas que no se conectan.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SOLUCIÓN - 3 PILARES ========== -->
  <section class="py-20 sm:py-28">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-lemon-500 font-semibold text-sm tracking-wide uppercase mb-3">La solución</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-dark tracking-tight">
          3 pilares, un solo entorno
        </h2>
        <p class="text-dark/60 mt-4 max-w-xl mx-auto">
          Todo lo que tu equipo comercial necesita para vender más, conectado y potenciado con inteligencia artificial.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- CRM Inteligente -->
        <div class="bg-white rounded-2xl p-8 border border-dark/5 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-lemon-300/20 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-lemon-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">CRM Inteligente</h3>
          <ul class="space-y-3 text-sm text-dark/60">
            <li class="flex gap-2">
              <svg class="w-5 h-5 text-lemon-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              Calificación automática de leads con IA
            </li>
            <li class="flex gap-2">
              <svg class="w-5 h-5 text-lemon-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              Seguimiento inteligente: te dice a quién contactar y cuándo
            </li>
            <li class="flex gap-2">
              <svg class="w-5 h-5 text-lemon-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              Pipeline visual y simple
            </li>
          </ul>
        </div>

        <!-- Gestión de Ads -->
        <div class="bg-white rounded-2xl p-8 border border-dark/5 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-lemon-300/20 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-lemon-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Gestión de Ads</h3>
          <ul class="space-y-3 text-sm text-dark/60">
            <li class="flex gap-2">
              <svg class="w-5 h-5 text-lemon-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              Manejo y optimización de campañas (Google, Meta, etc.)
            </li>
            <li class="flex gap-2">
              <svg class="w-5 h-5 text-lemon-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              Tracking de conversiones real conectado al CRM
            </li>
            <li class="flex gap-2">
              <svg class="w-5 h-5 text-lemon-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              Reportes de ROI claros
            </li>
          </ul>
        </div>

        <!-- Optimización de Ventas -->
        <div class="bg-white rounded-2xl p-8 border border-dark/5 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-lemon-300/20 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-lemon-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Optimización de Ventas</h3>
          <ul class="space-y-3 text-sm text-dark/60">
            <li class="flex gap-2">
              <svg class="w-5 h-5 text-lemon-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              Análisis de embudo completo
            </li>
            <li class="flex gap-2">
              <svg class="w-5 h-5 text-lemon-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              Recomendaciones de IA para mejorar conversión
            </li>
