---
import Layout from '../layouts/Layout.astro';
import NicheLanding from '../components/NicheLanding.astro';

const whatsappUrl = "https://wa.me/56977066965?text=Hola,%20soy%20abogado%20y%20quiero%20saber%20de%20Lelemon";

const chatMessages = [
  { sender: 'client' as const, text: 'Hola me echaron del trabajo hace 3 días, no me han pagado nada. Necesito un abogado', time: '22:47' },
  { sender: 'ai' as const, text: 'Hola, lamento tu situación. Para orientarte mejor: ¿firmaste finiquito?', time: '22:47' },
  { sender: 'client' as const, text: 'No todavía no firmé nada', time: '22:48' },
  { sender: 'ai' as const, text: 'Bien, es importante que no firmes nada sin asesoría. ¿Te sirve una consulta mañana a las 10 o a las 16 con el abogado?', time: '22:48' },
  { sender: 'client' as const, text: 'Mañana a las 10 porfa', time: '22:49' },
  { sender: 'ai' as const, text: 'Perfecto, quedas agendado. ¿Tu nombre completo y RUT? Así el abogado ya tiene tu info antes de la reunión', time: '22:49' },
];

const painPoints = [
  "Te llegan consultas a las 10pm. Respondes a las 9am. Para entonces el cliente ya habló con otros 3 abogados",
  "Dependes de que te recomienden. Si paran los referidos, no entra nadie nuevo",
  "Pagaste por un aviso en Google y no sabes si generó una sola consulta real",
  "Alguien busca 'abogado laboral Santiago' en Google y no apareces ni en la página 3",
  "Pasas horas respondiendo las mismas preguntas: '¿cuánto cobra?', '¿atiende mi caso?', '¿dónde queda?'",
];

const benefits = [
  {
    title: "Apareces cuando te buscan, no cuando te recomiendan",
    description: "Web optimizada para que cuando alguien googlee 'abogado laboral Santiago' o 'abogado de familia Chile', aparezcas tú con tus áreas de práctica, experiencia y un botón directo a WhatsApp.",
  },
  {
    title: "Un asistente que califica casos mientras duermes",
    description: "Responde a las 11pm, a las 3am, en feriados. Identifica el tipo de caso, evalúa urgencia, recoge los datos clave y agenda la consulta. Tú ves en el panel: quién es, qué pasó, si firmó finiquito o no.",
  },
  {
    title: "Publicidad que trae casos, no curiosos",
    description: "Google Ads cuando alguien busca abogado + Meta para captar personas con problemas legales reales. Sabes exactamente cuántas consultas genera cada peso que inviertes.",
  },
];

const faqs = [
  { question: "¿El asistente da asesoría legal?", answer: "Nunca. Recoge información, califica el caso y agenda con el abogado. No interpreta la ley ni da consejos. Está entrenado para derivar siempre al profesional." },
  { question: "¿Sirve para estudios con varios abogados?", answer: "Sí. El asistente puede derivar por especialidad — laboral, familia, civil, penal — y agendar con el abogado correcto. Cada uno ve sus casos." },
  { question: "¿Puedo ver las conversaciones?", answer: "Todas. Panel completo con cada chat, datos del cliente, tipo de caso y estado. Te puedes meter a cualquier conversación y tomar el control." },
  { question: "¿Cuánto se demora?", answer: "El asistente se activa en 3-5 días. La web en 1-2 semanas según el contenido por especialidad. Campañas arrancan cuando la web esté lista." },
  { question: "¿Cuánto sale?", answer: "Desde $249 USD/mes + $149 de setup una vez. Primer mes gratis. Sin contrato, cancelas cuando quieras. Publicidad se paga directo a Google o Meta." },
];
---

<Layout
  title="Deja de depender de referidos | Lelemon para Abogados"
  description="Asistente IA que califica casos por WhatsApp 24/7, web que posiciona tu especialidad en Google y campañas que traen clientes. Para abogados en Chile. Primer mes gratis."
  canonicalUrl="https://lelemon.cl/para-abogados/"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Lelemon para Abogados",
    "description": "Agencia digital para estudios jurídicos y abogados en Chile. Web profesional, asistente inteligente en WhatsApp y campañas que traen clientes con casos reales.",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Lelemon",
      "url": "https://lelemon.cl"
    },
    "areaServed": { "@type": "Country", "name": "Chile" },
    "audience": { "@type": "Audience", "audienceType": "Abogados y estudios jurídicos en Chile" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
    }))
  })} />

  <NicheLanding
    niche="Abogados"
    nicheSlug="abogados"
    heroTitle="El que responde primero"
    heroHighlight="se queda con el caso."
    heroDescription="A las 10pm alguien necesita un abogado urgente. Le escribe a tres. El que contesta primero se queda con el cliente. ¿Vas a seguir respondiendo mañana a las 9?"
    painTitle="Estás perdiendo casos todos los días y ni te enteras."
    painDescription="Alguien fue despedido hoy. Buscó 'abogado laboral' en Google. Te encontró... y también a otros 5. Le escribió a todos por WhatsApp. Tú respondiste mañana. Los otros dos ya lo habían llamado."
    painPoints={painPoints}
    chatBusiness="Estudio Jurídico Valdés"
    chatMessages={chatMessages}
    chatResult={{ priority: "Caso urgente", name: "Persona por confirmar", detail: "Despido sin finiquito · No firmó nada · Consulta mañana 10am" }}
    benefits={benefits}
    faqs={faqs}
    whatsappUrl={whatsappUrl}
  />
</Layout>
