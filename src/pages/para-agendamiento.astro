---
import Layout from '../layouts/Layout.astro';
import NichePageLight from '../components/NichePageLight.astro';

const whatsappUrl = "https://wa.me/56977066965?text=Hola,%20quiero%20saber%20de%20Lelemon";

const chatMessages = [
  { sender: 'client' as const, text: 'Hola, necesito una hora para mañana, ¿tienen disponibilidad?', time: '23:14' },
  { sender: 'ai' as const, text: 'Hola! Sí, mañana tenemos disponible a las 9:30 y a las 12:00. ¿Cuál te acomoda?', time: '23:14' },
  { sender: 'client' as const, text: '9:30 porfa', time: '23:15' },
  { sender: 'ai' as const, text: 'Perfecto, agendado mañana a las 9:30. Te enviaré un recordatorio en la mañana para que no se te olvide 😊', time: '23:15' },
];

const steps = [
  { number: '01', title: 'Tu cliente escribe por WhatsApp', description: 'A cualquier hora del día o la noche. El asistente responde en segundos, saluda y pregunta qué necesita.' },
  { number: '02', title: 'Revisa disponibilidad y propone horarios', description: 'Se conecta a tu agenda (Google Calendar u otro), ve los horarios disponibles y le ofrece opciones al cliente.' },
  { number: '03', title: 'Confirma, recuerda y reagenda', description: 'Agenda la cita, envía confirmación inmediata y un recordatorio automático antes de la hora. Si el cliente necesita reagendar, lo hace solo.' },
];

const benefits = [
  { icon: '🌙', title: 'Agenda citas a las 3am', description: 'Tus clientes reservan cuando quieren, no solo en horario de oficina. Fines de semana, feriados, madrugada.' },
  { icon: '🚫', title: 'Reduce inasistencias', description: 'Recordatorios automáticos por WhatsApp antes de cada cita. Menos no-shows, más productividad.' },
  { icon: '⚡', title: 'Respuesta en segundos', description: 'Sin esperar a que alguien conteste el teléfono o revise mensajes. El cliente agenda y sigue con su vida.' },
  { icon: '🔄', title: 'Reagendamiento sin fricción', description: 'El cliente puede cambiar su hora directamente por WhatsApp, sin llamar ni esperar.' },
  { icon: '📊', title: 'Control total de tu agenda', description: 'Ves todas las citas en tu panel. Sabes quién agendó, cuándo y para qué.' },
  { icon: '🤝', title: 'Tú decides cuándo intervenir', description: 'El asistente hace el trabajo repetitivo. Tú entras solo cuando hay algo que requiere tu atención.' },
];

const idealFor = [
  'Clínicas dentales y centros médicos que reciben consultas fuera de horario',
  'Peluquerías y salones de belleza con alta rotación de citas',
  'Consultorios de psicología, kinesiología y nutrición',
  'Talleres mecánicos y centros de servicio técnico',
  'Estudios de abogados y contadores con agenda de reuniones',
  'Centros de estética y spa que agendan tratamientos',
  'Veterinarias y clínicas de mascotas',
  'Cualquier negocio en Chile que agenda citas y pierde reservas fuera de horario',
];

const faqs = [
  { question: '¿Se conecta con Google Calendar?', answer: 'Sí. El asistente revisa tu disponibilidad en tiempo real y agenda directamente en tu calendario. También funciona con otros sistemas de agenda.' },
  { question: '¿Qué pasa si el cliente quiere reagendar?', answer: 'Puede hacerlo directamente por WhatsApp. El asistente le muestra nuevos horarios disponibles y actualiza la cita automáticamente.' },
  { question: '¿Envía recordatorios antes de la cita?', answer: 'Sí. Envía un recordatorio automático por WhatsApp el día anterior o la misma mañana (tú eliges). Esto reduce las inasistencias significativamente.' },
  { question: '¿Puedo bloquear horarios o días?', answer: 'Sí. Bloqueas lo que necesites en tu calendario y el asistente respeta esa disponibilidad. Si te enfermas un día, lo marcas y listo.' },
  { question: '¿Funciona los fines de semana y feriados?', answer: 'Funciona 24/7, los 365 días del año. Si tu negocio atiende sábados pero no domingos, el asistente lo sabe y solo ofrece horarios válidos.' },
];
---

<Layout
  title="Agendamiento por WhatsApp 24/7 para negocios en Chile | Lelemon"
  description="Automatiza tu agenda con un asistente IA en WhatsApp que revisa disponibilidad, propone horarios, confirma citas y envía recordatorios. Funciona 24/7."
  canonicalUrl="https://lelemon.cl/para-agendamiento/"
>
  <NichePageLight
    niche="Agendamiento"
    nicheSlug="agendamiento"
    emoji="📅"
    headline="Automatiza tus agendamientos por WhatsApp"
    subtitle="Tu asistente revisa disponibilidad, propone horarios, confirma la cita y manda recordatorio. Funciona a las 3am, los domingos, en feriados. Tus clientes agendan cuando quieren."
    highlights={[
      "Revisa disponibilidad y propone horarios en tiempo real",
      "Confirma, reagenda y manda recordatorios automáticos",
      "Funciona 24/7 sin intervención humana",
    ]}
    steps={steps}
    benefits={benefits}
    idealFor={idealFor}
    faqs={faqs}
    chatBusiness="Centro Médico Salud+"
    chatEmoji="📅"
    chatMessages={chatMessages}
    whatsappUrl={whatsappUrl}
  />
</Layout>
