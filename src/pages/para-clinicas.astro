---
import Layout from '../layouts/Layout.astro';
import NicheLanding from '../components/NicheLanding.astro';

const whatsappUrl = "https://wa.me/56977066965?text=Hola,%20tengo%20una%20clínica%20y%20quiero%20saber%20de%20Lelemon";

const chatMessages = [
  { sender: 'client' as const, text: 'Hola necesito una hora con dermatólogo, ojalá esta semana', time: '20:42' },
  { sender: 'ai' as const, text: 'Hola! Tenemos hora con la Dra. Morales el jueves a las 10:00 y el viernes a las 15:30. ¿Cuál te acomoda?', time: '20:42' },
  { sender: 'client' as const, text: 'Jueves a las 10', time: '20:43' },
  { sender: 'ai' as const, text: '¿Tienes Fonasa o Isapre? Y tu nombre completo para agendar', time: '20:43' },
  { sender: 'client' as const, text: 'Isapre Colmena, Valentina Paredes', time: '20:44' },
  { sender: 'ai' as const, text: 'Listo Valentina, agendada con Dra. Morales jueves 10am. Trae tu carnet de Isapre y cédula. Te mando recordatorio el miércoles', time: '20:44' },
];

const painPoints = [
  "Tu recepción atiende teléfono, agenda, cobra y responde WhatsApp. Las llamadas se pierden y los pacientes se van",
  "Tienes 5 especialistas y la mitad tiene huecos en la agenda porque nadie les llena las horas",
  "Gastas en publicidad pero no sabes cuántos pacientes nuevos llegan por ahí vs. por referido",
  "Pacientes agendan y no llegan. Nadie mandó recordatorio y perdiste esa hora productiva",
  "Tu competencia sale primero en Google. Tú ni siquiera tienes una web que se vea bien en el celular",
];

const benefits = [
  {
    title: "Una web que vende tus especialidades, no solo las lista",
    description: "Dermatología, kinesiología, nutrición — cada especialidad con su página, su contenido optimizado y su botón de WhatsApp. Cuando alguien busca 'dermatólogo en Las Condes', apareces tú.",
  },
  {
    title: "Un asistente que agenda con el especialista correcto",
    description: "El paciente dice qué necesita, el asistente identifica la especialidad, muestra horarios disponibles, pide datos y agenda. Funciona a las 8pm, a las 6am, los domingos. Tu recepción respira.",
  },
  {
    title: "Campañas que llenan las horas de todos tus especialistas",
    description: "¿El kinesiólogo tiene huecos los martes? Campaña de kinesiología los martes. ¿La dermatóloga está copada? Bajamos esa campaña. Control total sobre qué agenda llenar y cuándo.",
  },
];

const faqs = [
  { question: "¿Funciona con varias especialidades?", answer: "Sí. El asistente maneja todas las especialidades de tu clínica. Identifica qué necesita el paciente y agenda con el profesional correcto según disponibilidad." },
  { question: "¿Se integra con nuestro sistema de agenda?", answer: "Trabajamos con las agendas más comunes. En la llamada inicial vemos qué sistema usas y cómo nos integramos. Si no hay sistema, nosotros te damos uno." },
  { question: "¿Puedo ver las estadísticas por especialista?", answer: "Sí. En el panel ves cuántas consultas recibe cada especialidad, cuántos agendan, cuántos llegan y de dónde vienen (Google, Instagram, referido)." },
  { question: "¿Cuánto se demora?", answer: "El asistente en 3-5 días. La web en 2-3 semanas porque tiene más contenido por especialidad. Campañas arrancan cuando la web esté lista." },
  { question: "¿Cuánto sale?", answer: "Desde $249 USD/mes + $149 de setup una vez. Primer mes gratis. Sin contrato, cancelas cuando quieras. Publicidad se paga directo a Google o Meta." },
];
---

<Layout
  title="Deja de perder pacientes en la sala de espera digital | Lelemon para Clínicas"
  description="Asistente IA que agenda pacientes por WhatsApp 24/7 con el especialista correcto, web que posiciona todas tus especialidades y campañas que llenan la agenda. Primer mes gratis."
  canonicalUrl="https://lelemon.cl/para-clinicas/"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Lelemon para Clínicas",
    "description": "Agencia digital para clínicas y centros médicos en Chile. Web profesional, asistente inteligente en WhatsApp y campañas que traen pacientes por especialidad.",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Lelemon",
      "url": "https://lelemon.cl"
    },
    "areaServed": { "@type": "Country", "name": "Chile" },
    "audience": { "@type": "Audience", "audienceType": "Clínicas y centros médicos en Chile" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
    }))
  })} />

  <NicheLanding
    niche="Clínicas"
    nicheSlug="clinicas"
    heroTitle="5 especialistas."
    heroHighlight="La mitad con huecos en la agenda."
    heroDescription="Tu clínica tiene capacidad para atender el doble de pacientes. El problema no es falta de demanda — es que la gente no te encuentra, no te contesta nadie y se van a otro lado."
    painTitle="Estás pagando arriendo, sueldos y equipos para atender a la mitad de los pacientes que podrías."
    painDescription="Tienes un kinesiólogo con 3 horas libres al día y una dermatóloga con lista de espera de 2 semanas. El problema no es tu equipo. Es que nadie está llenando esas agendas de forma inteligente."
    painPoints={painPoints}
    chatBusiness="Centro Médico Salud Vital"
    chatMessages={chatMessages}
    chatResult={{ priority: "Paciente nuevo", name: "Valentina Paredes", detail: "Dermatología · Isapre Colmena · Jueves 10am · Dra. Morales" }}
    benefits={benefits}
    faqs={faqs}
    whatsappUrl={whatsappUrl}
  />
</Layout>
