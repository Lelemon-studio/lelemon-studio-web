---
import Layout from '../layouts/Layout.astro';
import NichePageLight from '../components/NichePageLight.astro';

const whatsappUrl = "https://wa.me/56950467634?text=Hola,%20quiero%20saber%20de%20Lelemon";

const chatMessages = [
  { sender: 'client' as const, text: 'Hola, tienen la polera negra en talla M?', time: '20:32' },
  { sender: 'ai' as const, text: 'Hola! Sí, la polera negra está disponible en M y L. Además tiene 20% de descuento, queda en $14.990 🔥', time: '20:32' },
  { sender: 'client' as const, text: 'Buena! La quiero en M', time: '20:33' },
  { sender: 'ai' as const, text: 'Perfecto! Aquí tienes tu link de pago 👉 pay.link/moda-bella/14990. Apenas confirmes el pago te envío los datos de despacho.', time: '20:33' },
];

const steps = [
  { number: '01', title: 'El cliente pregunta por un producto', description: 'Puede preguntar precio, stock, tallas, colores o cualquier detalle. El asistente responde con la información actualizada de tu catálogo.' },
  { number: '02', title: 'El asistente vende y aplica descuentos', description: 'Muestra opciones, informa promociones activas, responde objeciones y guía al cliente hacia la compra.' },
  { number: '03', title: 'Envía link de pago y cierra la venta', description: 'Genera y envía el link de pago directo por WhatsApp. El cliente paga sin salir de la conversación.' },
];

const benefits = [
  { icon: '💸', title: 'Vende mientras duermes', description: 'A las 11pm alguien pregunta por un producto. A las 11:01 ya tiene el link de pago. Sin que tú hagas nada.' },
  { icon: '🏷️', title: 'Aplica descuentos automáticos', description: 'Configura tus promociones y el asistente las aplica cuando corresponde. Black Friday, fin de temporada, lo que sea.' },
  { icon: '📦', title: 'Informa stock en tiempo real', description: 'Si el producto está agotado, lo dice y sugiere alternativas. Nada de vender algo que no tienes.' },
  { icon: '💬', title: 'Responde objeciones', description: 'Conoce tus productos, políticas de cambio, tiempos de despacho. Responde dudas que frenan la compra.' },
  { icon: '🔗', title: 'Link de pago integrado', description: 'Genera links de pago directos. El cliente paga en 2 clics sin salir de WhatsApp.' },
  { icon: '📈', title: 'Más conversiones, menos abandono', description: 'Cada segundo que un cliente espera respuesta, aumenta la probabilidad de que se vaya. El asistente responde al instante.' },
];

const idealFor = [
  'Tiendas de ropa, zapatos y accesorios que venden por redes sociales',
  'Negocios de comida, bakeries y pastelerías que reciben pedidos',
  'Tiendas de productos naturales, suplementos y cosmética',
  'Ferreterías y distribuidoras con catálogos amplios',
  'Joyerías y tiendas de regalos con consultas frecuentes',
  'Emprendedores que venden por Instagram y derivan a WhatsApp',
  'Distribuidores B2B que reciben pedidos por WhatsApp',
  'Cualquier negocio en Chile que vende productos y pierde ventas por responder tarde',
];

const faqs = [
  { question: '¿El asistente conoce todos mis productos?', answer: 'Sí. Lo entrenamos con tu catálogo completo: nombres, precios, tallas, colores, stock. Cuando actualizas algo, el asistente lo sabe.' },
  { question: '¿Puede enviar fotos de los productos?', answer: 'Sí. Puede enviar imágenes del producto que el cliente pregunta, directo por WhatsApp.' },
  { question: '¿Cómo funciona el link de pago?', answer: 'Se integra con tu pasarela de pago (Mercado Pago, Flow, Transbank u otra). El asistente genera un link único por pedido y lo envía en el chat.' },
  { question: '¿Qué pasa si un producto está agotado?', answer: 'El asistente informa que no hay stock y puede sugerir alternativas similares. También puede avisar cuando vuelva a estar disponible.' },
  { question: '¿Puedo tomar el control de la conversación?', answer: 'En cualquier momento. Si el cliente tiene una duda compleja o quieres cerrar tú la venta, entras al chat y el asistente se retira.' },
];
---

<Layout
  title="Vende con asistente IA 24/7 en Chile | Lelemon"
  description="Asistente IA que responde consultas, muestra precios, aplica descuentos y envía links de pago por WhatsApp, Instagram y Messenger. Vende mientras duermes."
  canonicalUrl="https://lelemon.cl/para-ventas/"
>
  <NichePageLight
    niche="Ventas"
    nicheSlug="ventas"
    emoji="💰"
    headline="Vende con un asistente IA que nunca duerme"
    subtitle="Tu asistente responde consultas de productos, informa precios, aplica descuentos activos y envía link de pago. Por WhatsApp, Instagram y Messenger, a cualquier hora."
    highlights={[
      "Responde consultas de precio y stock al instante",
      "Envía link de pago directo por WhatsApp",
      "Aplica descuentos y promociones activas automáticamente",
    ]}
    steps={steps}
    benefits={benefits}
    idealFor={idealFor}
    faqs={faqs}
    chatBusiness="Tienda Moda Bella"
    chatEmoji="👜"
    chatMessages={chatMessages}
    whatsappUrl={whatsappUrl}
  />
</Layout>
