---
import Layout from '../layouts/Layout.astro';
import NichePageLight from '../components/NichePageLight.astro';

const whatsappUrl = "https://wa.me/56977066965?text=Hola,%20quiero%20saber%20de%20Lelemon";

const chatMessages = [
  { sender: 'client' as const, text: 'Hola, dónde va mi pedido #4521?', time: '15:40' },
  { sender: 'ai' as const, text: 'Hola! Tu pedido #4521 está en camino con Starken, código de seguimiento ST-884521. Llega estimado el miércoles 12 📦', time: '15:40' },
  { sender: 'client' as const, text: 'Necesito cambiar la dirección de entrega', time: '15:41' },
  { sender: 'ai' as const, text: 'Tu pedido ya fue despachado, así que no puedo cambiar la dirección directamente. Pero ya notifiqué al courier para que se comuniquen contigo y coordinen la entrega 👍', time: '15:41' },
];

const steps = [
  { number: '01', title: 'El cliente pregunta algo', description: 'Estado de pedido, política de cambios, horarios, precios, garantía. El asistente tiene toda la info de tu negocio y responde al instante.' },
  { number: '02', title: 'Resuelve sin intervención humana', description: 'El 80% de las consultas son repetitivas. El asistente las resuelve solo: tracking, FAQ, instrucciones, información general.' },
  { number: '03', title: 'Escala lo que necesita atención humana', description: 'Si el caso es complejo o el cliente quiere hablar con una persona, el asistente te notifica y te pasa el contexto completo.' },
];

const benefits = [
  { icon: '⚡', title: 'Respuesta inmediata, siempre', description: 'Tus clientes no esperan. Escriben y tienen respuesta en segundos. A las 3am, un domingo, en feriado.' },
  { icon: '🧠', title: 'Conoce tu negocio completo', description: 'Entrenado con tus FAQ, políticas, horarios, productos. Responde como lo harías tú, pero sin cansarse.' },
  { icon: '🔀', title: 'Escalamiento inteligente', description: 'No todo se puede resolver con IA. Cuando detecta un caso complejo, te lo pasa con todo el contexto de la conversación.' },
  { icon: '😊', title: 'Mejora la experiencia del cliente', description: 'Responder rápido genera confianza. Clientes satisfechos vuelven y recomiendan.' },
  { icon: '📉', title: 'Menos carga para tu equipo', description: 'Tu equipo deja de responder "¿cuál es el horario?" 50 veces al día. Se enfoca en lo que realmente importa.' },
  { icon: '📊', title: 'Ves cada conversación', description: 'Panel con historial completo. Sabes qué preguntan más, qué falta en tu FAQ y dónde mejorar.' },
];

const idealFor = [
  'E-commerce y tiendas online que reciben consultas de envío y cambios',
  'Restaurantes y servicios de delivery con consultas recurrentes',
  'Empresas de servicios con clientes que preguntan horarios y disponibilidad',
  'Clínicas y centros de salud con preguntas frecuentes de pacientes',
  'Inmobiliarias con consultas de arriendo, visitas y documentación',
  'Gimnasios y centros deportivos con consultas de planes y horarios',
  'Empresas de transporte y logística con seguimiento de envíos',
  'Cualquier negocio en Chile que pierde tiempo respondiendo las mismas preguntas',
];

const faqs = [
  { question: '¿El asistente puede resolver problemas complejos?', answer: 'Resuelve consultas basadas en la información que tiene: FAQ, políticas, estado de pedidos. Para casos que requieren criterio humano, escala automáticamente a tu equipo con todo el contexto.' },
  { question: '¿Cómo sabe qué responder?', answer: 'Lo entrenamos con la información de tu negocio: preguntas frecuentes, políticas, horarios, productos, precios. Tú validas las respuestas antes de activarlo.' },
  { question: '¿Qué pasa si el cliente se enoja?', answer: 'El asistente detecta frustración y ofrece hablar con una persona. Te notifica inmediatamente con el contexto completo para que puedas intervenir.' },
  { question: '¿Puedo actualizar las respuestas?', answer: 'Sí. Cuando cambias horarios, políticas o cualquier info, actualizamos el asistente y al instante tiene la nueva información.' },
  { question: '¿Cuántas consultas puede manejar a la vez?', answer: 'Ilimitadas. Puede atender 1 o 100 conversaciones simultáneas sin degradar calidad. No hay cola de espera.' },
];
---

<Layout
  title="Atención al cliente con IA 24/7 | Lelemon"
  description="Asistente IA que resuelve dudas, informa estado de pedidos y escala casos complejos. Disponible 24/7 en WhatsApp, Instagram y Messenger para negocios en Chile."
  canonicalUrl="https://lelemon.cl/para-soporte/"
>
  <NichePageLight
    niche="Soporte"
    nicheSlug="soporte"
    emoji="🛟"
    headline="Atención al cliente con IA, disponible 24/7"
    subtitle="Tu asistente resuelve dudas frecuentes, da instrucciones, informa estado de pedidos y escala a humano solo cuando es necesario. En WhatsApp, Instagram y Messenger."
    highlights={[
      "Resuelve el 80% de consultas sin intervención humana",
      "Escala casos complejos automáticamente a tu equipo",
      "Disponible 24/7 — domingos, feriados, madrugada",
    ]}
    steps={steps}
    benefits={benefits}
    idealFor={idealFor}
    faqs={faqs}
    chatBusiness="TechStore Chile"
    chatEmoji="🛟"
    chatMessages={chatMessages}
    whatsappUrl={whatsappUrl}
  />
</Layout>
